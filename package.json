{
  "name": "novanet",
  "version": "0.1.0",
  "private": true,
  "description": "NovaNet - Knowledge graph localization orchestrator",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@novanet/studio",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --filter=@novanet/studio",
    "infra:up": "pnpm --filter=@novanet/db up",
    "infra:down": "pnpm --filter=@novanet/db down",
    "infra:seed": "pnpm --filter=@novanet/db seed",
    "infra:reset": "pnpm --filter=@novanet/db reset",
    "validate:types": "npx tsx scripts/validate-types.ts",
    "schema:generate": "cargo run --manifest-path tools/novanet/Cargo.toml -- schema generate",
    "schema:validate": "cargo run --manifest-path tools/novanet/Cargo.toml -- schema validate",
    "doc:generate": "cargo run --manifest-path tools/novanet/Cargo.toml -- doc generate",
    "doc:audit": "./tools/scripts/doc-audit.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@turbo/gen": "^2.8.0",
    "husky": "^9.1.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
