{
  "name": "novanet",
  "version": "0.20.0",
  "private": true,
  "description": "NovaNet - Knowledge graph localization orchestrator",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@novanet/studio",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --filter=@novanet/studio",
    "infra:up": "pnpm --filter=@novanet/db up",
    "infra:down": "pnpm --filter=@novanet/db down",
    "infra:seed": "pnpm --filter=@novanet/db seed",
    "infra:reset": "pnpm --filter=@novanet/db reset",
    "db:backup": "pnpm --filter=@novanet/db backup",
    "db:backup:list": "pnpm --filter=@novanet/db backup:list",
    "db:restore": "pnpm --filter=@novanet/db restore",
    "validate:types": "npx tsx scripts/validate-types.ts",
    "validate:design-system": "node tools/scripts/validate-design-system.mjs",
    "verify:quick": "./tools/scripts/verify-design-system.sh --quick",
    "verify:full": "./tools/scripts/verify-design-system.sh --full",
    "verify:ci": "./tools/scripts/verify-design-system.sh --ci",
    "schema:generate": "cargo run --manifest-path tools/novanet/Cargo.toml -- schema generate",
    "schema:validate": "cargo run --manifest-path tools/novanet/Cargo.toml -- schema validate",
    "doc:generate": "cargo run --manifest-path tools/novanet/Cargo.toml -- doc generate",
    "doc:audit": "./tools/scripts/doc-audit.sh",
    "skill:audit": "./tools/scripts/skill-audit.sh",
    "audit:all": "./tools/scripts/doc-audit.sh && ./tools/scripts/skill-audit.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@turbo/gen": "^2.8.14",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "tmp": ">=0.2.4",
      "@tootallnate/once": ">=3.0.1",
      "dompurify": ">=3.3.2",
      "flatted": ">=3.4.0"
    }
  }
}
