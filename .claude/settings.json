{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(docker:*)",
      "Bash(git:*)",
      "Bash(cargo:*)",
      "mcp__neo4j__*"
    ]
  },
  "env": {
    "NEO4J_URI": "neo4j://localhost:7687",
    "NEO4J_USERNAME": "neo4j"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-format.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "pathPattern": "**/tui/*.rs",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/keybindings-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "pathPattern": "**/tools/novanet/**/*.rs",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/semantic-check.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "pathPattern": "**/models/**/*.yaml",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/yaml-sync-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "pathPattern": "**/models/views.yaml",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/views-sync-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "pathPattern": "**/{CLAUDE,README}.md|**/.claude/**/*.md",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/doc-sync-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "pathPattern": "**/.claude/rules/adr/**/*.md",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/adr-context.sh"
          }
        ]
      }
    ]
  }
}
