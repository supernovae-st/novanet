# Neo4j Connection (REQUIRED)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=novanetpassword

# Anthropic API (for AI Chat)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Environment
NODE_ENV=development

# =============================================================================
# Security Configuration (optional in development)
# =============================================================================

# Authentication mode: 'disabled' | 'api-key' | 'jwt'
# Set to 'api-key' in production
AUTH_MODE=disabled

# Comma-separated list of valid API keys (required if AUTH_MODE=api-key)
# Generate with: openssl rand -hex 32
# API_KEYS=key1,key2,key3
