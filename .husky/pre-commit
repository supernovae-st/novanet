#!/usr/bin/env sh

# Schema sync validation - runs when YAML models are changed
# Ensures generated artifacts stay in sync with YAML source of truth

# Check if YAML models changed in this commit
if git diff --cached --name-only | grep -q "packages/core/models/"; then
  echo "📋 YAML models changed - validating sync..."

  # Run schema validation
  pnpm schema:validate

  if [ $? -ne 0 ]; then
    echo ""
    echo "════════════════════════════════════════════════════════════"
    echo "❌ Schema sync validation failed!"
    echo ""
    echo "To fix, run:"
    echo "  pnpm schema:generate"
    echo ""
    echo "Then stage the regenerated files:"
    echo "  git add packages/core/src/graph/layers.ts"
    echo "  git add packages/core/src/graph/hierarchy.ts"
    echo "  git add packages/db/seed/"
    echo "════════════════════════════════════════════════════════════"
    exit 1
  fi

  echo "✅ Schema sync validated"
fi
