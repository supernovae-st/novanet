#!/usr/bin/env sh

# Pre-commit validation for supernovae-agi monorepo
# - Conventional commit format (via commit-msg hook)
# - NovaNet: Schema sync, design system coherence
# - Nika: Rust clippy validation
# - Both: Lint and format checks

set -e

CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

echo "🔍 Running pre-commit checks..."

# =============================================================================
# NovaNet: Schema Sync Validation
# =============================================================================

if echo "$CHANGED_FILES" | grep -q "novanet-dev/packages/core/models/"; then
  echo "📋 NovaNet YAML models changed - validating sync..."

  cd novanet-dev
  cargo run --quiet -- schema validate || {
    echo ""
    echo "════════════════════════════════════════════════════════════"
    echo "❌ Schema sync validation failed!"
    echo ""
    echo "To fix, run:"
    echo "  cd novanet-dev && cargo run -- schema generate"
    echo "════════════════════════════════════════════════════════════"
    exit 1
  }
  cd ..

  echo "✅ Schema sync validated"
fi

# =============================================================================
# NovaNet: Design System Coherence Validation
# =============================================================================

DESIGN_SYSTEM_PATTERNS="taxonomy.yaml|visual-encoding.yaml|tui/theme.rs|graph/layers.ts"

if echo "$CHANGED_FILES" | grep -Eq "novanet-dev/.*($DESIGN_SYSTEM_PATTERNS)"; then
  echo "🎨 Design system files changed - validating coherence..."

  cd novanet-dev
  if command -v pnpm > /dev/null && [ -f "package.json" ]; then
    pnpm validate:design-system 2>/dev/null || echo "⚠️  Design system validation skipped (script not found)"
  fi
  cd ..

  echo "✅ Design system coherence validated"
fi

# =============================================================================
# NovaNet: TypeScript Lint
# =============================================================================

if echo "$CHANGED_FILES" | grep -q "novanet-dev/.*\.\(ts\|tsx\)$"; then
  echo "🔷 NovaNet TypeScript files changed - running lint..."

  cd novanet-dev
  pnpm lint --quiet 2>/dev/null || {
    echo "❌ TypeScript lint failed. Run: cd novanet-dev && pnpm lint"
    exit 1
  }
  cd ..

  echo "✅ NovaNet TypeScript lint passed"
fi

# =============================================================================
# NovaNet: Rust Clippy
# =============================================================================

if echo "$CHANGED_FILES" | grep -q "novanet-dev/tools/.*\.rs$"; then
  echo "🦀 NovaNet Rust files changed - running clippy..."

  cd novanet-dev/tools/novanet
  cargo clippy --quiet -- -D warnings 2>/dev/null || {
    echo "❌ NovaNet clippy failed. Run: cd novanet-dev/tools/novanet && cargo clippy"
    exit 1
  }
  cd ../../..

  echo "✅ NovaNet Rust clippy passed"
fi

# =============================================================================
# Nika: Rust Clippy
# =============================================================================

if echo "$CHANGED_FILES" | grep -q "nika-dev/tools/.*\.rs$"; then
  echo "🦀 Nika Rust files changed - running clippy..."

  cd nika-dev/tools/nika
  cargo clippy --quiet -- -D warnings 2>/dev/null || {
    echo "❌ Nika clippy failed. Run: cd nika-dev/tools/nika && cargo clippy"
    exit 1
  }
  cd ../../..

  echo "✅ Nika Rust clippy passed"
fi

echo "✅ All pre-commit checks passed!"
