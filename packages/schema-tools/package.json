{
  "name": "@novanet/schema-tools",
  "version": "1.0.0",
  "description": "Build-time generators and validators for NovaNet schema",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "generate:all": "tsx scripts/generate-all.ts",
    "validate:sync": "tsx scripts/validate-sync.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts --ext .ts"
  },
  "dependencies": {
    "@novanet/core": "workspace:*",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "eslint": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:"
  }
}
