{
  "name": "@novanet/core",
  "version": "8.1.0",
  "description": "NovaNet Neo4j graph models and TypeScript layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./filters": {
      "types": "./dist/filters/index.d.ts",
      "import": "./dist/filters/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "import": "./dist/schemas/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "import:locale-knowledge": "tsx scripts/import-locale-knowledge.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts --ext .ts",
    "validate": "npm run validate:schema && npm run validate:version && npm run validate:relations",
    "validate:schema": "tsx scripts/validate-schema.ts",
    "validate:version": "tsx scripts/validate-version.ts",
    "validate:relations": "tsx scripts/validate-relations.ts",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "validate:docs": "tsx scripts/validate-docs.ts"
  },
  "dependencies": {
    "neo4j-driver": "^5.28.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
