{
  "name": "@novanet/core",
  "version": "8.1.0",
  "description": "NovaNet Neo4j graph models and TypeScript layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "import:locale-knowledge": "tsx scripts/import-locale-knowledge.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts --ext .ts",
    "validate": "npm run validate:schema && npm run validate:version && npm run validate:relations",
    "validate:schema": "tsx scripts/validate-schema.ts",
    "validate:version": "tsx scripts/validate-version.ts",
    "validate:relations": "tsx scripts/validate-relations.ts",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "validate:docs": "tsx scripts/validate-docs.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "neo4j-driver": "^5.27.0",
    "openai": "^6.17.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^2.1.0"
  }
}
