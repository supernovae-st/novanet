# NovaNet Core - Pre-commit Hooks (Strict Mode)
# Validates: TypeScript, YAML, schemas, versions, relations

echo "🔍 Running pre-commit checks..."

# 1. TypeScript compile check
echo "📦 TypeScript compile..."
npm run build || exit 1

# 2. Lint (optional - only if eslint is installed)
if command -v eslint &> /dev/null || npm list eslint &> /dev/null; then
  echo "🧹 ESLint..."
  npm run lint || exit 1
else
  echo "⚠️  ESLint not installed, skipping..."
fi

# 3. YAML lint (if yamllint installed)
if command -v yamllint &> /dev/null; then
  echo "📄 YAML lint..."
  yamllint models/ config/ seed/ 2>/dev/null || echo "⚠️  YAML lint warnings (non-blocking)"
fi

# 4. Schema validation
echo "✅ Schema validation..."
npm run validate:schema || exit 1

# 5. Version consistency check
echo "🔢 Version consistency..."
npm run validate:version || exit 1

# 6. Relation registry check
echo "🔗 Relation registry..."
npm run validate:relations || exit 1

# 7. Documentation generation and validation
# Check if any view YAML, types, generators, or relations changed
DOCS_CHANGED=$(git diff --cached --name-only -- 'models/views/*.yaml' 'models/relations.yaml' 'models/_index.yaml' 'src/types/*.ts' 'src/generators/*.ts' 2>/dev/null | wc -l)
if [ "$DOCS_CHANGED" -gt 0 ]; then
  echo "📄 Regenerating documentation..."
  npm run generate:docs 2>/dev/null
  # Auto-stage regenerated docs
  git add models/docs/views/VIEW-*.md 2>/dev/null || true
  git add neo4j/queries/*.cypher 2>/dev/null || true
fi

# 8. Validate docs match source of truth
echo "📋 Validating docs against source..."
npm run validate:docs || exit 1

echo "✅ All checks passed!"
