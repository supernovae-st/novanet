{
  "name": "@novanet/db",
  "version": "0.20.0",
  "private": true,
  "description": "NovaNet database infrastructure - Neo4j seeds, migrations, and Docker",
  "scripts": {
    "up": "docker compose up -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "seed": "./seed.sh",
    "reset": "docker compose down -v && docker compose up -d && sleep 5 && ./seed.sh",
    "backup": "../../../private-data/scripts/backup.sh",
    "restore": "../../../private-data/scripts/restore.sh",
    "drift": "../../../private-data/scripts/drift.sh",
    "doctor": "../../../private-data/scripts/doctor.sh"
  },
  "keywords": ["neo4j", "database", "novanet"]
}
