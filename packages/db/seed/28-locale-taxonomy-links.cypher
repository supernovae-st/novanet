SET l.language_note = 'Kartvelian (South Caucasian) - unique language isolate';

// Armenian (special - Indo-European isolate): hy
MATCH (l:Locale)
WHERE l.language_code = 'hy'
SET l.language_note = 'Armenian - Indo-European isolate branch';

