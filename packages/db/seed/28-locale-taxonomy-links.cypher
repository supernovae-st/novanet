// -----------------------------------------------------------------------------
// 3. LOCALE → INCOME GROUP (HAS_INCOME_LEVEL)
// World Bank FY26 classifications
// -----------------------------------------------------------------------------

// High Income Countries (HIC) - GNI per capita > $13,935
MATCH (l:Locale), (i:IncomeGroup {key: 'hic'})
WHERE l.country_code IN [
  // North America
  'US', 'CA',
  // Western Europe
  'AT', 'BE', 'CH', 'DE', 'DK', 'FI', 'FR', 'GB', 'IE', 'IS', 'LU', 'MC', 'NL', 'NO', 'SE',
  // Southern Europe
  'AD', 'ES', 'IT', 'MT', 'PT', 'SI', 'SM', 'VA', 'CY',
  // Eastern Europe
  'CZ', 'EE', 'HR', 'HU', 'LT', 'LV', 'PL', 'SK',
  // East Asia
  'HK', 'JP', 'KR', 'MO', 'SG', 'TW', 'BN',
  // Middle East
  'AE', 'BH', 'IL', 'KW', 'OM', 'QA', 'SA',
  // Oceania
  'AU', 'NZ',
  // Caribbean
  'BB', 'KY', 'PR', 'TT', 'VI'
]
MERGE (l)-[:HAS_INCOME_LEVEL]->(i);

// Upper Middle Income Countries (UMIC) - GNI $4,496-$13,935
MATCH (l:Locale), (i:IncomeGroup {key: 'umic'})
WHERE l.country_code IN [
  // Americas
  'AR', 'BR', 'CL', 'CO', 'CR', 'CU', 'DO', 'EC', 'GT', 'JM', 'MX', 'PA', 'PE', 'PY', 'UY', 'VE',
  // Europe
  'AL', 'BA', 'BG', 'BY', 'GE', 'MD', 'ME', 'MK', 'RO', 'RS', 'RU', 'TR', 'UA', 'XK',
  // Asia
  'AZ', 'CN', 'ID', 'IR', 'IQ', 'JO', 'KZ', 'LB', 'LY', 'MY', 'TH', 'TM', 'TN',
  // Africa
  'BW', 'GA', 'MU', 'NA', 'ZA', 'DZ', 'EG', 'LY',
  // Oceania
  'FJ'
]
MERGE (l)-[:HAS_INCOME_LEVEL]->(i);

// Lower Middle Income Countries (LMIC) - GNI $1,136-$4,495
MATCH (l:Locale), (i:IncomeGroup {key: 'lmic'})
WHERE l.country_code IN [
  // Asia
  'BD', 'BT', 'IN', 'KH', 'KG', 'LA', 'LK', 'MM', 'MN', 'NP', 'PH', 'PK', 'TJ', 'UZ', 'VN',
  // Africa
  'AO', 'BF', 'CI', 'CM', 'CD', 'DJ', 'GH', 'KE', 'LS', 'MA', 'MG', 'MR', 'MW', 'MZ', 'NG', 'RW', 'SN', 'SZ', 'TZ', 'UG', 'ZM', 'ZW',
  // Americas
  'BO', 'HN', 'HT', 'NI', 'SV',
  // Middle East
  'PS', 'SY', 'YE'
]
MERGE (l)-[:HAS_INCOME_LEVEL]->(i);

// Low Income Countries (LIC) - GNI ≤ $1,135
MATCH (l:Locale), (i:IncomeGroup {key: 'lic'})
WHERE l.country_code IN [
  // Africa
  'BI', 'CF', 'ER', 'ET', 'GM', 'GN', 'GW', 'LR', 'ML', 'NE', 'SD', 'SL', 'SO', 'SS', 'TD', 'TG',
  // Asia
  'AF'
]
MERGE (l)-[:HAS_INCOME_LEVEL]->(i);

// -----------------------------------------------------------------------------
// 4. LOCALE → CULTURAL SUBREALM (IN_CULTURAL_SUBREALM)
// Based on Broek & Webb cultural geography
// -----------------------------------------------------------------------------

// Anglo-Saxon (Occidental)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'anglo-saxon'})
WHERE l.country_code IN ['US', 'CA', 'GB', 'IE', 'AU', 'NZ']
   OR (l.country_code IN ['ZA', 'NG', 'KE', 'GH', 'UG', 'ZM', 'ZW', 'BW', 'TZ', 'JM', 'TT', 'BB'] AND l.language_code = 'en')
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

