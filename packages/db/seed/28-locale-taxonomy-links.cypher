// Germanic (gem): en, de, nl, sv, no, da, is, af
MATCH (l:Locale), (b:LanguageBranch {key: 'gem'})
WHERE l.language_code IN ['en', 'de', 'nl', 'sv', 'no', 'da', 'is', 'af', 'yi']
MERGE (l)-[:SPEAKS_BRANCH]->(b);

