MATCH (l:Locale), (s:CulturalSubRealm {key: 'himalayan-buddhist'})
WHERE l.country_code IN ['BT', 'NP']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Sinosphere (East Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'sinosphere'})
WHERE l.country_code IN ['CN', 'HK', 'MO', 'TW', 'SG']
   AND l.language_code = 'zh'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Japanese (East Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'japanese'})
WHERE l.country_code = 'JP'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Korean (East Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'korean'})
WHERE l.country_code = 'KR'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Mongolian (East Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'mongolian'})
WHERE l.country_code = 'MN'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Vietnamese (East Asian influenced)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'vietnamese'})
WHERE l.country_code = 'VN'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Mainland Buddhist (Southeast Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'mainland-buddhist'})
WHERE l.country_code IN ['KH', 'LA', 'MM', 'TH']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Filipino (Southeast Asian)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'filipino'})
WHERE l.country_code = 'PH'
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// West African (Meso-African)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'west-african'})
WHERE l.country_code IN ['BF', 'BJ', 'CI', 'GH', 'GM', 'GN', 'GW', 'LR', 'ML', 'MR', 'NE', 'NG', 'SL', 'SN', 'TG']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Central African (Meso-African)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'central-african'})
WHERE l.country_code IN ['AO', 'CD', 'CF', 'CG', 'CM', 'GA', 'GQ', 'ST', 'TD']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// East African (Meso-African)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'east-african'})
WHERE l.country_code IN ['BI', 'ET', 'KE', 'MG', 'MW', 'MZ', 'RW', 'SO', 'TZ', 'UG', 'ZM', 'ZW']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Southern African (Meso-African)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'southern-african'})
WHERE l.country_code IN ['BW', 'LS', 'NA', 'SZ', 'ZA']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Horn of Africa (Meso-African)
MATCH (l:Locale), (s:CulturalSubRealm {key: 'horn-of-africa'})
WHERE l.country_code IN ['DJ', 'ER', 'ET', 'SO']
MERGE (l)-[:IN_CULTURAL_SUBREALM]->(s);

// Caucasian (special)
MATCH (l:Locale)
WHERE l.country_code IN ['AM', 'GE']
SET l.cultural_note = 'Caucasian - unique blend of Occidental, Orthodox, and indigenous cultures';

// Israeli-Jewish (special)
MATCH (l:Locale)
WHERE l.country_code = 'IL' AND l.language_code = 'he'
SET l.cultural_note = 'Israeli-Jewish - unique Occidental-Judaic cultural blend';

// -----------------------------------------------------------------------------
// 5. LOCALE → POPULATION SUBCLUSTER (HAS_PRIMARY_POPULATION)
// For AI-generated imagery diversity
// -----------------------------------------------------------------------------

// Nordic-Baltic
MATCH (l:Locale), (p:PopulationSubCluster {key: 'nordic-baltic'})
WHERE l.country_code IN ['DK', 'EE', 'FI', 'IS', 'LT', 'LV', 'NO', 'SE']
MERGE (l)-[:HAS_PRIMARY_POPULATION]->(p);

// Western-Central European
MATCH (l:Locale), (p:PopulationSubCluster {key: 'western-central-european'})
WHERE l.country_code IN ['AT', 'BE', 'CH', 'CZ', 'DE', 'FR', 'GB', 'HU', 'IE', 'LI', 'LU', 'MC', 'NL', 'PL', 'SK']
MERGE (l)-[:HAS_PRIMARY_POPULATION]->(p);

