// =============================================================================
// LOCALE TAXONOMY LINKS - NovaNet v10.8
// =============================================================================
// Links 200 Locale nodes to Geographic Taxonomy nodes:
// - Locale -[:IN_SUBREGION]-> GeoRegion (based on country code)
// - Locale -[:SPEAKS_BRANCH]-> LanguageBranch (based on language code)
// - Locale -[:HAS_INCOME_LEVEL]-> IncomeGroup (based on country)
// - Locale -[:IN_CULTURAL_SUBREALM]-> CulturalSubRealm (based on country/region)
// - Locale -[:HAS_PRIMARY_POPULATION]-> PopulationSubCluster (based on region)
//
// Sources:
// - UN M49: Country to region mappings
// - ISO 639-5: Language to branch mappings
// - World Bank FY26: Income classifications
// - Broek & Webb: Cultural realm assignments
//
// AUTO-GENERATED by novanet v10.8.0
// =============================================================================

// -----------------------------------------------------------------------------
// 1. LOCALE → GEO REGION (IN_SUBREGION)
// Maps country_code to UN M49 intermediate regions
// -----------------------------------------------------------------------------

// Northern Africa (015): DZ, EG, LY, MA, SD, TN, EH
MATCH (l:Locale), (r:GeoRegion {key: 'northern-africa'})
WHERE l.country_code IN ['DZ', 'EG', 'LY', 'MA', 'SD', 'TN', 'EH']
MERGE (l)-[:IN_SUBREGION]->(r);

// Western Africa (011): BF, BJ, CI, CV, GH, GM, GN, GW, LR, ML, MR, NE, NG, SL, SN, TG
MATCH (l:Locale), (r:GeoRegion {key: 'western-africa'})
WHERE l.country_code IN ['BF', 'BJ', 'CI', 'CV', 'GH', 'GM', 'GN', 'GW', 'LR', 'ML', 'MR', 'NE', 'NG', 'SL', 'SN', 'TG']
MERGE (l)-[:IN_SUBREGION]->(r);

// Middle Africa (017): AO, CD, CF, CG, CM, GA, GQ, ST, TD
MATCH (l:Locale), (r:GeoRegion {key: 'middle-africa'})
WHERE l.country_code IN ['AO', 'CD', 'CF', 'CG', 'CM', 'GA', 'GQ', 'ST', 'TD']
MERGE (l)-[:IN_SUBREGION]->(r);

