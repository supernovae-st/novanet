// -----------------------------------------------------------------------------
// 6. OF_KIND CONNECTIONS FOR LOCALES
// Ensure all Locales connect to their meta-Kind
// -----------------------------------------------------------------------------

MATCH (l:Locale), (k:Kind {label: 'Locale'})
WHERE NOT (l)-[:OF_KIND]->(k)
MERGE (l)-[:OF_KIND]->(k);

// -----------------------------------------------------------------------------
// 7. SUMMARY STATS
// -----------------------------------------------------------------------------

// Count relationships created
MATCH (l:Locale)-[r:IN_SUBREGION]->()
RETURN 'IN_SUBREGION' AS relationship, count(r) AS count
UNION ALL
MATCH (l:Locale)-[r:SPEAKS_BRANCH]->()
RETURN 'SPEAKS_BRANCH' AS relationship, count(r) AS count
UNION ALL
MATCH (l:Locale)-[r:HAS_INCOME_LEVEL]->()
RETURN 'HAS_INCOME_LEVEL' AS relationship, count(r) AS count
UNION ALL
MATCH (l:Locale)-[r:IN_CULTURAL_SUBREALM]->()
RETURN 'IN_CULTURAL_SUBREALM' AS relationship, count(r) AS count
UNION ALL
MATCH (l:Locale)-[r:HAS_PRIMARY_POPULATION]->()
RETURN 'HAS_PRIMARY_POPULATION' AS relationship, count(r) AS count;
