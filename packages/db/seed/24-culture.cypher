    c.values = '[{"value":"Cymuned (Community)","importance":"High","expression":"Strong local bonds, mutual support, collective identity over individualism","marketing_angle":"Emphasize local roots, shared experiences, belonging to something meaningful"},{"value":"Yr Iaith (Language)","importance":"High","expression":"Welsh language as cultural cornerstone, pride in speaking and preserving Cymraeg","marketing_angle":"Use authentic Welsh, demonstrate commitment to language, avoid token gestures"},{"value":"Gwyleidd-dra (Humility)","importance":"High","expression":"Understatement preferred over boasting, let quality speak for itself","marketing_angle":"Avoid superlatives and hard selling; demonstrate value through substance"},{"value":"Tegwch (Fairness)","importance":"Medium","expression":"Strong sense of social justice, equality, fair treatment for all","marketing_angle":"Emphasize ethical practices, transparent pricing, fair dealing"},{"value":"Gwreiddiau (Roots)","importance":"Medium","expression":"Deep connection to land, heritage, place-based identity","marketing_angle":"Reference local geography, history, and cultural continuity"},{"value":"Cefnogaeth (Support)","importance":"Medium","expression":"Supporting local businesses, Welsh-medium services, community initiatives","marketing_angle":"Show genuine investment in Welsh communities, not just commercial interest"},{"value":"Cynhwysiant (Inclusivity)","importance":"Medium","expression":"Welcoming newcomers who respect the culture, Welsh learners encouraged","marketing_angle":"Be accessible to all while celebrating Welsh identity authentically"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Welsh language revival","importance":"Medium","expression":"Genuine achievement - celebrate carefully without over-claiming; acknowledge ongoing challenges","marketing_angle":""},{"value":"Industrial heritage","importance":"Medium","expression":"Complex legacy - mining communities shaped identity but decline brought hardship; approach with respect","marketing_angle":""},{"value":"Musical excellence","importance":"Low","expression":"Choral tradition, contemporary Welsh music - broadly celebrated pride point","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"MEDIUM_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'cy-GB: Communication style is balanced. Hierarchy importance: low. Orientation: Mixed individual/collective. Core values: Cymuned (Community), Yr Iaith (Language), Gwyleidd-dra (Humility).',
    c.taboos_summary = 'CRITICAL TABOOS: Welsh language politics, Linguistic imperialism. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'cy-GB.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

