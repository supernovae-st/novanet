    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Gotong Royong (Mutual Cooperation)","importance":"High","expression":"Community collaboration, helping neighbors, collective responsibility","marketing_angle":"Position products as benefiting community; emphasize sharing, teamwork, \"together we succeed\" narratives"},{"value":"Kekeluargaan (Family Spirit)","importance":"High","expression":"Extended family bonds, collective decisions, intergenerational care","marketing_angle":"Family-centered messaging; multi-generational appeal; products that bring family together"},{"value":"Hormat (Respect)","importance":"High","expression":"Deference to elders, authority, social hierarchy; polite speech levels","marketing_angle":"Show respect in communication; acknowledge customer worth; never condescending; honorifics matter"},{"value":"Musyawarah Mufakat (Consensus)","importance":"High","expression":"Group decision-making, avoiding conflict, seeking agreement","marketing_angle":"Avoid aggressive sales; allow consideration time; frame as collaborative solutions"},{"value":"Rukun (Harmony)","importance":"High","expression":"Maintaining social harmony, avoiding conflict, preserving relationships","marketing_angle":"Never confrontational; emphasize peaceful solutions; \"win-win\" framing; smooth interactions"},{"value":"Malu (Shame/Social Awareness)","importance":"Medium","expression":"Concern for social judgment, maintaining face, avoiding embarrassment","marketing_angle":"Never embarrass customers; discrete service; protect customer dignity in all interactions"},{"value":"Bhineka Tunggal Ika (Unity in Diversity)","importance":"Medium","expression":"Celebrating cultural diversity, religious pluralism, national unity","marketing_angle":"Inclusive messaging across ethnic groups; celebrate diversity; avoid favoring one group"},{"value":"Ramah Tamah (Hospitality/Friendliness)","importance":"Medium","expression":"Warm welcomes, generous hosting, friendly interactions","marketing_angle":"Warm, welcoming tone; generous customer service; smiling communication"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Independence (Merdeka, 17 August 1945)","importance":"Low","expression":"Major celebration; Sukarno revered; independence themes always positive; \"merdeka\" resonates","marketing_angle":""},{"value":"Batik and traditional crafts","importance":"Low","expression":"UNESCO heritage; deeply beloved; excellent for authentic brand associations","marketing_angle":""},{"value":"Badminton and sports achievements","importance":"Low","expression":"National sport passion; Olympic success celebrated; sports partnerships well-received","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'id-ID: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Gotong Royong (Mutual Cooperation), Kekeluargaan (Family Spirit), Hormat (Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: Insulting Islam or any religion, Separatism and territorial issues, PKI/Communism. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'id-ID.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

