    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Euskara (Language)","importance":"High","expression":"Basque language as the cornerstone of identity; speaking Euskara is an act of cultural affirmation","marketing_angle":"Genuine, quality Basque content shows deep respect; avoid token phrases or poor translations"},{"value":"Herria (Community/People)","importance":"High","expression":"Deep collective identity; \"herri\" means both village and people; community bonds transcend individualism","marketing_angle":"Emphasize local roots, belonging, shared heritage; we over I"},{"value":"Auzolana (Communal work)","importance":"High","expression":"Tradition of neighbors helping neighbors; collective labor for community projects","marketing_angle":"Frame brand as supporting community; mutual benefit over transactional relationships"},{"value":"Lana (Work)","importance":"High","expression":"Strong work ethic; industriousness valued; Basque cooperatives (Mondragon) exemplify this","marketing_angle":"Acknowledge effort and quality; substance over flash; hard work is respected"},{"value":"Leialtasuna (Loyalty)","importance":"Medium","expression":"Deep loyalty to family, community, language, and trusted institutions","marketing_angle":"Build long-term relationships; loyalty is earned and reciprocated"},{"value":"Euskal nortasuna (Basque identity)","importance":"Medium","expression":"Pride in distinct identity, history, and cultural uniqueness within Iberian context","marketing_angle":"Celebrate Basque distinctiveness genuinely; avoid treating as mere regional variant of Spain"},{"value":"Zintzotasuna (Honesty)","importance":"Medium","expression":"Straight-dealing valued; \"hitz bat, hitz\" (one\'s word is one\'s bond)","marketing_angle":"Transparent communication; keep promises; authenticity over polish"},{"value":"Tradizio berria (Renewed tradition)","importance":"Medium","expression":"Respect for tradition alongside innovation; modern Basque culture is dynamic, not museum-piece","marketing_angle":"Balance heritage with contemporary relevance; tradition is living, not frozen"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Basque language survival","importance":"Medium","expression":"Remarkable achievement against historical odds; celebrate respectfully without over-claiming; acknowledge ongoing revitalization efforts","marketing_angle":""},{"value":"Cooperative movement","importance":"Low","expression":"Mondragon as model of economic democracy; widely celebrated pride point","marketing_angle":""},{"value":"Pre-Roman heritage","importance":"Low","expression":"Unique ancient origins; archaeological sites (Santimamiñe) are safe references","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW","directness":"DIRECT","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'eu-ES: Communication style is direct. Hierarchy importance: low. Orientation: Individualist (focus on \'you\'). Core values: Euskara (Language), Herria (Community/People), Auzolana (Communal work).',
    c.taboos_summary = 'CRITICAL TABOOS: Political violence / ETA references, Independence politics, Spanish nationalism. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'eu-ES.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
