    c.culture_summary = 'en-TZ: Communication style is indirect. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Ujamaa (Familyhood), Unity / Umoja, Pole Pole (Patience/Gentleness).',
    c.taboos_summary = 'CRITICAL TABOOS: Criticizing Nyerere, Zanzibar separatism/politics, Religious division. Always avoid these topics.',
