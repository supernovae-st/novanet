MERGE (c:Culture {key: 'pt-AO'})
SET c.display_name = 'pt-AO Culture Norms',
    c.description = 'Cultural context and norms for pt-AO',
    c.llm_context = 'USE: pt-AO culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"8:00"}',
    c.values = '[{"value":"Respeito pelos Mais-Velhos (Kotas)","importance":"High","expression":"Deferencia absoluta aos mais velhos; consulta obrigatoria nas decisoes familiares; bencaos procuradas; termo \"kota\" usado com carinho e reverencia","marketing_angle":"Mostrar respeito geracional; nao usar tom excessivamente jovem; reconhecer sabedoria e experiencia; \"os nossos kotas confiam em nos\""},{"value":"Familia e Comunidade","importance":"High","expression":"Familia alargada central; apoio mutuo esperado; partilha de recursos; festas e marcos celebrados colectivamente; \"ubuntu\" angolano","marketing_angle":"Mensagens centradas na familia; beneficios colectivos; \"para toda a familia\"; apelo multi-geracional; eventos que reunem pessoas"},{"value":"Hospitalidade (Bem-vindo)","importance":"High","expression":"Convidados tratados como reis; partilha de comida e bebida obrigatoria; visitantes nunca saem de maos vazias; \"casa angolana esta sempre aberta\"","marketing_angle":"Calor no acolhimento; experiencias de boas-vindas; generosidade autentica; \"sinta-se em casa\"; servico atencioso"},{"value":"Resiliencia (Luta)","importance":"High","expression":"Decadas de guerra civil superadas; espirito de reconstrucao; optimismo apesar das dificuldades; \"angolano nao desiste\"","marketing_angle":"Narrativas de superacao; \"juntos somos mais fortes\"; reconhecer os desafios sem condescendencia; celebrar progressos"},{"value":"Orgulho Nacional (Angolanidade)","importance":"High","expression":"Forte identidade nacional pos-independencia; orgulho nos recursos naturais, cultura, musica; seleccao nacional (Palancas Negras)","marketing_angle":"Celebrar a cultura angolana; referencias locais genuinas; \"orgulho de ser angolano\"; evitar comparacoes desfavoraveis"},{"value":"Fe e Espiritualidade","importance":"Medium","expression":"Maioria catolica; protestantismo crescente; crencas tradicionais coexistem; bencaos e referencias a Deus comuns no quotidiano","marketing_angle":"Expressoes de bencao apropriadas; respeitar calendario religioso (Natal, Pascoa); \"Deus abencoe\"; evitar conteudo anti-religioso"},{"value":"Respeito pela Autoridade","importance":"Medium","expression":"Hierarquia social respeitada; titulos e posicoes valorizados; sobas (chefes tradicionais) reverenciados; estruturas de poder reconhecidas","marketing_angle":"Reconhecer posicoes e titulos; tom apropriado para diferentes niveis; parcerias com autoridades locais respeitadas"},{"value":"Trabalho e Empreendedorismo","importance":"Medium","expression":"\"Zungar\" (comercio informal) generalizado; espirito empreendedor admirado; \"desenrascar\" valorizado; auto-suficiencia","marketing_angle":"Apoiar pequenos negocios; ferramentas para empreendedores; respeitar economia informal; \"o seu sucesso e o nosso sucesso\""},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Independencia (11 de Novembro 1975)","importance":"Low","expression":"Celebracao nacional segura; orgulho unanime; bandeira, hino, simbolos nacionais respeitados","marketing_angle":""},{"value":"Kuduro e Musica Angolana","importance":"Low","expression":"Orgulho cultural genuino; reconhecimento internacional; artistas nacionais celebrados","marketing_angle":""},{"value":"Recursos Naturais (Petroleo, Diamantes)","importance":"Medium","expression":"Orgulho mas tambem sensibilidade; questoes de distribuicao de riqueza; focar no potencial, nao na critica","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'pt-AO: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Respeito pelos Mais-Velhos (Kotas), Familia e Comunidade, Hospitalidade (Bem-vindo).',
    c.taboos_summary = 'CRITICAL TABOOS: Guerra Civil (1975-2002), UNITA vs MPLA historico, Jonas Savimbi. Always avoid these topics.',
    c.template_version = '3.1',
