    c.business_hours = '{"end":"16:30","lunch_break":false,"start":"07:30"}',
    c.values = '[{"value":"Botho (Humanity/Respect)","importance":"High","expression":"Treating others with dignity, compassion, and mutual respect; \"Motho ke motho ka batho ba bangwe\" (A person is a person through others)","marketing_angle":"Emphasize community benefit, human connection, and social responsibility in messaging"},{"value":"Kagiso (Peace)","importance":"High","expression":"Harmony, stability, non-confrontation; pride in Botswana\'s peaceful history","marketing_angle":"Peaceful, positive framing; avoid aggressive or confrontational marketing tones"},{"value":"Respect for Elders (Tlotlo)","importance":"High","expression":"Deference to older generations, seeking wisdom from elders, traditional authority structures","marketing_angle":"Include multi-generational imagery; position products as family-approved"},{"value":"Pula (Rain/Blessing)","importance":"High","expression":"Rain as sacred blessing; national motto \"Pula!\" means rain, prosperity, good fortune","marketing_angle":"Use \"Pula\" appropriately as symbol of abundance; connect products to prosperity themes"},{"value":"Unity/Consensus (Kutlwano)","importance":"Medium","expression":"Collective decision-making through Kgotla tradition; community above individual","marketing_angle":"Emphasize shared benefits, group decisions; avoid overly individualistic messaging"},{"value":"Hard Work (Tiro)","importance":"Medium","expression":"Self-reliance, industriousness, building prosperity through effort","marketing_angle":"Respect the work ethic; products that help people achieve through their own effort"},{"value":"Hospitality (Go amogela baeng)","importance":"Medium","expression":"Welcoming guests, generous hosting, sharing food and drink","marketing_angle":"Products that enable hosting, generosity, welcoming others"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Okavango Delta (UNESCO World Heritage)","importance":"Low","expression":"Universally celebrated; safe for nature/conservation themes","marketing_angle":""},{"value":"Zebras (National Football Team)","importance":"Low","expression":"Safe sports reference; growing football enthusiasm","marketing_angle":""},{"value":"Sir Seretse Khama","importance":"Low","expression":"Founding president widely revered; respectful references welcome","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-BW: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Botho (Humanity/Respect), Kagiso (Peace), Respect for Elders (Tlotlo).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting elders/chiefs, Witchcraft accusations, HIV/AIDS stigmatization. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'en-BW.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

