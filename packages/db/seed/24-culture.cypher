    c.values = '[{"value":"Harmony (Wa / 和)","importance":"High","expression":"Avoiding conflict; group consensus; smooth social interactions; reading the atmosphere (kuuki wo yomu)","marketing_angle":"Emphasize fitting in, community benefit; avoid confrontational messaging; showcase collaborative solutions"},{"value":"Respect (Sonkei / 尊敬)","importance":"High","expression":"Deference to seniority, expertise, and social position; elaborate honorific language (keigo); bowing culture","marketing_angle":"Use appropriate keigo; show respect for customer; acknowledge expertise; avoid presumptuous tone"},{"value":"Quality (Hinshitsu / 品質)","importance":"High","expression":"Obsessive attention to detail; zero-defect mentality; craftsmanship (monozukuri); continuous improvement (kaizen)","marketing_angle":"Highlight precision, durability, craftsmanship; quality certifications; attention to packaging and presentation"},{"value":"Reliability (Shinrai / 信頼)","importance":"High","expression":"Keeping promises; punctuality; consistency; trust built over long relationships","marketing_angle":"Honor commitments precisely; reliable delivery; consistent service; long-term relationship messaging"},{"value":"Consideration (Omoiyari / 思いやり)","importance":"High","expression":"Anticipating others\' needs; thoughtful gestures; going beyond expectations","marketing_angle":"Demonstrate omotenashi (hospitality); anticipate needs; thoughtful details; exceed expectations quietly"},{"value":"Diligence (Kinben / 勤勉)","importance":"Medium","expression":"Hard work valued; perseverance; dedication to craft; continuous learning","marketing_angle":"Acknowledge effort; support professional development; respect for mastery; patience in relationships"},{"value":"Modesty (Kenkyo / 謙虚)","importance":"Medium","expression":"Understatement; deflecting praise; not standing out excessively (deru kugi wa utareru - the nail that sticks out gets hammered)","marketing_angle":"Understated elegance; let quality speak; avoid boastful claims; subtle superiority"},{"value":"Cleanliness (Seiketsu / 清潔)","importance":"Medium","expression":"Physical and spiritual purity; hygiene obsession; organization; decluttering (Marie Kondo influence)","marketing_angle":"Clean design; pristine presentation; hygiene messaging; organized user experience"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Technology and innovation","importance":"Low","expression":"Sony, Toyota, Nintendo heritage; bullet train (shinkansen); robotics leadership; safe reference","marketing_angle":""},{"value":"Food culture (Washoku)","importance":"Low","expression":"UNESCO intangible heritage; ramen, sushi, kaiseki; strong national pride; authentic representation important","marketing_angle":""},{"value":"Natural beauty","importance":"Low","expression":"Mount Fuji; cherry blossoms; four seasons; iconic imagery acceptable","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ja-JP: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Harmony (Wa / 和), Respect (Sonkei / 尊敬), Quality (Hinshitsu / 品質).',
    c.taboos_summary = 'CRITICAL TABOOS: World War II and imperial history, Atomic bombings (Hiroshima, Nagasaki), Territorial disputes. Always avoid these topics.',
