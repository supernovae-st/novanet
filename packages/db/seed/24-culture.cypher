    c.values = '[{"value":"الكرامة (Dignity/Honor)","importance":"High","expression":"Preserving personal and family honor; reputation management; face-saving in all interactions","marketing_angle":"Never embarrass customers; protect dignity in communications; premium positioning shows respect for customer status"},{"value":"الكرم (Generosity)","importance":"High","expression":"Lavish hospitality; gift-giving culture; treating guests with abundance","marketing_angle":"Position products as generous offerings; VIP treatment language; abundance messaging; \"عروض سخية\" (generous offers)"},{"value":"الولاء (Loyalty)","importance":"High","expression":"Strong family and tribal bonds; loyalty to leadership and nation; long-term relationships valued","marketing_angle":"Loyalty programs resonate; long-term partnership language; \"شريكك الدائم\" (your permanent partner)"},{"value":"الطموح (Ambition)","importance":"High","expression":"Vision for the future; striving for excellence; UAE growth mindset","marketing_angle":"Innovation themes; future-oriented messaging; \"نحو المستقبل\" (towards the future); achievement stories"},{"value":"التسامح (Tolerance)","importance":"High","expression":"Multicultural coexistence; Year of Tolerance (2019) legacy; interfaith respect","marketing_angle":"Inclusive messaging for diverse population; multicultural imagery; global brand positioning"},{"value":"الاحترام (Respect)","importance":"High","expression":"Deference to authority, elders, ruling families; maintaining social hierarchy","marketing_angle":"Respectful tone always; acknowledge customer importance; never condescending"},{"value":"العائلة (Family)","importance":"High","expression":"Extended family central; family decisions collective; intergenerational living","marketing_angle":"Family-focused messaging; multi-generational appeal; products bringing family together"},{"value":"التميز (Excellence)","importance":"Medium","expression":"Pursuit of world-class standards; \"first\" and \"best\" achievements; competitive positioning","marketing_angle":"Premium quality emphasis; world-class standards; \"الأفضل في فئته\" (best in class)"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sheikh Zayed (Founding Father)","importance":"Medium","expression":"Deeply revered; \"Father of the Nation\"; can reference his values (tolerance, giving) respectfully; never commercial use of image","marketing_angle":""},{"value":"UAE National Day (December 2)","importance":"Low","expression":"Major celebration; patriotic themes welcome; excellent campaign timing; \"روح الاتحاد\"","marketing_angle":""},{"value":"Space program (Hope Probe)","importance":"Low","expression":"First Arab Mars mission; source of immense pride; innovation symbol; science achievement","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ar-AE: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: الكرامة (Dignity/Honor), الكرم (Generosity), الولاء (Loyalty).',
