    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"தமிழ் பெருமை (Tamil Pride)","importance":"High","expression":"Exceptional pride in Tamil language, literature, and 2000+ year heritage; \"தமிழ் வாழ்க\" sentiment; Thiruvalluvar reverence; classical Tamil (செந்தமிழ்) as identity marker","marketing_angle":"Tamil-first communication essential; celebrate Tamil heritage; use pure Tamil terms where possible; respect Thirukkural references"},{"value":"குடும்பம் (Family)","importance":"High","expression":"Joint family traditions strong; multi-generational living common; collective decision-making; family honor (குடும்ப மரியாதை) paramount; \"குடும்பத்தோட\" living valued","marketing_angle":"Family-centric messaging; multi-generational benefits; \"குடும்பம் முழுக்க\" themes; products serving entire household"},{"value":"மரியாதை (Respect)","importance":"High","expression":"Deep respect for elders (பெரியவர்கள் மீது மரியாதை); teacher reverence (ஆசிரியர் வணக்கம்); hierarchical deference; hospitality as duty; using நீங்கள் form crucial","marketing_angle":"Respectful communication always; elder-inclusive imagery; honor relationships; humble service attitude"},{"value":"கல்வி (Education)","importance":"High","expression":"Education extremely valued; \"கல்வியே செல்வம்\" belief; professional degrees as family pride; IITs, AIIMS aspirations; engineering, medicine focus","marketing_angle":"Education benefits; career advancement; knowledge positioning; family pride through achievement"},{"value":"அறம் (Righteousness/Ethics)","importance":"Medium","expression":"Thirukkural-based ethics deeply rooted; \"அறம் செய்ய விரும்பு\" principle; justice orientation; dharmic responsibility without Sanskrit terminology","marketing_angle":"Ethical positioning; fair dealing emphasis; values-based branding; transparency messaging"},{"value":"விருந்தோம்பல் (Hospitality)","importance":"Medium","expression":"\"விருந்தோம்பல்\" as sacred duty; filter coffee/tea offering mandatory; guest treatment as honor; customer as respected guest","marketing_angle":"Warm welcome experiences; generous offerings; hospitality in service; \"உங்கள் சேவையில்\" attitude"},{"value":"சுயமரியாதை (Self-Respect)","importance":"Medium","expression":"Periyar\'s self-respect movement legacy; rejection of subservience; dignity in all dealings; equality consciousness","marketing_angle":"Dignified messaging; no patronizing tone; respect audience intelligence; equality in communication"},{"value":"கடின உழைப்பு (Hard Work)","importance":"Medium","expression":"Diligence respected; industrious nature; \"உழைப்பே உயர்வு\" ethos; self-made success stories valued in Chennai, Coimbatore business culture","marketing_angle":"Hard work narratives; earned success; effort-reward messaging; self-improvement themes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Tamil language and literature","importance":"Low","expression":"2000+ year heritage; Sangam literature; Thirukkural; safe for cultural pride themes; very positive resonance","marketing_angle":""},{"value":"Chennai IT/tech industry","importance":"Low","expression":"IT hub; automobile manufacturing; startup ecosystem; safe for progressive, innovation positioning","marketing_angle":""},{"value":"Bharathiyar and freedom movement","importance":"Medium","expression":"Independence movement poet; \"வந்தே மாதரம்\"; use respectfully; nationalist but not political","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ta-IN: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: தமிழ் பெருமை (Tamil Pride), குடும்பம் (Family), மரியாதை (Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: Tamil language disrespect, Caste discrimination, Hindi imposition. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ta-IN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

