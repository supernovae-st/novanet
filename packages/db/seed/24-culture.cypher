    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Bolingo (Love/Affection)","importance":"High","expression":"Deep interpersonal warmth; caring for others; emotional generosity in relationships","marketing_angle":"Position products as expressions of care; emphasize warmth, togetherness; \"mpo na bato oyo olingaka\" (for those you love)"},{"value":"Libota (Family)","importance":"High","expression":"Extended family networks; collective responsibility; intergenerational care; family honor","marketing_angle":"Family-centered messaging; multi-generational appeal; products benefiting entire family; \"libota ezali motuya\""},{"value":"Limemia (Hospitality)","importance":"High","expression":"Generous welcome of guests; sharing meals; making visitors feel at home","marketing_angle":"Emphasize welcoming, generous service; \"oyambami malamu\" (you are well received); hospitality-oriented communication"},{"value":"Bomoko (Unity/Solidarity)","importance":"High","expression":"Community cooperation; helping neighbors; collective problem-solving; Ubuntu philosophy","marketing_angle":"Position as community benefit; \"tokosala elongo\" (we work together); solidarity narratives"},{"value":"Lokumu (Honor/Dignity)","importance":"High","expression":"Personal reputation; family name; respect for authority and elders; avoiding shame","marketing_angle":"Never embarrass customers; protect dignity; acknowledge worth; \"moto ya lokumu\" positioning"},{"value":"Bondeko (Brotherhood)","importance":"Medium","expression":"Egalitarian relationships; mutual aid; treating strangers as siblings","marketing_angle":"Inclusive messaging; \"bandeko\" (brothers/sisters) framing; community belonging"},{"value":"Motema Malamu (Good Heart)","importance":"Medium","expression":"Generosity of spirit; kindness; sincere intentions; absence of malice","marketing_angle":"Authentic, sincere communication; genuine care; \"na motema moko\" (with one heart)"},{"value":"Botosi (Obedience/Respect)","importance":"Medium","expression":"Respect for elders, traditional authority, religious leaders, parents","marketing_angle":"Show respect in all communications; acknowledge hierarchy; never condescending"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Congolese music (rumba, soukouss)","importance":"Low","expression":"Internationally recognized; source of immense pride; Kinshasa = music capital; artist references highly effective","marketing_angle":""},{"value":"Size and geographic importance","importance":"Low","expression":"Largest country in sub-Saharan Africa; \"coeur de l\'Afrique\" (heart of Africa); use freely","marketing_angle":""},{"value":"Leopards (football)","importance":"Low","expression":"National team passion; AFCON participation celebrated; sports partnerships positive","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ln-CD: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Bolingo (Love/Affection), Libota (Family), Limemia (Hospitality).',
    c.taboos_summary = 'CRITICAL TABOOS: Ethnic divisions and tribalism, Political commentary (current government), Eastern DRC conflict. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ln-CD.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

