    c.values = '[{"value":"Janteloven (Law of Jante)","importance":"High","expression":"Egalitarianism; humility; distrust of self-promotion; collective over individual; no one is better than others","marketing_angle":"Avoid boastful claims; understatement preferred; \"we\" over \"I\"; let quality speak quietly"},{"value":"Likhet (Equality)","importance":"High","expression":"Flat hierarchies; first-name basis universal; CEOs accessible; wealth not displayed; gender equality","marketing_angle":"Peer-to-peer tone; avoid status symbols; inclusive representation; no hierarchy language"},{"value":"Friluftsliv (Outdoor life)","importance":"High","expression":"Deep connection to nature; hiking, skiing, cabin culture; \"ut pa tur, aldri sur\" (out on a trip, never sour)","marketing_angle":"Nature imagery resonates; outdoor references authentic; seasonal activities; sustainable positioning"},{"value":"Dugnad","importance":"High","expression":"Community volunteer work; collective responsibility; neighbors helping neighbors; shared effort","marketing_angle":"Community-focused messaging; collective benefit; \"together\" framing; social responsibility"},{"value":"Trust (Tillit)","importance":"High","expression":"High-trust society; handshake agreements honored; transparency expected; honesty baseline","marketing_angle":"No hidden fees; straightforward terms; transparent pricing; keep promises exactly"},{"value":"Work-life balance","importance":"High","expression":"37.5-hour work week; generous parental leave; vacation sacred; \"kos\" (coziness) valued","marketing_angle":"Respect personal time; no 24/7 urgency; family time protected; weekend boundaries"},{"value":"Sustainability","importance":"Medium","expression":"Oil fund stewardship; environmental consciousness; recycling culture; electric vehicle leadership","marketing_angle":"Environmental credentials; sustainable practices; long-term thinking; responsible consumption"},{"value":"Self-reliance (Selvstendighet)","importance":