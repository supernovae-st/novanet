MERGE (c:Culture {key: 'mi-NZ'})
SET c.display_name = 'mi-NZ Culture Norms',
    c.description = 'Cultural context and norms for mi-NZ',
    c.llm_context = 'USE: mi-NZ culture (southern hemisphere, indirect communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'southern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Whanaungatanga (kinship/relationship)","importance":"High","expression":"Building and maintaining family and community connections; acknowledging shared whakapapa (genealogy); treating strangers as potential whanau","marketing_angle":"Emphasise community, connection, belonging; \"Ka whakawhanaunga tatou\" (We are building relationships together)"},{"value":"Manaakitanga (hospitality/care)","importance":"High","expression":"Generous hosting; ensuring guests are fed and comfortable; showing care through actions; welcoming warmly","marketing_angle":"Highlight service, care, support; \"Manaaki whenua, manaaki tangata\" (Care for the land, care for the people)"},{"value":"Kaitiakitanga (guardianship/stewardship)","importance":"High","expression":"Protecting natural resources for future generations; sustainable practices; environmental responsibility","marketing_angle":"Sustainability messaging; intergenerational thinking; \"Mo tatou, a, mo ka uri a muri ake nei\" (For us and our children after us)"},{"value":"Mana (prestige/authority/dignity)","importance":"High","expression":"Respecting individual and collective dignity; earning respect through actions; maintaining honour; not diminishing others\' mana","marketing_angle":"Empowerment messaging; respect for customers; never condescending; uplifting language"},{"value":"Aroha (love/compassion)","importance":"High","expression":"Unconditional love and care; compassion in all interactions; empathy and kindness; forgiveness","marketing_angle":"Warm, caring brand voice; genuine empathy in support; \"Ka nui te aroha\" (Great love)"},{"value":"Tika (correctness/integrity)","importance":"Medium","expression":"Doing what is right and proper; honesty; ethical behaviour; keeping promises; following proper protocols","marketing_angle":"Trust and reliability messaging; ethical business practices; \"He tika, he pono\" (It is right and true)"},{"value":"Pono (truth/sincerity)","importance":"Medium","expression":"Being genuine and truthful; authenticity; reliability; no deception","marketing_angle":"Authentic brand voice; honest communication; avoiding exaggeration"},{"value":"Wairuatanga (spirituality)","importance":"Medium","expression":"Acknowledging spiritual dimensions of life; connection between physical and spiritual; respecting mauri (life force)","marketing_angle":"Depth and meaning in messaging; acknowledging the sacred; holistic approach"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Te reo Maori revival","importance":"Low","expression":"Celebrate the successful language revitalisation; kohanga reo (language nests) and kura kaupapa (Maori-medium schools); pride in speaking te reo","marketing_angle":""},{"value":"Treaty partnership","importance":"Medium","expression":"Pride in unique constitutional relationship; must acknowledge ongoing grievances and Waitangi Tribunal processes; balance celebration with recognition of unfinished business","marketing_angle":""},{"value":"Whakairo and ta moko","importance":"Medium","expression":"Pride in traditional arts; ta moko revival; but must respect that these are taonga (treasures) with protocols around use and representation","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'mi-NZ: Communication style is indirect. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Whanaungatanga (kinship/relationship), Manaakitanga (hospitality/care), Kaitiakitanga (guardianship/stewardship).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting tapu (sacred) places or objects, Mocking or misusing ta moko, Disrespecting kaumatua or elders. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'mi-NZ.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

