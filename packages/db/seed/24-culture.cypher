    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'no-NO: Communication style is direct. Hierarchy importance: low. Orientation: Individualist (focus on \'you\'). Core values: Janteloven (Law of Jante), Likhet (Equality), Friluftsliv (Outdoor life).',
