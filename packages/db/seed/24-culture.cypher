    c.values = '[{"value":"Ubuntu/Umunthu","importance":"High","expression":"\"Umuntu ngumuntu ngabantu\" (A person is a person through others); communal solidarity; mutual support; shared responsibility","marketing_angle":"Emphasize community benefit; collective success; \"together we grow\" messaging; products that serve families and communities"},{"value":"Respect for Elders (Ulemu)","importance":"High","expression":"Deference to elders and chiefs; use of respectful titles (Ba Mayo, Ba Tata); seeking elder counsel for major decisions","marketing_angle":"Multi-generational imagery; family-approved positioning; never bypass elder involvement; products as family investments"},{"value":"Christian Faith","importance":"High","expression":"Zambia is constitutionally a Christian nation; deep faith expressed openly; blessings and prayer common in daily life","marketing_angle":"Wholesome, faith-compatible messaging; family values; avoid anything that conflicts with Christian principles"},{"value":"\"One Zambia, One Nation\" Unity","importance":"High","expression":"National motto emphasizing unity across 73 ethnic groups; tribal harmony valued; inclusive national identity","marketing_angle":"Unifying messaging; never emphasize tribal distinctions; celebrate shared Zambian identity"},{"value":"Hospitality (Mwaiseni Spirit)","importance":"High","expression":"Welcoming strangers; generosity to visitors; sharing food and resources; warmth as core cultural trait","marketing_angle":"Welcoming brand tone; generous offers; hospitality-oriented products and messaging"},{"value":"Hard Work (Kufwaya Mulimo)","importance":"Medium","expression":"Self-reliance; working to provide for family; dignity in labor; agricultural heritage","marketing_angle":"Products that reward effort; tools for success; respect for working people"},{"value":"Family Loyalty (Ulupwa)","importance":"Medium","expression":"Extended family bonds; obligations to relatives; clan networks; collective child-rearing","marketing_angle":"Family-oriented positioning; products benefiting whole families; multi-generational appeal"},{"value":"Humility (Ukuicefya)","importance":"Medium","expression":"Modest self-presentation; avoiding boastfulness; sharing credit; not showing off wealth","marketing_angle":"Avoid arrogant brand messaging; humble service approach; quality speaks for itself"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Victoria Falls (Mosi-oa-Tunya)","importance":"Low","expression":"UNESCO site shared with Zimbabwe; \"Smoke that Thunders\"; universally celebrated; safe for tourism and nature themes","marketing_angle":""},{"value":"Wildlife and National Parks","importance":"Low","expression":"South Luangwa, Lower Zambezi, Kafue; conservation pride; walking safari invention; safe nature themes","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-ZM: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Ubuntu/Umunthu, Respect for Elders (Ulemu), Christian Faith.',
