    c.values = '[{"value":"Famille et liens familiaux","importance":"High","expression":"Famille elargie centrale dans les decisions ; menages multigenerationnels ; honneur familial primordial","marketing_angle":"Messages orientes famille ; produits qui rassemblent ; appel multigenerationnel ; « pour votre famille »"},{"value":"Islam et spiritualite","importance":"High","expression":"Prieres quotidiennes, observance du Ramadan, mode de vie halal ; integre aux expressions quotidiennes","marketing_angle":"Respecter le calendrier islamique ; conformite halal essentielle ; eviter le contenu pendant les heures de priere ; marketing strategique du Ramadan"},{"value":"Patriotisme et Revolution","importance":"High","expression":"Guerre d\'independance (1954-1962) fondatrice ; martyrs honores ; identite nationale forte","marketing_angle":"Commemorations du 1er novembre ; themes de fierte nationale ; eviter la nostalgie coloniale ; « fabrique en Algerie » resonne"},{"value":"Dignite et honneur (El-Karama)","importance":"High","expression":"Honneur personnel et familial ; preservation de la face essentielle ; respect de soi non negociable","marketing_angle":"Ne jamais embarrasser les clients ; ton respectueux toujours ; reconnaitre la valeur du client ; proteger la dignite"},{"value":"Solidarite sociale","importance":"High","expression":"Aide aux voisins, soutien communautaire ; tradition de « touiza » (travail collectif)","marketing_angle":"Messages d\'interet communautaire ; recits de succes collectif ; cadrage « ensemble »"},{"value":"Identite amazighe","importance":"Medium","expression":"Heritage berbere celebre ; tamazight langue officielle ; diversite culturelle","marketing_angle":"Inclure des elements amazighs ; respecter la diversite linguistique ; eviter le cadrage exclusivement arabe"},{"value":"Hospitalite (Diyafa)","importance":"Medium","expression":"Accueil genereux ; invites traites avec honneur ; rituels du the et du cafe","marketing_angle":"Attentes de service chaleureux ; offres genereuses ; ton accueillant ; « Ahlan wa sahlan » authentique"},{"value":"Patience et endurance (Sabr)","importance":"Medium","expression":"Perseverance valorisee ; resilience face aux difficultes ; vision a long terme","marketing_angle":"Reconnaitre les defis ; eviter l\'urgence agressive ; fiabilite stable preferee aux promesses tape-a-l\'oeil"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Guerre d\'independance (1954-1962)","importance":"Medium","expression":"1,5 million de martyrs ; sujet sacre ; utiliser avec reverence ; ne jamais trivialiser ; eviter la perspective coloniale francaise","marketing_angle":""},{"value":"Sahara algerien","importance":"Low","expression":"Merveille naturelle ; fierte touristique ; « le Grand Sud » ; imagerie du desert positive","marketing_angle":""},{"value":"Heritage amazigh/berbere","importance":"Medium","expression":"Richesse culturelle celebree ; tamazight officiel depuis 2016 ; traiter inclusivement ; eviter de politiser","marketing_angle":""}]',
