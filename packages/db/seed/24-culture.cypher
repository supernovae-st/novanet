MERGE (c:Culture {key: 'es-PY'})
SET c.display_name = 'es-PY Culture Norms',
    c.description = 'Cultural context and norms for es-PY',
    c.llm_context = 'USE: es-PY culture (southern hemisphere, indirect communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'southern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"12:00","lunch_break":false,"start":"08:00"}',
    c.values = '[{"value":"Familia (Family)","importance":"High","expression":"Extended family bonds central to life; multi-generational households common; collective decision-making; children highly valued; family gatherings frequent","marketing_angle":"Family-centered messaging resonates deeply; show multi-generational connections; \"para tu familia\" appeals; collective benefit over individual"},{"value":"Solidaridad (Solidarity)","importance":"High","expression":"Helping neighbors and community; communal support systems; sharing resources; \"mborayhu\" spirit in Spanish expression","marketing_angle":"Community connection themes; shared benefits; \"juntos\" language; mutual support narratives"},{"value":"Hospitalidad (Hospitality)","importance":"High","expression":"Welcoming strangers warmly; terere sharing ritual; treating guests as family; open homes","marketing_angle":"Service warmth; personal care; hospitality metaphors; \"mi casa es tu casa\" spirit"},{"value":"Tranquilidad (Tranquility)","importance":"High","expression":"Calm, unhurried pace valued; patience over rushing; contentment prioritized; \"tranquilo\" as life philosophy","marketing_angle":"Do not pressure; gentle messaging; allow time; avoid aggressive sales tactics"},{"value":"Humildad (Humility)","importance":"Medium","expression":"Modest self-presentation; discomfort with boasting; collective achievement over individual glory; \"no hay que agrandarse\"","marketing_angle":"Understated claims; avoid superlatives; community success stories; avoid arrogance"},{"value":"Resiliencia (Resilience)","importance":"Medium","expression":"Historical survival against odds; enduring hardship with dignity; quiet strength; \"salir adelante\"","marketing_angle":"Acknowledge strength; durability messaging; practical solutions; not preachy"},{"value":"Orgullo Bilingue (Bilingual Pride)","importance":"Medium","expression":"Pride in Spanish-Guarani bilingualism; jopara (code-switching) is natural; unique linguistic identity","marketing_angle":"Respect both languages; jopara in casual contexts is authentic; \"nande\" integration"},{"value":"Conexion con la Tierra (Land Connection)","importance":"Medium","expression":"Agricultural roots; connection to territory; rural identity even in urban dwellers; Chaco and campo pride","marketing_angle":"Nature metaphors; environmental themes; agricultural references resonate"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Bilingual nation (Spanish-Guarani)","importance":"Low","expression":"Source of immense pride; unique in Americas; safe to celebrate; \"nuestras dos lenguas\"","marketing_angle":""},{"value":"Itaipu Dam","importance":"Low","expression":"World\'s largest hydroelectric dam (by production); engineering pride; shared with Brazil","marketing_angle":""},{"value":"Nanduti lace craft","importance":"Low","expression":"Traditional handicraft; UNESCO heritage; feminine cultural pride","marketing_angle":""},{"value":"Survival and resilience","importance":"Medium","expression":"Pride in national survival but connected to traumatic war history; celebrate carefully","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'es-PY: Communication style is indirect. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Familia (Family), Solidaridad (Solidarity), Hospitalidad (Hospitality).',
    c.taboos_summary = 'CRITICAL TABOOS: Triple Alliance War (1864-1870), Indigenous exploitation, Triple Alliance War (1864-1870). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'es-PY.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'ha-NG'})
SET c.display_name = 'ha-NG Culture Norms',
    c.description = 'Cultural context and norms for ha-NG',
    c.llm_context = 'USE: ha-NG culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'sunday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Addini (Faith/Religion)","importance":"High","expression":"Islam permeates daily life; prayers, greetings, business ethics all shaped by Islamic principles; regular mosque attendance; Ramadan observance","marketing_angle":"Islamic values alignment; halal positioning; respect for religious calendar; trustworthiness messaging"},{"value":"Iyali (Family)","importance":"High","expression":"Extended family networks; collective responsibility; elders honored and consulted; children seen as blessing; in-laws respected","marketing_angle":"Family-centered messaging; multi-generational appeal; collective benefits; \"iyali guda\" (one family) themes"},{"value":"Mutunci (Dignity/Respect)","importance":"High","expression":"Personal honor paramount; respect for status, age, and achievement; face-saving essential; reputation carefully guarded","marketing_angle":"Respect-based communication; dignified positioning; never embarrass or shame; honor customer status"},{"value":"Karimci (Generosity/Hospitality)","importance":"High","expression":"Guests treated lavishly; sharing wealth is virtue; traders known for hospitality; \"bakon Allah\" (guest of God) concept","marketing_angle":"Generous offers; hospitality themes; abundance messaging; welcome experiences"},{"value":"Kasuwanci (Trade/Commerce)","importance":"Medium","expression":"Long trading heritage (trans-Saharan routes); business acumen valued; fair dealing honored; merchant class respected","marketing_angle":"Business credibility; fair trading emphasis; \"reliable partner\" positioning; commercial heritage"},{"value":"Gaskiya (Honesty/Truth)","importance":"Medium","expression":"Truth-telling valued; promises expected to be kept; word is bond; \"kalmar mutum\" (a person\'s word) is sacred","marketing_angle":"Trustworthiness claims; promise-keeping; authentic messaging; no false advertising"},{"value":"Hadin Kai (Unity/Solidarity)","importance":"Medium","expression":"Community cohesion; supporting fellow Hausas; helping neighbors; collective action for common good","marketing_angle":"Community messaging; solidarity themes; \"together\" positioning; collective success"},{"value":"Ilimi (Knowledge/Learning)","importance":"Medium","expression":"Islamic scholarship deeply valued; Quranic education traditional; modern education increasingly important","marketing_angle":"Educational content valued; knowledge-sharing; expert positioning; scholarly respect"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sultan of Sokoto","importance":"Medium","expression":"Highest Islamic authority in Nigeria; commands immense respect; reference with utmost reverence only","marketing_angle":""},{"value":"Trans-Saharan trade heritage","importance":"Low","expression":"Historical pride in merchant tradition; safe commercial messaging","marketing_angle":""},{"value":"Hausa language spread","importance":"Low","expression":"Lingua franca of West Africa; pride in language\'s reach and influence","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ha-NG: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Addini (Faith/Religion), Iyali (Family), Mutunci (Dignity/Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: Insulting Islam or the Prophet, Boko Haram/terrorism, Ethnic/religious conflict. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ha-NG.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'el-CY'})
SET c.display_name = 'el-CY Culture Norms',
    c.description = 'Cultural context and norms for el-CY',
    c.llm_context = 'USE: el-CY culture (northern hemisphere, balanced communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'mixed',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"13:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Φιλοξενία (Philoxenia/Hospitality)","importance":"High","expression":"Genuine warmth to guests and strangers; offering food, coffee, and time is expected; treating others well reflects honor","marketing_angle":"Be genuinely welcoming; personal service over efficiency; make customers feel like honored guests; kopiaste (come, join) culture"},{"value":"Οικογένεια (Family)","importance":"High","expression":"Extended family involvement in decisions; multi-generational bonds strong; Sunday family gatherings sacred; family business tradition","marketing_angle":"Frame products as benefiting whole family; respect family decision-making; acknowledge multiple generations"},{"value":"Ορθοδοξία (Orthodox Faith)","importance":"High","expression":"Greek Orthodox identity central to Cypriot Greek identity; religious holidays major events; church attendance significant","marketing_angle":"Respect religious calendar; Easter is bigger than Christmas; avoid conflicts with major Orthodox feasts"},{"value":"Κοινότητα (Community)","importance":"High","expression":"Village and neighborhood ties strong; reputation matters; word-of-mouth powerful; everyone knows everyone","marketing_angle":"Every interaction matters; community trust essential; local endorsement valuable; negative word spreads fast"},{"value":"Πατρίδα (Homeland/National Identity)","importance":"High","expression":"Deep connection to Cyprus and Greek heritage; 1974 division remains painful; Cypriot Greek identity strongly held","marketing_angle":"Acknowledge Cypriot identity; avoid anything touching division; celebrate island beauty and heritage"},{"value":"Αξιοπρέπεια (Dignity)","importance":"Medium","expression":"Maintaining face important; public embarrassment offensive; respect in all interactions expected","marketing_angle":"Never shame customers; handle issues privately; protect dignity; respect essential in all dealings"},{"value":"Φιλότιμο (Honor/Sense of Duty)","importance":"Medium","expression":"Doing the right thing even at personal cost; generosity; keeping word; reliability expected","marketing_angle":"Emphasize commitment and reliability; keeping promises matters; honor in business dealings"},{"value":"Πρακτικότητα (Pragmatism)","importance":"Medium","expression":"Mediterranean practicality; focus on workable solutions; flexibility valued; island resourcefulness","marketing_angle":"Offer practical solutions; understand local context; appreciate \"Cypriot way\" of problem-solving"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Ancient history","importance":"Low","expression":"10,000 years of civilization; Aphrodite\'s birthplace; UNESCO sites - safe and celebrated","marketing_angle":""},{"value":"Greek identity","importance":"Medium","expression":"Greek heritage important but distinct Cypriot identity exists; not simply \"Greek\"; acknowledge nuance","marketing_angle":""},{"value":"EU membership","importance":"Low","expression":"Joined EU 2004; generally positive; eurozone membership source of stability","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"MEDIUM_HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'el-CY: Communication style is balanced. Hierarchy importance: medium. Orientation: Mixed individual/collective. Core values: Φιλοξενία (Philoxenia/Hospitality), Οικογένεια (Family), Ορθοδοξία (Orthodox Faith).',
    c.taboos_summary = 'CRITICAL TABOOS: Cyprus division/1974, Greek-Turkish relations, Recognition of "TRNC". Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'el-CY.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'jv-ID'})
SET c.display_name = 'jv-ID Culture Norms',
    c.description = 'Cultural context and norms for jv-ID',
    c.llm_context = 'USE: jv-ID culture (southern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'southern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Rukun (Harmony)","importance":"High","expression":"Maintaining social harmony; avoiding open conflict; prioritizing group cohesion over individual expression; smooth interpersonal relations","marketing_angle":"Frame products as supporting family/community harmony; avoid competitive or confrontational messaging; emphasize togetherness"},{"value":"Hormat (Respect)","importance":"High","expression":"Strict adherence to social hierarchy; deference to elders, superiors, and high-status individuals; proper use of speech levels (unggah-ungguh)","marketing_angle":"Show respect for hierarchy in imagery; elder approval validates choices; acknowledge seniority and expertise"},{"value":"Tepa Slira (Empathy)","importance":"High","expression":"Deep awareness of others\' feelings and positions; putting oneself in another\'s place; sensitivity to unspoken concerns","marketing_angle":"Customer-centric messaging; show understanding; address concerns before they arise; personalized attention"},{"value":"Sabar (Patience)","importance":"High","expression":"Emotional restraint; accepting circumstances with grace; not rushing or pushing; calm perseverance through difficulties","marketing_angle":"Never pressure or rush customers; patient service tone; acknowledge waiting; avoid urgent hard-sell tactics"},{"value":"Andap Asor (Humility)","importance":"High","expression":"Self-lowering behavior; not boasting; understating one\'s achievements; elevating others","marketing_angle":"Humble brand voice; avoid boastful claims; customer-elevating language; show appreciation"},{"value":"Gotong Royong (Mutual Cooperation)","importance":"Medium","expression":"Community mutual aid; collective effort; sharing burdens and successes; neighborhood solidarity","marketing_angle":"Community-focused initiatives; collective benefits messaging; local partnership references"},{"value":"Nrimo (Acceptance)","importance":"Medium","expression":"Accepting fate gracefully; contentment with circumstances; not complaining; gratitude for what one has","marketing_angle":"Gratitude messaging; satisfaction themes; avoid creating dissatisfaction or FOMO-based urgency"},{"value":"Gemi, Nastiti, Ngati-ati (Prudence)","importance":"Medium","expression":"Careful with resources; thoughtful decision-making; avoiding waste; measured actions","marketing_angle":"Value-focused messaging; quality over flashiness; long-term thinking; wise investment framing"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Keraton Yogyakarta and Solo (Royal Courts)","importance":"High","expression":"Deep reverence for Sultanate; never disrespect or mock royalty; use ceremonial references with care and respect","marketing_angle":""},{"value":"Batik heritage","importance":"Low","expression":"UNESCO recognized; safe pride reference; regional batik motifs vary (Yogya, Solo, Pekalongan styles)","marketing_angle":""},{"value":"Borobudur and Prambanan temples","importance":"Low","expression":"World heritage sites; safe cultural references; Buddhist and Hindu heritage respected","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'jv-ID: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Rukun (Harmony), Hormat (Respect), Tepa Slira (Empathy).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting the Keraton (Royal Courts), Causing public isin (shame/embarrassment), Direct criticism or confrontation. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'jv-ID.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'km-KH'})
SET c.display_name = 'km-KH Culture Norms',
    c.description = 'Cultural context and norms for km-KH',
    c.llm_context = 'USE: km-KH culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"12:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"ការគោរព (Kar Korop - Respect)","importance":"High","expression":"Deep respect for elders, authority, monks; elaborate pronoun system; deference in speech and behavior","marketing_angle":"Always use respectful forms of address; acknowledge customer dignity; honor hierarchy in imagery and messaging"},{"value":"ពុទ្ធសាសនា (Putthasasna - Buddhism)","importance":"High","expression":"Theravada Buddhism central to identity; temple activities; merit-making (បុណ្យ); monastic respect","marketing_angle":"Align with Buddhist values of compassion, generosity; acknowledge religious calendar; never trivialize Buddhist elements"},{"value":"ភាពសុខដុម (Pheap Sok Dom - Harmony)","importance":"High","expression":"Social harmony paramount; conflict avoidance; smooth relationships; consensus-seeking","marketing_angle":"Non-confrontational messaging; emphasize peaceful solutions; avoid aggressive sales tactics"},{"value":"គ្រួសារ (Krousar - Family)","importance":"High","expression":"Extended family (ក្រុមគ្រួសារ) central; multi-generational living; collective decision-making","marketing_angle":"Family-centered messaging; multi-generational appeal; products benefiting family unit"},{"value":"រក្សាមុខ (Roksaa Muk - Face Saving)","importance":"High","expression":"Preserving dignity; avoiding public embarrassment; protecting social standing","marketing_angle":"Never embarrass customers publicly; discrete service; protect customer dignity in all interactions"},{"value":"សុភាព (Sophea - Modesty/Humility)","importance":"Medium","expression":"Humble demeanor valued; boasting discouraged; quiet achievement","marketing_angle":"Avoid excessive self-promotion; let quality speak; humble, sincere communication"},{"value":"មេត្តា (Metta - Loving-kindness)","importance":"Medium","expression":"Buddhist compassion; genuine care for others; generosity of spirit","marketing_angle":"Warm, caring tone; genuine helpfulness; generosity themes resonate"},{"value":"កតញ្ញូ (Katanyu - Gratitude)","importance":"Medium","expression":"Deep gratitude to parents, teachers, benefactors; remembering those who helped","marketing_angle":"Acknowledge customer loyalty; gratitude expressions authentic; \"thank you\" carries weight"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Angkor Wat and Khmer Empire","importance":"Low","expression":"Supreme national symbol; on flag; source of deep pride; use respectfully and prominently","marketing_angle":""},{"value":"Independence (9 November 1953)","importance":"Low","expression":"King Norodom Sihanouk revered; independence themes positive; national holiday celebrated","marketing_angle":""},{"value":"Royal family","importance":"Medium","expression":"Constitutional monarchy; King highly respected; use with reverence only; never commercial exploitation","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'km-KH: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: ការគោរព (Kar Korop - Respect), ពុទ្ធសាសនា (Putthasasna - Buddhism), ភាពសុខដុម (Pheap Sok Dom - Harmony).',
    c.taboos_summary = 'CRITICAL TABOOS: Khmer Rouge era (1975-1979), Criticism of Royal Family, Buddhist disrespect. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'km-KH.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

