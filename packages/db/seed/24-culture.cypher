ed service recovery"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Pearl diving heritage","importance":"Low","expression":"Safe and celebrated; pre-oil identity; use freely in lifestyle content","marketing_angle":""},{"value":"Formula 1 hosting","importance":"Low","expression":"First Gulf race (2004); sports and modernity pride; broad appeal","marketing_angle":""},{"value":"2011 protests/unrest","importance":"Critical","expression":"Extremely sensitive; never reference; deep social wounds","marketing_angle":""}]',
