MERGE (c:Culture {key: 'ig-NG'})
SET c.display_name = 'ig-NG Culture Norms',
    c.description = 'Cultural context and norms for ig-NG',
    c.llm_context = 'USE: ig-NG culture (northern hemisphere, balanced communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Igwe bu ike (Unity is strength)","importance":"High","expression":"Strong communal bonds; village unions (Nzuko); age grades support each other; town meetings (Ohaneze); collective decision-making","marketing_angle":"Community messaging; \"we succeed together\" themes; collective benefits; group offers"},{"value":"Oru aka (Hard work/Self-reliance)","importance":"High","expression":"Enterprise deeply valued; \"Igbo landing\" spirit; apprenticeship system (Igba boi); business ownership as ultimate goal; work ethic paramount","marketing_angle":"Achievement messaging; entrepreneurship themes; \"build your success\" positioning; self-made narratives"},{"value":"Nsopuru (Respect)","importance":"High","expression":"Elders revered; traditional titles honored (Nze, Ozo, Lolo, Chief); greeting culture essential; kneeling/prostration for elders; names carry weight","marketing_angle":"Respect-based communication; title recognition; dignified positioning; honor customer status"},{"value":"Ezinulo (Family)","importance":"High","expression":"Extended family obligations; kinship networks strong; children as wealth; supporting relatives expected; family name protection","marketing_angle":"Family-centered messaging; legacy themes; generational benefits; protecting family honor"},{"value":"Okpukpe (Faith/Religion)","importance":"High","expression":"Christianity dominant (Catholic, Anglican, Pentecostal); traditional beliefs (Chi, Ala) also respected; Sunday worship central; Christmas major celebration","marketing_angle":"Christian values alignment; Sunday awareness; Christmas campaigns; faith-positive messaging"},{"value":"Ego (Wealth/Achievement)","importance":"Medium","expression":"Material success valued and displayed; titles bought with achievement; \"Ogaranya\" (wealthy person) respected; success celebrated publicly","marketing_angle":"Aspirational messaging; success stories; premium positioning; achievement recognition"},{"value":"Nkwurita okwu (Communication/Oratory)","importance":"Medium","expression":"Proverbs (Ilu) highly valued; eloquent speech respected; debate tradition; \"Okwu bu ndu\" (words are life); persuasion as art","marketing_angle":"Eloquent copy; proverb integration; wisdom-based messaging; persuasive narratives"},{"value":"Omenala (Tradition/Culture)","importance":"Medium","expression":"Cultural festivals (New Yam - Iri Ji); masquerades (Mmanwu); naming ceremonies; traditional marriage (Igba nkwu); heritage preservation","marketing_angle":"Cultural pride connections; festival tie-ins; traditional values respect; heritage celebration"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Igbo entrepreneurship","importance":"Low","expression":"Celebrated nationally; \"Igbo bu Igbo\" (Igbo are Igbo); safe business credibility reference","marketing_angle":""},{"value":"Chinua Achebe legacy","importance":"Low","expression":"Literary giant; \"Things Fall Apart\"; cultural ambassador; safe intellectual reference","marketing_angle":""},{"value":"Biafra/Civil War","importance":"Critical","expression":"Deep wound; avoid entirely; independence movements ongoing; extremely divisive","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ig-NG: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Igwe bu ike (Unity is strength), Oru aka (Hard work/Self-reliance), Nsopuru (Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: Biafra/Civil War, Ethnic stereotypes, Religious mockery. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ig-NG.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

