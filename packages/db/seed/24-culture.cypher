    c.values = '[{"value":"Harambee (Pulling Together)","importance":"High","expression":"Community fundraising, collective problem-solving, pooling resources for shared goals","marketing_angle":"Emphasize community benefit; \"together\" messaging; show how product/service helps the collective"},{"value":"Ubuntu (Shared Humanity)","importance":"High","expression":"\"I am because we are\"; hospitality to strangers; interconnectedness of people","marketing_angle":"Human-centered messaging; show how actions affect community; \"we\'re all in this together\""},{"value":"Family and Clan Ties","importance":"High","expression":"Extended family support systems; financial obligations to relatives; multi-generational households","marketing_angle":"Family-focused imagery; products that benefit whole family; acknowledge extended family dynamics"},{"value":"Respect for Elders","importance":"High","expression":"Deference to age and experience; seeking elder counsel; caring for aging parents","marketing_angle":"Include older generations respectfully; avoid youth-centric exclusivity; honor tradition alongside progress"},{"value":"Entrepreneurial Spirit","importance":"High","expression":"Jua kali (informal sector) innovation; side hustles; M-Pesa adoption; \"hustler\" work ethic","marketing_angle":"Celebrate self-made success; practical solutions; enable small business and personal growth"},{"value":"Religious Faith","importance":"High","expression":"Christianity dominant; Islam significant especially Coast/North; faith integrated into daily life","marketing_angle":"Respectful acknowledgment of faith; avoid secularism-forward messaging; blessed/grateful themes resonate"},{"value":"Education as Advancement","importance":"Medium","expression":"Education seen as key to social mobility; sacrifices made for school fees; academic achievement celebrated","marketing_angle":"Education partnerships; supporting learning; acknowledge parent investment in children\'s futures"},{"value":"Resilience and Optimism","importance":"Medium","expression":"\"Hakuna matata\" attitude; bouncing back from challenges; positivity despite difficulties","marketing_angle":"Hopeful messaging; solutions-oriented; acknowledge challenges but focus on overcoming"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Long-distance running dominance","importance":"Low","expression":"Extremely safe; Kipchoge, Cheruiyot, Keitany are national heroes; marathon metaphors resonate","marketing_angle":""},{"value":"Wildlife and safari tourism","importance":"Low","expression":"Maasai Mara, Big Five, conservation efforts; core to national identity; responsible tourism angle","marketing_angle":""},{"value":"Coffee and tea production","importance":"Low","expression":"World-renowned Kenyan coffee and tea; agricultural heritage; safe for references","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'en-KE: Communication style is balanced. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Harambee (Pulling Together), Ubuntu (Shared Humanity), Family and Clan Ties.',
    c.taboos_summary = 'CRITICAL TABOOS: Ethnic/tribal tensions, Political tribalism, 2007-2008 Post-Election Violence. Always avoid these topics.',
    c.template_version = '3.1',
