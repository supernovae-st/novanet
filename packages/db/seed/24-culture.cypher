MERGE (c:Culture {key: 'fr-FR'})
SET c.display_name = 'fr-FR Culture Norms',
    c.description = 'Cultural context and norms for fr-FR',
    c.llm_context = 'USE: fr-FR culture (northern hemisphere, balanced communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Liberte (Freedom)","importance":"High","expression":"Personal autonomy, freedom of expression, resistance to authority, individual choice","marketing_angle":"Emphasize choice, autonomy, personal expression - \"Choisissez votre style\""},{"value":"Egalite (Equality)","importance":"High","expression":"Social equality, meritocracy, fair treatment, access to services","marketing_angle":"Position products as accessible, democratic, for everyone"},{"value":"Laicite (Secularism)","importance":"High","expression":"Separation of religion and state, neutral public spaces, religious tolerance","marketing_angle":"Keep religious references neutral, avoid faith-based messaging"},{"value":"Excellence / Savoir-faire","importance":"High","expression":"Quality craftsmanship, expertise, refined taste, attention to detail","marketing_angle":"Highlight quality, craftsmanship, heritage, expertise"},{"value":"Art de vivre (Quality of life)","importance":"High","expression":"Pleasure in food, culture, leisure, balance between work and life","marketing_angle":"Connect products to enjoyment, pleasure, lifestyle enhancement"},{"value":"Intellectual engagement","importance":"Medium","expression":"Value for debate, critical thinking, informed opinions","marketing_angle":"Provide substance, avoid dumbing down, respect intelligence"},{"value":"Patrimoine (Heritage)","importance":"Medium","expression":"Cultural heritage, traditions, history, regional identity","marketing_angle":"Reference French heritage appropriately, respect traditions"},{"value":"Solidarity","importance":"Medium","expression":"Social safety net, collective responsibility, work-life balance","marketing_angle":"Appeal to collective benefit, not just individual gain"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Gastronomie et vin","importance":"Low","expression":"Safe and celebrated - French cuisine and wine are sources of pride","marketing_angle":""},{"value":"Revolution et droits de l\'homme","importance":"Medium","expression":"Positive when referencing values, careful with historical details","marketing_angle":""},{"value":"Science et innovation","importance":"Low","expression":"Pasteur, Curie, Airbus - celebrate French achievements","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'fr-FR: Communication style is balanced. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Liberte (Freedom), Egalite (Equality), Laicite (Secularism).',
    c.taboos_summary = 'CRITICAL TABOOS: Personal income/wealth, Religious affiliation, Political extremism. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-FR.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'fr-SN'})
SET c.display_name = 'fr-SN Culture Norms',
    c.description = 'Cultural context and norms for fr-SN',
    c.llm_context = 'USE: fr-SN culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Teranga (hospitalite)","importance":"High","expression":"Valeur fondatrice de l\'identite senegalaise ; accueil inconditionnel de l\'etranger ; generosite sans attente de retour ; partage du repas autour du bol commun ; l\'invite est sacre","marketing_angle":"Communication chaleureuse et accueillante ; \"Bienvenue\" sincere ; service genereux qui depasse les attentes ; le client est un invite d\'honneur ; \"Vous etes chez vous\""},{"value":"Respect des aines et autorites religieuses","importance":"High","expression":"Les serigne, cheikh, imam et aines sont veneres ; on sollicite leur benediction pour les decisions importantes ; les salutations elaborees sont obligatoires ; jamais de contradiction publique","marketing_angle":"Temoignages de figures respectees ; titres religieux et d\'honneur utilises systematiquement ; ton respectueux envers l\'experience ; valorisation de la sagesse"},{"value":"Foi et spiritualite (Islam)","importance":"High","expression":"95% de la population est musulmane ; pratique quotidienne visible ; confreries (Mourides, Tidjanes, Layennes, Khadres) structurent la vie sociale ; les marabouts sont des guides spirituels influents","marketing_angle":"Respecter les temps de priere et le Ramadan ; formules religieuses naturelles (Inch\'Allah) ; sensibilite aux fetes religieuses (Tabaski, Korite, Magal, Gamou) ; ne jamais instrumentaliser la foi"},{"value":"Jom (dignite/honneur)","importance":"High","expression":"Chaque personne merite un traitement digne ; la honte publique est une offense grave ; proteger sa reputation et celle de sa famille ; ne jamais humilier autrui","marketing_angle":"Ne jamais placer le client en situation d\'embarras ; discretion sur l\'argent et les problemes ; communications qui preservent la dignite ; erreurs admises en prive"},{"value":"Kersa (pudeur/modestie)","importance":"High","expression":"Retenue valorisee ; la vantardise est mal vue ; reussite partagee et non etalee ; modestie dans l\'expression ; ne pas \"faire le grand\"","marketing_angle":"Eviter le marketing trop agressif ou vantard ; celebrer le client plutot que la marque ; succes presente humblement ; eviter les superlatifs excessifs"},{"value":"Solidarite communautaire et familiale","importance":"High","expression":"Famille elargie (mbokk) tres presente ; entraide lors des evenements sociaux (mariages, baptemes, funerailles) ; tontines et cotisations collectives ; responsabilite envers le groupe","marketing_angle":"Messages de communaute : \"Ensemble\", \"On est ensemble\" ; offres familiales ; parrainage ; benefices partages ; \"Votre reussite est celle de tous\""},{"value":"Ngor (integrite/honnetete)","importance":"Medium","expression":"Tenir parole est sacre ; la confiance se merite par les actes ; mefiance envers les promesses non tenues","marketing_angle":"Transparence demonstree ; garanties claires ; eviter les promesses exagerees ; fiabilite prouvee ; \"Nous tenons nos engagements\""},{"value":"Sutura (discretion)","importance":"Medium","expression":"Garder les affaires privees privees ; ne pas exposer les faiblesses d\'autrui ; la discretion protege les relations","marketing_angle":"Confidentialite des donnees clients ; discretion sur les situations difficiles ; ne pas etaler les problemes en public"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"CAN 2022 et Lions de la Teranga","importance":"Low","expression":"Premiere victoire de la CAN, moment d\'euphorie nationale ; Sadio Mane et l\'equipe sont des heros ; references positives tres bien recues ; federateur absolu","marketing_angle":""},{"value":"Leopold Sedar Senghor","importance":"Medium","expression":"Poete-president, pere de la nation, figure majeure de la Negritude ; respecte mais aussi critique pour certaines politiques ; utiliser avec nuance et respect","marketing_angle":""},{"value":"Artisanat et culture","importance":"Low","expression":"Tissage, bijoux, sculpture, poterie ; musique (mbalax de Youssou N\'Dour) ; cuisine senegalaise (thieboudienne, yassa) ; valoriser l\'artisanat local est toujours positif","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'fr-SN: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Teranga (hospitalite), Respect des aines et autorites religieuses, Foi et spiritualite (Islam).',
    c.taboos_summary = 'CRITICAL TABOOS: Irrespect envers les autorites religieuses, Insultes aux parents ou ancetres, Irrespect envers l\'Islam. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-SN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'pa-IN'})
SET c.display_name = 'pa-IN Culture Norms',
    c.description = 'Cultural context and norms for pa-IN',
    c.llm_context = 'USE: pa-IN culture (northern hemisphere, balanced communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"18:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"ਇੱਜ਼ਤ (Honour/Respect)","importance":"High","expression":"Protecting family name, maintaining social standing, respectful conduct in all dealings, never causing shame to family or community","marketing_angle":"Position products as enhancing family prestige; use language that acknowledges customer\'s dignity; \"ਤੁਹਾਡੀ ਇੱਜ਼ਤ ਸਾਡੀ ਜ਼ਿੰਮੇਵਾਰੀ\""},{"value":"ਸੇਵਾ (Selfless Service)","importance":"High","expression":"Serving others without expectation, community langar tradition, helping neighbors, volunteering at gurdwara, collective effort","marketing_angle":"Frame brand as serving customers; \"ਤੁਹਾਡੀ ਸੇਵਾ ਵਿੱਚ\"; emphasize service over transaction"},{"value":"ਪਰਿਵਾਰ (Family)","importance":"High","expression":"Joint family living, multi-generational decision-making, family meals together, parents\' wishes respected, children\'s success reflects on family","marketing_angle":"Family-oriented messaging; multi-generational product positioning; \"ਸਾਰੇ ਪਰਿਵਾਰ ਲਈ\""},{"value":"ਸੰਗਤ (Community)","importance":"High","expression":"Collective identity, village/pind connections, community gatherings, shared celebrations, social networks for support","marketing_angle":"Community endorsements work well; group benefits; \"ਸੰਗਤ ਦੀ ਪਸੰਦ\" testimonial style"},{"value":"ਮਿਹਨਤ (Hard Work)","importance":"High","expression":"Agricultural labor ethic, self-made success valued, physical effort respected, dedication to craft, early rising culture","marketing_angle":"Acknowledge effort required; reward hard work; \"ਮਿਹਨਤ ਦਾ ਫਲ ਮਿੱਠਾ\""},{"value":"ਮਹਿਮਾਨ-ਨਿਵਾਜ਼ੀ (Hospitality)","importance":"High","expression":"Guests treated as God, generous food offerings, comfortable accommodations, never letting guests leave empty-handed","marketing_angle":"Hospitality-themed customer service; generous offers; make customers feel honored"},{"value":"ਸਮਾਨਤਾ (Equality)","importance":"Medium","expression":"Sikh principle of equal treatment regardless of caste/gender, langar tradition where all eat together, rejection of social hierarchy","marketing_angle":"Inclusive messaging; avoid caste/class distinctions; democratic brand positioning"},{"value":"ਚੜ੍ਹਦੀ ਕਲਾ (Rising Spirits/Optimism)","importance":"Medium","expression":"Sikh concept of staying positive through adversity, never giving up, maintaining high spirits, resilient attitude","marketing_angle":"Aspirational messaging; overcoming challenges; \"ਚੜ੍ਹਦੀ ਕਲਾ ਵਿੱਚ ਰਹੋ\" blessings"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sikh Gurus & Religious Heritage","importance":"HIGH","expression":"Reference with utmost respect only; never for commercial exploitation; Guru Nanak\'s teachings of equality, Guru Gobind Singh\'s bravery - these are sacred, not marketing material","marketing_angle":""},{"value":"Agricultural Contribution","importance":"LOW","expression":"Punjab as \"breadbasket of India\" - safe to celebrate; wheat/rice production, hardworking farmers, green revolution contributions","marketing_angle":""},{"value":"Punjabi Music & Dance","importance":"LOW","expression":"Bhangra, Gidda internationally known; Punjabi music industry; can use celebratory imagery freely","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'pa-IN: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: ਇੱਜ਼ਤ (Honour/Respect), ਸੇਵਾ (Selfless Service), ਪਰਿਵਾਰ (Family).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespect to Sikh faith/Gurus, 1984 references, Caste system mentions. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'pa-IN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

