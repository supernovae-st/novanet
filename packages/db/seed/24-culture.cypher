    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'zh-SG: Communication style is balanced. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Kiasu (怕输 - Fear of Losing Out), Meritocracy (精英制度), Racial Harmony (种族和谐).',
