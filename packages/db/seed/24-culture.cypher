MERGE (c:Culture {key: 'fr-BE'})
SET c.display_name = 'fr-BE Culture Norms',
    c.description = 'Cultural context and norms for fr-BE',
    c.llm_context = 'USE: fr-BE culture (northern hemisphere, balanced communication, low hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'low',
    c.individualism_level = 'individualist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:30","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Compromis (Compromise)","importance":"High","expression":"Consensus-seeking in politics and business; coalition culture; avoiding confrontation while finding middle ground; Belgian model of negotiation","marketing_angle":"Emphasize solutions that work for everyone; avoid winner-takes-all messaging; collaborative language"},{"value":"Modestie (Modesty)","importance":"High","expression":"Understated success; avoiding boasting; tall poppy syndrome; discretion about wealth and achievements; humility valued over self-promotion","marketing_angle":"Avoid superlatives and grandiose claims; let quality speak for itself; testimonials over self-praise"},{"value":"Pragmatisme (Pragmatism)","importance":"High","expression":"Practical solutions over ideological purity; getting things done; efficiency valued; concrete results over abstract principles","marketing_angle":"Focus on practical benefits; tangible outcomes; what actually works over theoretical advantages"},{"value":"Autodérision (Self-deprecation)","importance":"High","expression":"Ability to laugh at oneself; national tradition of self-mockery; surrealist humor heritage; not taking oneself too seriously","marketing_angle":"Gentle self-deprecating humor welcomed; avoid pompous or self-important tone; lightheartedness appreciated"},{"value":"Qualité de vie (Quality of life)","importance":"High","expression":"Work-life balance prioritized; gastronomy culture; enjoying life\'s pleasures; leisure and family time valued; convivialité","marketing_angle":"Lifestyle-oriented messaging; pleasure and enjoyment themes; quality over quantity"},{"value":"Fiabilité (Reliability)","importance":"Medium","expression":"Keeping commitments; doing what you say; consistent performance; trust through dependability","marketing_angle":"Honor promises precisely; reliability as selling point; consistency messaging"},{"value":"Ouverture (Openness)","importance":"Medium","expression":"Multicultural society; Brussels as EU capital; international outlook; tolerance of diversity; multiple languages","marketing_angle":"Inclusive messaging; multicultural imagery; European identity resonates"},{"value":"Discrétion (Discretion)","importance":"Medium","expression":"Privacy valued; personal matters kept private; understated displays; avoiding ostentation","marketing_angle":"Respect privacy; avoid intrusive personalization; subtle rather than flashy"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Gastronomie (Beer, chocolate, frites, waffles)","importance":"Low","expression":"Safe, universally positive; Belgians proud of culinary heritage; UNESCO recognition of beer culture","marketing_angle":""},{"value":"Art nouveau et surréalisme (Horta, Magritte)","importance":"Low","expression":"Artistic heritage valued; Brussels Art Nouveau architecture; Magritte international recognition","marketing_angle":""},{"value":"Diables Rouges (Red Devils football team)","importance":"Medium","expression":"Unifying national symbol; strong support; but sports rivalries exist; avoid exclusionary messaging","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'fr-BE: Communication style is balanced. Hierarchy importance: low. Orientation: Individualist (focus on \'you\'). Core values: Compromis (Compromise), Modestie (Modesty), Pragmatisme (Pragmatism).',
    c.taboos_summary = 'CRITICAL TABOOS: Linguistic tensions (Flemish vs Walloon), Comparing to France dismissively, Congo colonization (1885-1960). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-BE.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

