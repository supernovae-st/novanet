    c.values = '[{"value":"Diyafa (Hospitality)","importance":"High","expression":"Generous welcoming of guests, offering tea and food, treating visitors as honored","marketing_angle":"Position brand as gracious host; emphasize service generosity; \"أهلاً وسهلاً\" (welcome) messaging"},{"value":"Sharaf/Ird (Honor)","importance":"High","expression":"Protecting family and tribal reputation, keeping promises, maintaining dignity","marketing_angle":"Emphasize reliability, discretion, quality; never risk customer\'s reputation or dignity"},{"value":"Asabiya (Tribal/Family Solidarity)","importance":"High","expression":"Loyalty to extended family and tribe, collective decision-making, mutual support","marketing_angle":"Family-oriented messaging; collective benefits; products serving whole family unit"},{"value":"Din (Religious Faith)","importance":"High","expression":"Islam central to daily life, religious observance, moral framework","marketing_angle":"Respect Islamic values in all content; halal compliance; religious calendar awareness"},{"value":"Sumud (Resilience/Steadfastness)","importance":"High","expression":"Endurance through decades of hardship, rebuilding spirit, perseverance","marketing_angle":"Durability messaging; long-term value; \"rebuilt stronger\" narratives resonate"},{"value":"Watan (Patriotism)","importance":"Medium","expression":"Love of Iraq despite difficulties, pride in Mesopotamian heritage, national identity","marketing_angle":"Celebrate Iraqi identity; ancient heritage references; local production pride"},{"value":"Karama (Dignity)","importance":"Medium","expression":"Personal and collective dignity, not being patronized, self-respect","marketing_angle":"Respect customer intelligence; avoid condescension; empower rather than pity"},{"value":"Karam (Generosity)","importance":"Medium","expression":"Giving freely, helping neighbors, sharing resources","marketing_angle":"Generous offers valued; community support messaging; \"giving back\" narratives"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Mesopotamian civilization (Babylon, Ur, Assyria, Sumer)","importance":"Low","expression":"Excellent source of pride; Hammurabi\'s Code, cuneiform, ziggurat imagery positive","marketing_angle":""},{"value":"Iraqi poets and intellectuals (Al-Mutanabbi, Al-Jawahiri)","importance":"Low","expression":"Literary heritage respected; poetic references resonate across demographics","marketing_angle":""},{"value":"Recent political events (post-2003)","importance":"High","expression":"Deeply divisive; avoid commercial references; different views across communities","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ar-IQ: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Diyafa (Hospitality), Sharaf/Ird (Honor), Asabiya (Tribal/Family Solidarity).',
    c.taboos_summary = 'CRITICAL TABOOS: Sectarian references or division (Sunni/Shia), Criticism of Islam or religious figures, Criticism of Marja (religious authorities). Always avoid these topics.',
