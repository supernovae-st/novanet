MERGE (c:Culture {key: 'zu-ZA'})
SET c.display_name = 'zu-ZA Culture Norms',
    c.description = 'Cultural context and norms for zu-ZA',
    c.llm_context = 'USE: zu-ZA culture (southern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'southern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Ubuntu (Humanity through others)","importance":"High","expression":"\"Umuntu ngumuntu ngabantu\" - A person is a person through other people. Community interdependence, shared responsibility, collective wellbeing","marketing_angle":"Emphasize community benefit, shared success, inclusive messaging. \"Thina sonke\" (all of us together) resonates deeply"},{"value":"Inhlonipho (Respect)","importance":"High","expression":"Deference to elders, use of hlonipha language, proper greetings, acknowledging dignity of all people regardless of status","marketing_angle":"Show respect in all communications. Proper greetings mandatory. Never skip formalities or appear presumptuous"},{"value":"Ukulunga (Righteousness/Integrity)","importance":"High","expression":"Honesty in dealings, keeping commitments, moral uprightness, trustworthiness in community standing","marketing_angle":"Emphasize trustworthiness, reliability, ethical business practices. \"Isandla esigeza esinye\" (hands wash each other)"},{"value":"Isithunzi (Dignity/Prestige)","importance":"Medium","expression":"Maintaining personal and family honor, reputation management, carrying oneself with pride and composure","marketing_angle":"Help customers maintain their dignity. Never embarrass or belittle. Protect their standing in community"},{"value":"Umndeni (Family)","importance":"Medium","expression":"Extended family networks, ancestral connections, collective family decisions, multi-generational bonds","marketing_angle":"Family-centered messaging. Acknowledge that decisions often involve family. Multi-generational households common"},{"value":"Ukuzimela (Self-reliance)","importance":"Medium","expression":"Personal initiative within community context, entrepreneurship balanced with community contribution, economic empowerment","marketing_angle":"Support empowerment messaging. Balance individual achievement with community benefit. \"Indlela ibuzwa kwabaphambili\""},{"value":"Ubuqotho (Authenticity)","importance":"Medium","expression":"Genuine relationships, sincerity over superficiality, consistency between words and actions","marketing_angle":"Be genuine, not performative. Empty marketing speak quickly identified. Authentic community engagement valued"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Zulu cultural heritage","importance":"Medium","expression":"Deeply valued. Reference with respect and accuracy. Avoid superficial or stereotypical portrayals. The Zulu nation\'s history of resistance and independence is a source of pride","marketing_angle":""},{"value":"Constitutional democracy","importance":"Low","expression":"Pride in progressive constitution, human rights framework. Safe to reference positively in appropriate contexts","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'zu-ZA: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Ubuntu (Humanity through others), Inhlonipho (Respect), Ukulunga (Righteousness/Integrity).',
    c.taboos_summary = 'CRITICAL TABOOS: Apartheid dismissal or minimization, Ethnic stereotyping, Witchcraft/traditional medicine mockery. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'zu-ZA.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'fr-BF'})
SET c.display_name = 'fr-BF Culture Norms',
    c.description = 'Cultural context and norms for fr-BF',
    c.llm_context = 'USE: fr-BF culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Integrite (Burkindi)","importance":"High","expression":"Le nom du pays signifie \"Pays des Hommes Integres\" - l\'honnetete et la droiture sont des valeurs fondamentales ; tenir sa parole est sacre","marketing_angle":"Mettre en avant la transparence, les garanties claires, la fiabilite demonstree ; \"Nous tenons nos engagements\" resonne profondement"},{"value":"Respect des aines et de la hierarchie","importance":"High","expression":"Les aines sont consultes pour les decisions importantes ; les salutations elaborees sont obligatoires ; on ne contredit pas publiquement un superieur","marketing_angle":"Utiliser des temoignages de figures respectees ; montrer le respect dans le service client ; valoriser l\'experience et la sagesse"},{"value":"Solidarite communautaire","importance":"High","expression":"Le concept de famille etendue ; l\'entraide lors des evenements (mariages, funerailles, baptemes) ; cotisations collectives (tontines)","marketing_angle":"Messages de communaute : \"Ensemble\", \"Avec vous\" ; offres familiales ; programmes de parrainage ; benefices partages"},{"value":"Hospitalite (Teranga)","importance":"High","expression":"Accueil chaleureux des visiteurs ; partage du repas ; l\'etranger est un invite de Dieu ; ne jamais refuser l\'eau a un visiteur","marketing_angle":"Communication accueillante et chaleureuse ; attention personnalisee ; le client est un invite d\'honneur ; service genereux"},{"value":"Dignite et honneur","importance":"High","expression":"La reputation personnelle et familiale est precieuse ; eviter la honte publique ; maintenir son rang avec grace ; ne pas humilier autrui","marketing_angle":"Ne jamais placer le client en situation d\'embarras ; discretion sur les questions d\'argent ; respect constant de la dignite"},{"value":"Dialogue et consensus","importance":"Medium","expression":"Tradition de palabre sous l\'arbre ; recherche de consensus plutot que confrontation ; mediation valorisee ; patience dans la resolution des conflits","marketing_angle":"Eviter les ultimatums ; proposer des alternatives ; montrer la flexibilite ; langage de partenariat"},{"value":"Courage et resilience","importance":"Medium","expression":"Histoire de resistance ; adaptation aux defis climatiques et economiques ; fierte de la capacite a surmonter les epreuves","marketing_angle":"Valoriser la perseverance ; messages d\'espoir realistes ; celebrer les reussites malgre les obstacles"},{"value":"Humilite","importance":"Medium","expression":"La vantardise est mal vue ; la reussite se montre avec discretion ; ne pas ecraser les autres par son succes","marketing_angle":"Eviter le ton arrogant ; celebrer le client plutot que la marque ; succes presente comme fruit du travail collectif"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Thomas Sankara","importance":"High","expression":"Icone nationale, \"Pere de la Revolution\", figure quasi-sacree pour beaucoup ; utiliser avec grand respect, jamais de maniere commerciale legere ; symbolise l\'integrite, l\'independance, la fierte africaine","marketing_angle":""},{"value":"Les Etalons (equipe nationale de football)","importance":"Low","expression":"Grande popularite ; finale de la CAN 2013 ; passion nationale ; references sportives bien recues ; federateur","marketing_angle":""},{"value":"Musique et culture","importance":"Low","expression":"Artistes reconnus (Sana Bob, Floby, Smarty, Greg Burkimbila) ; scene musicale vibrante ; couscous, poulet bicyclette, dolo","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'fr-BF: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Integrite (Burkindi), Respect des aines et de la hierarchie, Solidarite communautaire.',
    c.taboos_summary = 'CRITICAL TABOOS: Ethnicisme et tribalisme, Critique de Thomas Sankara, Situation securitaire actuelle. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-BF.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

