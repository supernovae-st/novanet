    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Pamilya (Family)","importance":"High","expression":"Extended family bonds; multi-generational households; sacrificing for children\'s education; OFW remittances supporting family","marketing_angle":"\"Para sa pamilya\" framing; products as family investments; multi-generational benefits; collective decision-making"},{"value":"Pagkamagalang (Respect)","importance":"High","expression":"Po/opo usage; mano gesture to elders; deference to age and authority; never causing loss of face","marketing_angle":"Show respect in communication; never embarrass customers; honorifics essential; acknowledge worth"},{"value":"Pakikisama (Smooth Interpersonal Relations)","importance":"High","expression":"Avoiding conflict; going along with the group; maintaining harmony; not being \"suplado/suplada\"","marketing_angle":"Consensus-friendly CTAs; avoid confrontational messaging; community testimonials; group validation"},{"value":"Hiya (Social Propriety/Shame Awareness)","importance":"High","expression":"Concern for social judgment; avoiding embarrassment; maintaining face; sensitivity to others\' perceptions","marketing_angle":"Never shame customers; discrete service; protect dignity; private resolution of issues"},{"value":"Utang na Loob (Debt of Gratitude)","importance":"High","expression":"Reciprocal obligations; loyalty to those who helped; remembering favors; lifelong gratitude","marketing_angle":"Loyalty programs resonate; reward long-term customers; \"salamat sa tiwala\" messaging"},{"value":"Bayanihan (Community Spirit)","importance":"Medium","expression":"Helping neighbors; collective effort; community mutual aid; shared responsibility","marketing_angle":"Community initiatives; local pride; \"sama-sama\" collective action messaging"},{"value":"Pagkamalikhain (Creativity/Resourcefulness)","importance":"Medium","expression":"\"Diskarte\" problem-solving; making do with limited resources; innovative solutions; Filipino ingenuity","marketing_angle":"Celebrate resourcefulness; value-for-money positioning; practical solutions"},{"value":"Hospitality (Pagkamapagpatanggap)","importance":"Medium","expression":"Welcoming guests; offering food; making visitors comfortable; generosity even with little","marketing_angle":"Warm service tone; generous offers; \"bisita ka namin\" guest treatment positioning"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Philippine independence and heroes","importance":"Medium","expression":"Rizal, Bonifacio, Aguinaldo revered; handle historical complexities respectfully; June 12 celebrations","marketing_angle":""},{"value":"Filipino hospitality worldwide","importance":"Low","expression":"Celebrated global reputation; safe positive reference; warmth of Filipinos recognized internationally","marketing_angle":""},{"value":"Culinary heritage (adobo, sinigang)","importance":"Low","expression":"Food pride strong; regional variations celebrated; safe positive references","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'tl-PH: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Pamilya (Family), Pagkamagalang (Respect), Pakikisama (Smooth Interpersonal Relations).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting religious symbols or beliefs, Causing public hiya (shame/embarrassment), Mocking or disrespecting elders. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'tl-PH.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'en-PK'})
SET c.display_name = 'en-PK Culture Norms',
    c.description = 'Cultural context and norms for en-PK',
    c.llm_context = 'USE: en-PK culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Izzat (Honour/Respect)","importance":"High","expression":"Protecting family reputation, maintaining dignity in public, respectful conduct","marketing_angle":"Appeal to pride, quality, and reputation; \"Trusted by families across Pakistan\""},{"value":"Faith (Iman)","importance":"High","expression":"Islamic practices woven into daily life, religious observance, trust in divine will","marketing_angle":"Halal compliance essential; \"Inshallah\" accepted; Ramadan/Eid campaigns resonate deeply"},{"value":"Family (Khandan)","importance":"High","expression":"Extended family involvement in decisions, multi-generational households, family loyalty","marketing_angle":"Family-oriented messaging; collective benefits; \"For you and your loved ones\""},{"value":"Hospitality (Mehmaan Nawazi)","importance":"High","expression":"Guests treated with utmost respect, generosity expected, warmth in service","marketing_angle":"Hospitality language in service; \"We are honoured to serve you\"; warm welcome messaging"},{"value":"Community (Biradari)","importance":"Medium","expression":"Strong community bonds, collective decision-making, social networks matter","marketing_angle":"Community endorsements; word-of-mouth emphasis; social proof messaging"},{"value":"Education (Taleem)","importance":"Medium","expression":"High value placed on academic achievement, professional qualifications respected","marketing_angle":"Education-focused offers; certification emphasis; knowledge-building content"},{"value":"Resilience (Sabr)","importance":"Medium","expression":"Patience through hardship, adaptability, perseverance despite challenges","marketing_angle":"Reliability messaging; long-term partnership; \"We stand with you\""},{"value":"Progress (Taraqqi)","importance":"Medium","expression":"Aspiration for improvement, embracing modernity while respecting tradition","marketing_angle":"Future-focused messaging balanced with heritage; \"Moving forward together\""},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Cricket achievements","importance":"Low","expression":"Extremely safe and beloved; national obsession; PSL, Pakistan team victories, legendary players (Imran Khan the cricketer, Wasim Akram, Babar Azam) all resonate positively","marketing_angle":""},{"value":"Nuclear capability","importance":"Medium","expression":"Source of national pride for security; reference carefully and in appropriate contexts only; avoid casual usage","marketing_angle":""},{"value":"Independence and founding","importance":"Medium","expression":"14th August (Independence Day) major celebration; Quaid-e-Azam (Jinnah) revered; but avoid Indo-Pak partition controversies","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-PK: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Izzat (Honour/Respect), Faith (Iman), Family (Khandan).',
    c.taboos_summary = 'CRITICAL TABOOS: Blasphemy and disrespect to Islam, Anti-Pakistan sentiment, Kashmir dispute (taking India\'s position). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'en-PK.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'fr-CH'})
SET c.display_name = 'fr-CH Culture Norms',
    c.description = 'Cultural context and norms for fr-CH',
    c.llm_context = 'USE: fr-CH culture (northern hemisphere, balanced communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'individualist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Qualite et precision","importance":"High","expression":"Tradition horlogere; exigence du \"Swiss Made\"; zero tolerance pour la mediocrite; attention au detail","marketing_angle":"Mettre en avant fiabilite, durabilite, precision; \"Fabrique en Suisse\" est un argument premium"},{"value":"Neutralite","importance":"High","expression":"Non-alignement politique; tradition diplomatique (Geneve); impartialite; equilibre","marketing_angle":"Messages equilibres; eviter de prendre parti; positionnement inclusif; pas de declaration politique"},{"value":"Discretion","importance":"High","expression":"Respect de la vie privee; tradition bancaire; affaires personnelles gardees privees; sobriete","marketing_angle":"Respecter la protection des donnees; pas de questions intrusives; marketing subtil"},{"value":"Ponctualite","importance":"High","expression":"Le temps est precieux; les CFF sont une reference; les retards sont inacceptables","marketing_angle":"Respecter les delais de livraison; creneaux precis; communiquer les retards immediatement"},{"value":"Consensus et compromis","importance":"High","expression":"Culture de democratie directe; toutes les voix comptent; decisions par accord","marketing_angle":"Langage inclusif; proposer des options; respecter les avis divergents"},{"value":"Respect multilinguistique","importance":"High","expression":"Quatre langues officielles; aucune culture dominante; fierte regionale","marketing_angle":"Reconnaitre la diversite linguistique; eviter le germanocentrisme; respecter toutes les regions"},{"value":"Fiabilite (Confiance)","importance":"High","expression":"Tenir ses promesses; qualite constante; service dependable; confiance par les actes","marketing_angle":"Delivrer exactement ce qui est promis; experience coherente; construire la confiance"},{"value":"Modestie","importance":"Medium","expression":"Sous-estimation preferee; succes montre par la qualite pas par la vantardise; confiance discrete","marketing_angle":"Eviter les superlatifs; laisser la qualite parler; pas de pretentions tape-a-l\'oeil"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Democratie directe","importance":"Low","expression":"Systeme politique unique; participation citoyenne; votations; source de fierte; peut etre reference respectueusement","marketing_angle":""},{"value":"Tradition de neutralite","importance":"Medium","expression":"Pierre angulaire historique; complexe dans le contexte moderne (relations UE, sanctions); traiter respectueusement","marketing_angle":""},{"value":"Geneve internationale","importance":"Low","expression":"Siege ONU, CICR, OMC; vocation humanitaire; diplomatie; fierte romande specifique","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'fr-CH: Communication style is balanced. Hierarchy importance: medium. Orientation: Individualist (focus on \'you\'). Core values: Qualite et precision, Neutralite, Discretion.',
    c.taboos_summary = 'CRITICAL TABOOS: Comparer les Suisses aux Francais de maniere defavorable, Confondre Suisse romande et France, Favoritisme entre regions linguistiques. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-CH.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

