    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'low',
    c.individualism_level = 'individualist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:30","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Community and belonging","importance":"High","expression":"Strong local identities (parish, county, town); GAA club loyalty; \"knowing everyone\"; supporting local","marketing_angle":"Emphasise local connections, community impact, supporting Irish businesses; \"part of the community\" messaging"},{"value":"Authenticity and genuineness","importance":"High","expression":"Distrust of pretension; \"notions\" are mocked; prefer substance over style; detect insincerity quickly","marketing_angle":"Be genuine, avoid hype; understatement works better than boasting; real customer stories beat polished campaigns"},{"value":"Humour and wit","importance":"High","expression":"Self-deprecation valued; dry wit; storytelling tradition; \"craic\" central to interaction; banter expected","marketing_angle":"Brands that can laugh at themselves win loyalty; clever copy appreciated; humour humanises the brand"},{"value":"Resilience and pragmatism","importance":"High","expression":"\"Ah sure, we\'ll manage\"; problem-solving attitude; making do; economic hardship shaped practical outlook","marketing_angle":"\"Gets the job done\" messaging; practical benefits over luxury positioning; value-conscious framing"},{"value":"Hospitality and warmth","importance":"High","expression":"\"Ceud mile failte\" (hundred thousand welcomes); genuine interest in others; tea offered constantly","marketing_angle":"Warm, welcoming tone; customer is guest not target; genuine helpfulness over scripted service"},{"value":"Family and relationships","importance":"Medium","expression":"Strong extended family ties; multi-generational gatherings; family occasions important","marketing_angle":"Family-focused imagery resonates; multi-generational appeal; \"for the whole family\" works well"},{"value":"Fairness and equality","importance":"Medium","expression":"Egalitarian ethos; dislike of class pretension; \"who do they think they are\" attitude","marketing_angle":"Avoid elitist positioning; value for money messaging; treat all customers equally"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Cultural heritage (literature, music, language)","importance":"Low","expression":"Safe to celebrate; Irish literary tradition (Joyce, Yeats, Heaney); traditional music; Irish language revival welcomed","marketing_angle":""},{"value":"Economic transformation","importance":"Medium","expression":"\"Celtic Tiger\" has mixed associations; tech hub success is celebrated; avoid implying Ireland was backward","marketing_angle":""},{"value":"Irish diaspora and global influence","importance":"Low","expression":"Positive - pride in global Irish community; St. Patrick\'s Day is celebrated (avoid leprechaun stereotypes); emigrant stories resonate","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'en-IE: Communication style is balanced. Hierarchy importance: low. Orientation: Individualist (focus on \'you\'). Core values: Community and belonging, Authenticity and genuineness, Humour and wit.',
    c.taboos_summary = 'CRITICAL TABOOS: British stereotyping of Ireland, Northern Ireland conflict, Famine references. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'en-IE.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

