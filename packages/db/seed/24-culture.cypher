    c.values = '[{"value":"Ordnung (Order)","importance":"High","expression":"Systematic approach to everything; organization prized; clear structures and processes; planning ahead","marketing_angle":"Emphasize reliability, clear processes, well-structured information; avoid chaos or spontaneity messaging"},{"value":"Gruendlichkeit (Thoroughness)","importance":"High","expression":"Doing things properly the first time; attention to detail; complete solutions over quick fixes; no cutting corners","marketing_angle":"Highlight comprehensive features, complete solutions, attention to detail; substance over style"},{"value":"Puenktlichkeit (Punctuality)","importance":"High","expression":"On-time is late; respecting schedules; reliability; time commitments taken seriously","marketing_angle":"Precise delivery windows, punctual service, clear timelines; meeting deadlines is baseline expectation"},{"value":"Qualitaet (Quality)","importance":"High","expression":"Engineering excellence; durability; craftsmanship; Made in Germany pride; function over form","marketing_angle":"Quality certifications, durability messaging, engineering precision; TUeV, DIN standards resonate"},{"value":"Zuverlaessigkeit (Reliability)","importance":"High","expression":"Keeping promises; consistent performance; trust through predictability; long-term relationships","marketing_angle":"Honor commitments precisely; consistent service quality; reliability as competitive advantage"},{"value":"Direktheit (Directness)","importance":"Medium","expression":"Clear, unambiguous communication; honesty valued over politeness; saying what you mean","marketing_angle":"Be straightforward; avoid marketing fluff; credible claims over enthusiasm; transparency appreciated"},{"value":"Privatsphaere (Privacy)","importance":"Medium","expression":"Personal matters kept private; clear boundaries between professional and personal; data protection consciousness","marketing_angle":"Respect privacy; DSGVO compliance essential; minimal data collection; transparent data use"},{"value":"Sachlichkeit (Objectivity)","importance":"Medium","expression":"Fact-based decisions; rational arguments; evidence over emotion; substance over style","marketing_angle":"Lead with facts and specifications; avoid emotional manipulation; evidence-based claims"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Engineering and manufacturing (Maschinenbau)","importance":"Low","expression":"Car industry, Mittelstand, precision engineering; safe and positive reference","marketing_angle":""},{"value":"Social market economy (Soziale Marktwirtschaft)","importance":"Low","expression":"Balance of capitalism and social safety; can reference positively","marketing_angle":""},{"value":"Cultural heritage (Kultur)","importance":"Low","expression":"Music (Bach, Beethoven), philosophy, literature; safe references to high culture","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'de-DE: Communication style is direct. Hierarchy importance: medium. Orientation: Individualist (focus on \'you\'). Core values: Ordnung (Order), Gruendlichkeit (Thoroughness), Puenktlichkeit (Punctuality).',
    c.taboos_summary = 'CRITICAL TABOOS: Nazi era and Holocaust, Swastika and Nazi symbols, Comparing anything to Nazis/Hitler. Always avoid these topics.',
