    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"බුද්ධාගම (Buddhism/Buddhist values)","importance":"High","expression":"Theravada Buddhism deeply embedded; temple culture; dana (giving); mindfulness; \"සද්ධර්මය\" (good doctrine) guides conduct","marketing_angle":"Spiritual wellbeing themes; ethical positioning; mindfulness benefits; \"සතුට\" (contentment) over materialism"},{"value":"ගෞරවය (Respect)","importance":"High","expression":"Hierarchical respect for elders, teachers, monks; \"ආයුබෝවන්\" greeting with palms together; parental respect as duty","marketing_angle":"Respectful address always; elder-inclusive imagery; humble service attitude; proper honorifics"},{"value":"පවුල (Family)","importance":"High","expression":"Extended family networks strong; multi-generational households; family honor important; collective decision-making","marketing_angle":"Family-centric messaging; multi-generational benefits; \"පවුලේ සතුට\" themes; products serving entire household"},{"value":"සත්කාරය (Hospitality)","importance":"High","expression":"Guest is honored; generous hosting tradition; \"ආගන්තුක සත්කාරය\" considered virtue; offering tea/food as greeting","marketing_angle":"Warm welcome experiences; generous offerings; hospitable service; customer-as-guest mindset"},{"value":"ශික්ෂණය (Education)","importance":"Medium","expression":"Education highly valued; professional degrees as status markers; English education prestigious; tuition culture","marketing_angle":"Education benefits; career advancement; knowledge positioning; family pride through achievement"},{"value":"මධ්‍යස්ථභාවය (Moderation/Middle path)","importance":"Medium","expression":"Buddhist influence on avoiding extremes; \"මධ්‍යම මාර්ගය\" philosophy; contentment valued over excess","marketing_angle":"Balanced messaging; quality over quantity; sustainable value; avoid excess/extreme claims"},{"value":"කාර්මික බෞද්ධ (Karma/Merit)","importance":"Medium","expression":"Actions have consequences; \"පින්කම්\" (meritorious deeds) important; charity and dana valued","marketing_angle":"Ethical business practices; giving back themes; quality-karma connection; merit-earning opportunities"},{"value":"ස්වදේශීය (Local pride)","importance":"Medium","expression":"Pride in Sri Lankan products, culture, craftsmanship; \"Made in Sri Lanka\" resonates; Ceylon heritage","marketing_angle":"Local authenticity; heritage positioning; supporting local economy; pride in national products"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Buddhist heritage and temples","importance":"Low","expression":"Safe; ancient temples, stupas, Buddhist philosophy; use respectfully; never commercialize sacred imagery","marketing_angle":""},{"value":"Ceylon Tea","importance":"Low","expression":"National pride; quality reputation; safe for heritage and quality positioning","marketing_angle":""},{"value":"Independence (1948)","importance":"Medium","expression":"February 4th celebration; avoid colonial comparisons; respectful patriotic references acceptable","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'si-LK: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: බුද්ධාගම (Buddhism/Buddhist values), ගෞරවය (Respect), පවුල (Family).',
