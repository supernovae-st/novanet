    c.values = '[{"value":"Calidez/Calor humano","importance":"High","expression":"Immediate warmth with strangers; physical closeness; terms of endearment (\"mi amor\", \"manito\"); genuine interest in wellbeing","marketing_angle":"Warm, personal tone; acknowledge the person; \"con mucho gusto\" service; closeness not formality"},{"value":"Fe/Religiosidad","importance":"High","expression":"Catholic traditions embedded deeply; \"Si Dios quiere\" in daily speech; church on Sundays; saints\' feast days; religious holidays major events","marketing_angle":"Respect religious traditions; holiday marketing around Semana Santa, Navidad; avoid sacrilege"},{"value":"Beisbol","importance":"High","expression":"National passion; children grow up playing; MLB stars are national heroes (Pedro Martinez, Manny Ramirez, David Ortiz); spring training facilities","marketing_angle":"Baseball metaphors resonate; Dominican MLB pride; \"jonron\" success language; sports as unifier"},{"value":"Musica y baile (Merengue/Bachata)","importance":"High","expression":"Merengue national dance; bachata global export; music everywhere; dancing is social bonding; Juan Luis Guerra, Romeo Santos iconic","marketing_angle":"Musical references; rhythm and energy; celebration; \"suena a merengue\" = feels right"},{"value":"Respeto (to elders, authority)","importance":"Medium","expression":"Deference to parents, elders; \"bendicion\" greeting to elders; acknowledging hierarchy while maintaining warmth","marketing_angle":"Acknowledge seniority warmly; \"Don/Dona\" usage; respect but not distance"},{"value":"Hospitalidad","importance":"Medium","expression":"Guests offered food and drink; sharing is expected; open doors; welcoming strangers as potential friends","marketing_angle":"Generous, welcoming language; \"como en tu casa\" comfort; sharing themes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Baseball/MLB success","importance":"Low","expression":"Safe universal pride; Dominican Republic is largest source of foreign MLB players; Pedro Martinez, Big Papi national heroes","marketing_angle":""},{"value":"Caribbean beaches/tourism","importance":"Low","expression":"Punta Cana, Samana, Puerto Plata; beautiful country; tourism success story","marketing_angle":""},{"value":"Diaspora success","importance":"Low","expression":"New York Dominicans (Dominicanyorks); success abroad while maintaining ties; American Dream narrative","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'es-DO: Communication style is direct. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Calidez/Calor humano, Fe/Religiosidad, Beisbol.',
    c.taboos_summary = 'CRITICAL TABOOS: Trujillo dictatorship (1930-1961), Haiti/Haitian relations, Colorism/racial hierarchy. Always avoid these topics.',
