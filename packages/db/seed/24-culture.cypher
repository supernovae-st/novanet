    c.values = '[{"value":"Famille elargie (Libota)","importance":"High","expression":"Reseaux familiaux etendus ; responsabilite collective ; soin intergenerationnel ; honneur familial","marketing_angle":"Messagerie centree sur la famille ; benefices pour toute la famille ; \"pour toute la famille\" ; decisions collectives"},{"value":"Hospitalite (Limemia)","importance":"High","expression":"Accueil genereux des visiteurs ; partage des repas ; faire en sorte que les invites se sentent chez eux","marketing_angle":"Emphase sur le service accueillant et genereux ; \"vous etes les bienvenus\" ; communication orientee hospitalite"},{"value":"Unite et solidarite (Bomoko)","importance":"High","expression":"Cooperation communautaire ; entraide entre voisins ; resolution collective des problemes ; philosophie Ubuntu","marketing_angle":"Positionner comme benefice communautaire ; \"nous travaillons ensemble\" ; narratifs de solidarite"},{"value":"Honneur et dignite (Lokumu)","importance":"High","expression":"Reputation personnelle ; nom de famille ; respect de l\'autorite et des aines ; eviter la honte","marketing_angle":"Ne jamais embarrasser les clients ; proteger la dignite ; reconnaitre la valeur ; positionnement respectueux"},{"value":"Respect des aines (Botosi)","importance":"High","expression":"Deference envers les aines ; respect de l\'autorite traditionnelle et religieuse ; obeissance aux parents","marketing_angle":"Montrer du respect dans toutes les communications ; reconnaitre la hierarchie ; jamais condescendant"},{"value":"Generosite de coeur (Motema Malamu)","importance":"Medium","expression":"Generosite d\'esprit ; bonte ; intentions sinceres ; absence de malice","marketing_angle":"Communication authentique et sincere ; soin veritable ; \"avec un coeur sincere\""},{"value":"Fraternite (Bondeko)","importance":"Medium","expression":"Relations egalitaires ; entraide mutuelle ; traiter les etrangers comme des freres","marketing_angle":"Messagerie inclusive ; encadrement \"freres et soeurs\" ; appartenance communautaire"},{"value":"Foi et spiritualite","importance":"Medium","expression":"Christianisme profondement ancre ; priere et benedictions quotidiennes ; Eglises de reveil, catholique, protestante","marketing_angle":"Messagerie respectueuse de la foi ; benedictions appropriees ; \"Que Dieu vous benisse\" bienvenu"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Musique congolaise (rumba, soukouss)","importance":"Low","expression":"Reconnue internationalement ; source de grande fierte ; Kinshasa = capitale musicale ; references aux artistes tres efficaces","marketing_angle":""},{"value":"Taille et importance geographique","importance":"Low","expression":"Plus grand pays d\'Afrique subsaharienne ; \"coeur de l\'Afrique\" ; utiliser librement","marketing_angle":""},{"value":"Les Leopards (football)","importance":"Low","expression":"Passion pour l\'equipe nationale ; participation a la CAN celebree ; TP Mazembe, AS Vita Club ; partenariats sportifs positifs","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'fr-CD: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Famille elargie (Libota), Hospitalite (Limemia), Unite et solidarite (Bomoko).',
    c.taboos_summary = 'CRITICAL TABOOS: Divisions ethniques et tribalisme, Commentaire politique (gouvernement actuel), Conflit a l\'Est de la RDC. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-CD.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

