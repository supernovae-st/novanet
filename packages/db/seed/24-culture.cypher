    c.holidays = '[]',
    c.business_hours = '{"end":"18:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Mêvanperwerî (Hospitality)","importance":"High","expression":"Guests treated as sacred; elaborate hosting rituals; offering food, tea, warmth","marketing_angle":"Position brand as hospitable host; emphasize generous service; warm customer treatment; \"mala te ava\" (blessings on your home) resonates"},{"value":"Namûs (Honor)","importance":"High","expression":"Family reputation protection; collective responsibility; avoiding shame","marketing_angle":"Emphasize reliability, discretion, quality; never risk customer\'s standing; trust-based messaging"},{"value":"Malbat (Family)","importance":"High","expression":"Extended family networks; collective decisions; multi-generational bonds","marketing_angle":"Family-oriented messaging; products benefiting whole clan; respect for elders in all communications"},{"value":"Xwebûn (Authenticity/Being oneself)","importance":"High","expression":"Cultural identity preservation; language pride; authenticity valued","marketing_angle":"Celebrate Kurdish identity; use genuine Kurmanji; avoid token representation; \"Kurdî bixwîne\" (Read Kurdish) campaigns resonate"},{"value":"Rêz (Respect)","importance":"High","expression":"Deference to elders, guests, and community; courtesy in all interactions","marketing_angle":"Formal address essential; show respect through language and service; hospitality language mandatory"},{"value":"Welatparêzî (Love of homeland)","importance":"Medium","expression":"Connection to ancestral lands; mountain and nature symbolism; diaspora longing","marketing_angle":"Nature imagery (mountains, plains); homeland themes; \"çiya\" (mountain) symbolism; avoid political framing"},{"value":"Berxwedanî (Resilience)","importance":"Medium","expression":"Perseverance through hardship; community solidarity; strength in adversity","marketing_angle":"Position for long-term value; emphasize durability; resilience narratives without politicization"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Kurdish language and literature","importance":"Medium","expression":"Celebrated but historically suppressed; use proudly but avoid victimhood framing in commercial contexts","marketing_angle":""},{"value":"Dengbêj tradition (oral poetry)","importance":"Low","expression":"Beloved art form; reference with respect; voice and authenticity themes","marketing_angle":""},{"value":"Mountain heritage","importance":"Low","expression":"\"Çiya\" (mountain) symbolism safe; nature connection; avoid political territorial framing","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ku-TR: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Mêvanperwerî (Hospitality), Namûs (Honor), Malbat (Family).',
    c.taboos_summary = 'CRITICAL TABOOS: PKK and armed conflict, Kurdish political parties and movements, Turkey-Kurdistan territorial discussions. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ku-TR.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'en-BW'})
