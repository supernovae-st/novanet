st required"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"NHS (National Health Service)","importance":"High","expression":"Deep emotional attachment; free healthcare at point of use is a defining British value; never criticise","marketing_angle":""},{"value":"Armed forces and veterans","importance":"Medium","expression":"Respect expected; Remembrance Day and poppies important; never commercialise November period","marketing_angle":""},{"value":"Sports heritage","importance":"Low","expression":"Football (soccer), cricket, rugby, tennis (Wimbledon); safe for references; widespread appeal","marketing_angle":""}]',
