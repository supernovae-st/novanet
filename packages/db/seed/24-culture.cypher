    c.business_hours = '{"end":"18:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Хүндэтгэл (Respect)","importance":"High","expression":"Deep reverence for elders, teachers, authority; formal address mandatory; standing when elders enter","marketing_angle":"Use formal register always; acknowledge customer value; show deference to age and experience"},{"value":"Зочломтгой байдал (Hospitality)","importance":"High","expression":"Generous welcome to guests; offering airag, tea, food; ger (yurt) open to travelers","marketing_angle":"Position brand as welcoming host; emphasize service excellence; customer as honored guest"},{"value":"Гэр бүл (Family)","importance":"High","expression":"Extended family bonds; clan identity; collective responsibility; ancestor veneration","marketing_angle":"Family-oriented messaging; multi-generational imagery; products benefiting whole family"},{"value":"Эх орон (Homeland/Patriotism)","importance":"High","expression":"Strong national pride; Chinggis Khaan legacy; steppe heritage; independence celebration","marketing_angle":"Celebrate Mongolian achievements; support local products; respect national symbols"},{"value":"Тэвчээр (Endurance/Resilience)","importance":"Medium","expression":"Ability to withstand hardship; nomadic survival mentality; harsh climate adaptation","marketing_angle":"Emphasize reliability, durability; products that last; overcoming challenges together"},{"value":"Шударга байдал (Honesty/Justice)","importance":"Medium","expression":"Keeping one\'s word; moral uprightness; fair dealing; traditional justice concepts","marketing_angle":"Emphasize trustworthiness; quality guarantees; transparent business practices"},{"value":"Байгаль (Nature Connection)","importance":"Medium","expression":"Sacred relationship with land, sky, animals; environmental stewardship; nomadic harmony","marketing_angle":"Eco-friendly messaging resonates; natural imagery; sustainability appeals"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Chinggis Khaan and Mongol Empire","importance":"Medium","expression":"Revered founding figure; use respectfully; never mock or trivialize; avoid colonial framing","marketing_angle":""},{"value":"Democratic transition (1990)","importance":"Low","expression":"Peaceful revolution celebrated; symbol of national character; positive reference","marketing_angle":""},{"value":"Mongolian script (traditional)","importance":"Medium","expression":"Cultural revival ongoing; respect traditional script; Cyrillic also fully accepted","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'mn-MN: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Хүндэтгэл (Respect), Зочломтгой байдал (Hospitality), Гэр бүл (Family).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting Chinggis Khaan, Inner Mongolia and territorial issues, Criticism of elders or family. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'mn-MN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

