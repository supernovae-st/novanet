    c.values = '[{"value":"Darifa (Hospitality/Warmth)","importance":"High","expression":"Generous welcome, offering tea and food, treating guests as family","marketing_angle":"Position brand as warm host; emphasize marhba (welcome); generous offers and inclusive messaging"},{"value":"Al-\'Ayla (Family)","importance":"High","expression":"Extended family bonds, collective decisions, multi-generational households","marketing_angle":"Family-oriented messaging; show multi-generational benefits; products that bring family together"},{"value":"Karama (Dignity)","importance":"High","expression":"Self-respect, saving face, maintaining honor in public","marketing_angle":"Never embarrass customer; discreet service; respect privacy; quality that reflects well"},{"value":"Al-Tasamoh (Tolerance)","importance":"High","expression":"Religious openness, cultural diversity acceptance, Amazigh-Arab coexistence","marketing_angle":"Emphasize inclusivity; celebrate Morocco\'s multicultural identity; welcome diverse audiences"},{"value":"Al-Iqtisad (Pragmatism)","importance":"Medium","expression":"Value-consciousness, practical choices, stretching resources","marketing_angle":"Clear value proposition; quality-price balance; \"zwin o rkhi\" (nice and affordable) resonates"},{"value":"Al-Hadatha (Modernity)","importance":"Medium","expression":"Embracing progress while respecting tradition, tech adoption, urban development","marketing_angle":"Innovation within tradition; modern solutions respecting heritage; Morocco 2030 vision themes"},{"value":"L-Khir (Blessing/Goodness)","importance":"Medium","expression":"Seeking blessing in transactions, ethical business, community benefit","marketing_angle":"Frame purchases as blessed; ethical sourcing; community impact messaging"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"King Mohammed VI and royal family","importance":"Medium","expression":"Respected widely but avoid political positioning; use for formal/official contexts only","marketing_angle":""},{"value":"Moroccan cuisine and hospitality","importance":"Low","expression":"Universally positive; couscous, tagine, mint tea; hospitality themes always work","marketing_angle":""},{"value":"Western Sahara/Moroccan Sahara","importance":"Critical","expression":"NEVER reference in commercial content; sovereignty issue; causes immediate backlash","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'ar-MA: Communication style is balanced. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Darifa (Hospitality/Warmth), Al-\'Ayla (Family), Karama (Dignity).',
