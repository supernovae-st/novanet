    c.values = '[{"value":"Vanua (land/people/custom)","importance":"High","expression":"Deep connection between people, land, and tradition; identity tied to ancestral lands and village; respect for customary practices","marketing_angle":"Community-rooted messaging; connection to place; honor traditions; \"For Fiji, by Fiji\" resonates"},{"value":"Kerekere (reciprocal sharing)","importance":"High","expression":"Sharing resources within community; obligation to give when asked; mutual support system; generosity expected","marketing_angle":"Generosity messaging; community benefits; sharing economy; \"Together we thrive\""},{"value":"Veiqaravi (service/duty)","importance":"High","expression":"Service to community, church, and elders; volunteering time and resources; collective responsibility","marketing_angle":"Service excellence; community contribution; \"We serve\"; duty-based loyalty programs"},{"value":"Veidokai (respect)","importance":"High","expression":"Deep respect for elders, chiefs, and hierarchy; humility in interactions; deference to authority and tradition","marketing_angle":"Respectful brand voice; honor customer relationships; never condescending; acknowledge status"},{"value":"Loloma (love/kindness)","importance":"High","expression":"Warmth and compassion in interactions; hospitality to strangers; caring for others\' wellbeing","marketing_angle":"Warm, caring messaging; genuine hospitality; heartfelt customer care"},{"value":"Sautu (peace/harmony)","importance":"Medium","expression":"Maintaining social harmony; avoiding conflict; consensus-building; peaceful coexistence","marketing_angle":"Harmonious messaging; avoid confrontational approaches; unity themes"},{"value":"Religious faith","importance":"Medium","expression":"Christian values central to indigenous Fijian life; church attendance important; Sunday observance; prayer in public life","marketing_angle":"Respectful of faith; avoid Sunday promotions; acknowledge spiritual dimension"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Rugby Sevens success","importance":"Low","expression":"Olympic gold (2016, 2020) and World Series dominance; massive national pride; safe ground for celebration","marketing_angle":""},{"value":"Bula greeting and hospitality","importance":"Low","expression":"Internationally recognized; authentic cultural expression; can use warmly in marketing","marketing_angle":""},{"value":"Independence (1970)","importance":"Medium","expression":"National pride but complex history; celebrate without ignoring post-independence challenges","marketing_angle":""}]',
