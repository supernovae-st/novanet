    c.values = '[{"value":"Someah Hade Ka Semah (Warm Hospitality)","importance":"High","expression":"Genuine warmth to guests and strangers; welcoming spirit; friendly openness; treating others with generosity","marketing_angle":"Position brand as welcoming host; warm customer service; friendly approachable tone; hospitality-centered messaging"},{"value":"Silih Asih (Mutual Love)","importance":"High","expression":"Deep caring for community; loving relationships; empathy and compassion; prioritizing others\' well-being","marketing_angle":"Customer care messaging; show genuine concern; community love; \"urang Sunda silih asih\" (Sundanese people love each other)"},{"value":"Silih Asah (Mutual Learning)","importance":"High","expression":"Continuous improvement together; sharing knowledge; helping others grow; education and skill development","marketing_angle":"Educational content; knowledge sharing; \"learning together\" framing; mutual improvement narratives"},{"value":"Silih Asuh (Mutual Nurturing)","importance":"High","expression":"Protecting and nurturing each other; guidance to younger generations; collective care and responsibility","marketing_angle":"Mentorship themes; nurturing brand voice; protective care messaging; generational guidance"},{"value":"Cageur, Bageur, Bener, Pinter, Singer","importance":"High","expression":"Ideal Sundanese character: healthy, good/kind, honest, smart, skillful - holistic excellence standard","marketing_angle":"Quality messaging addressing multiple virtues; honest brand positioning; smart solutions; skilled craftsmanship"},{"value":"Undak-Usuk Basa (Speech Level Respect)","importance":"High","expression":"Elaborate speech levels showing respect; language as expression of social awareness; proper address essential","marketing_angle":"Respectful communication; appropriate honorifics; never talking down; linguistic sensitivity"},{"value":"Handap Asor (Humility)","importance":"Medium","expression":"Self-lowering behavior; not boasting; elevating others; modest self-presentation","marketing_angle":"Humble brand voice; avoid arrogance; customer-elevating language; modest claims"},{"value":"Tata Titi Duduga Peryoga (Careful Consideration)","importance":"Medium","expression":"Thoughtful, measured behavior; careful consideration before action; prudent decision-making","marketing_angle":"Quality over haste messaging; thoughtful approach; careful attention to detail; considered solutions"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sundanese language and culture","importance":"Low","expression":"Safe pride reference; celebrate Basa Sunda; acknowledge cultural distinctiveness from Javanese","marketing_angle":""},{"value":"Angklung (bamboo instrument)","importance":"Low","expression":"UNESCO Intangible Heritage; uniquely Sundanese; safe cultural reference; educational heritage","marketing_angle":""},{"value":"Sundanese cuisine uniqueness","importance":"Low","expression":"Fresh vegetables, sambal, distinct flavors; pride in culinary identity separate from Javanese food","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'su-ID: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Someah Hade Ka Semah (Warm Hospitality), Silih Asih (Mutual Love), Silih Asah (Mutual Learning).',
