    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"08:30"}',
    c.values = '[{"value":"Gemuetlichkeit (Cozy comfort)","importance":"High","expression":"Appreciation for relaxed, comfortable social atmosphere; coffee house culture; unhurried enjoyment","marketing_angle":"Emphasize comfort, quality of life, \"Zeit nehmen\" (taking time); avoid aggressive urgency"},{"value":"Qualitaet und Tradition","importance":"High","expression":"Pride in craftsmanship, established standards; \"Austrian quality\" as distinct from German efficiency","marketing_angle":"Reference heritage, proven quality, \"Seit Generationen\" (for generations); local manufacturing"},{"value":"Titles and Formality","importance":"High","expression":"Extensive use of academic and professional titles (Herr Doktor, Frau Magister, Herr Ingenieur); respect hierarchy","marketing_angle":"Use correct titles; acknowledge expertise; formal address builds trust"},{"value":"Regional Identity","importance":"High","expression":"Strong pride in Bundeslaender (federal states); Vienna distinct from Tirol, Salzburg from Styria","marketing_angle":"Acknowledge regional diversity; localize where possible; avoid Vienna-centrism for national campaigns"},{"value":"Cultural Sophistication","importance":"Medium","expression":"Vienna as music capital; Habsburg cultural heritage; appreciation for arts, opera, classical music","marketing_angle":"Reference cultural achievements tastefully; sophistication without elitism"},{"value":"Work-Life Balance","importance":"Medium","expression":"Value leisure time, holidays, Feierabend culture; less workaholic than German stereotype","marketing_angle":"Respect personal time; avoid \"always-on\" messaging; emphasize quality of life"},{"value":"Conflict Avoidance","importance":"Medium","expression":"Preference for harmony; indirect disagreement; diplomatic phrasing; \"Vielleicht koennte man...\"","marketing_angle":"Soft-sell approaches; avoid confrontational marketing; suggest rather than demand"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Habsburg cultural legacy","importance":"Low","expression":"Architecture, music, arts; safe for cultural references; avoid political Habsburg nostalgia","marketing_angle":""},{"value":"Alpine landscape","importance":"Low","expression":"Mountains, skiing, clean environment; positive association; tourism-friendly","marketing_angle":""},{"value":"Distinct from Germany","importance":"Medium","expression":"Austrians are NOT Germans; never conflate; Austrian German is distinct; respect differences","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"MODERATE_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'de-AT: Communication style is indirect. Hierarchy importance: high. Orientation: Mixed individual/collective. Core values: Gemuetlichkeit (Cozy comfort), Qualitaet und Tradition, Titles and Formality.',
    c.taboos_summary = 'CRITICAL TABOOS: Calling Austrians "German", Nazi period/Holocaust, Nazi imagery or symbols. Always avoid these topics.',
