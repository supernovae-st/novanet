    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Obuntu Bulamu (Shared Humanity)","importance":"High","expression":"\"I am because we are\"; hospitality to strangers; interconnectedness of all people; community responsibility for individual wellbeing","marketing_angle":"Community-focused messaging; show how product/service benefits the collective; \"we\'re in this together\" framing"},{"value":"Family and Clan Identity","importance":"High","expression":"Extended family networks; clan affiliations matter; support obligations extend broadly; multigenerational households common","marketing_angle":"Family-centric imagery; products that benefit whole family; acknowledge extended family dynamics; multigenerational appeal"},{"value":"Ekitiibwa (Respect/Honor)","importance":"High","expression":"Deep respect for elders, titles, and positions; deferential behavior expected; polite greetings are mandatory; formal address in public","marketing_angle":"Use formal register; always include honorifics when known; show respect for customer\'s time and dignity"},{"value":"Religious Faith","importance":"High","expression":"Christianity dominant (Catholic, Anglican, Pentecostal); Islam significant (15-20%); faith deeply integrated into daily life; blessings and religious expressions common","marketing_angle":"Acknowledge faith respectfully; blessed/grateful themes resonate; avoid overtly secular positioning"},{"value":"Hospitality (Okwaniriza)","importance":"High","expression":"Uganda known for warmth toward visitors; sharing food and drink with guests; hosting obligations taken seriously","marketing_angle":"Welcome-focused messaging; show warmth and generosity; hospitality metaphors resonate"},{"value":"Hard Work and Self-Reliance","importance":"Medium","expression":"Entrepreneurial spirit; informal sector innovation; side businesses common; \"hustle\" mentality to provide for family","marketing_angle":"Celebrate self-made success; practical solutions; enable small business and personal growth"},{"value":"Education as Path to Success","importance":"Medium","expression":"Education seen as key to social mobility; significant family sacrifices for school fees; academic achievement celebrated","marketing_angle":"Education partnerships; supporting learning; acknowledge parent investment in children\'s futures"},{"value":"Resilience and Optimism","importance":"Medium","expression":"History of overcoming adversity; forward-looking despite challenges; belief in better future","marketing_angle":"Hopeful messaging; solutions-oriented; acknowledge challenges but focus on overcoming them"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Source of the Nile","importance":"Low","expression":"Jinja has the Nile source; major tourist attraction; safe positive reference point","marketing_angle":""},{"value":"Independence (1962)","importance":"Medium","expression":"Pride in sovereignty; but post-independence history complex; focus on nationhood rather than specific leaders","marketing_angle":""},{"value":"Coffee Production","importance":"Low","expression":"Ugandan coffee internationally recognized; agricultural heritage; Robusta coffee origin; safe reference","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-UG: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Obuntu Bulamu (Shared Humanity), Family and Clan Identity, Ekitiibwa (Respect/Honor).',
    c.taboos_summary = 'CRITICAL TABOOS: LGBTQ+ topics, Ethnic/tribal tensions, Current political opposition. Always avoid these topics.',
