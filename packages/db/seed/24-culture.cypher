pression":"Ancestral knowledge valued; oral tradition; elders as repositories of wisdom","marketing_angle":"Educational content respected; wisdom-based messaging; elder voices valued"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Machu Picchu/Tawantinsuyu heritage","importance":"Low","expression":"Source of immense pride; Incan civilization celebrated; safe to reference respectfully","marketing_angle":""},{"value":"Textile traditions","importance":"Low","expression":"UNESCO heritage; weavers honored; patterns carry cosmological meaning; artisanal pride","marketing_angle":""},{"value":"Inti Raymi and festivals","importance":"Low","expression":"Sun festival revived; cultural celebration; tourism positive but authenticity valued","marketing_angle":""},{"value":"Resistance and survival","importance":"Medium","expression":"Pride in surviving colonization but connected to trauma; celebrate carefully","marketing_angle":""}]',
