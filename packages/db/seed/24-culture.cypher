MERGE (c:Culture {key: 'fr-CI'})
SET c.display_name = 'fr-CI Culture Norms',
    c.description = 'Cultural context and norms for fr-CI',
    c.llm_context = 'USE: fr-CI culture (northern hemisphere, balanced communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Hospitalite et accueil (Akwaba)","importance":"High","expression":"\"Akwaba\" (bienvenue en Baoule) symbolise l\'accueil chaleureux ivoirien ; l\'etranger est sacre ; partager le repas est un honneur ; ne jamais refuser l\'eau ou l\'hospitalite","marketing_angle":"Communication chaleureuse et accueillante ; \"Bienvenue dans la famille\" ; le client est un invite d\'honneur ; service genereux et personnalise ; \"On est ensemble\""},{"value":"Respect des aines et de la hierarchie","importance":"High","expression":"Les aines sont consultes pour les decisions importantes ; salutations elaborees obligatoires ; \"Tonton\" et \"Tante\" sont des marques de respect meme sans lien familial ; les chefs traditionnels sont tres respectes","marketing_angle":"Utiliser des temoignages de figures respectees ; montrer le respect dans le service client ; valoriser l\'experience et la sagesse ; les titres sont importants"},{"value":"Solidarite communautaire","importance":"High","expression":"Concept de famille elargie ; entraide lors des evenements (mariages, deces, baptemes) ; cotisations collectives (tontines) ; \"Un seul doigt ne peut pas ramasser un caillou\"","marketing_angle":"Messages de communaute : \"Ensemble\", \"On est ensemble\" ; offres familiales ; programmes de parrainage ; benefices partages ; solidarite nationale"},{"value":"Joie de vivre et optimisme","importance":"High","expression":"Malgre les epreuves, les Ivoiriens celebrent la vie ; musique (coupe-decale, zouglou), danse, fetes ; ambiance des maquis ; capacite a rire et positiver","marketing_angle":"Ton positif et energique ; celebrer les petites victoires ; humour bienveillant acceptable ; references a la musique et la fete dans les contextes appropries"},{"value":"Dignite et fierte","importance":"High","expression":"La reputation personnelle et familiale est precieuse ; ne pas humilier publiquement ; maintenir son rang avec grace ; fierte d\'etre Ivoirien ; resilience face aux epreuves","marketing_angle":"Ne jamais placer le client en situation d\'embarras ; discretion sur les questions d\'argent ; respect constant de la dignite ; celebrer la fierte ivoirienne"},{"value":"Reconciliation et paix","importance":"Medium","expression":"Apres la crise de 2010-2011, forte valorisation de la cohesion nationale ; vivre-ensemble entre ethnies et religions ; dialogue et pardon","marketing_angle":"Messages d\'unite nationale ; eviter tout ce qui divise ; celebrer la diversite ; \"Cote d\'Ivoire unie\" ; solidarite inter-communautaire"},{"value":"Reussite et succes","importance":"Medium","expression":"Admiration pour la reussite economique ; Abidjan comme capitale economique de l\'UEMOA ; entrepreneuriat valorise ; \"faire son chemin\" respecte","marketing_angle":"Celebrer le succes ; offres premium pour la classe moyenne emergente ; aspiration appreciee ; reussite par le travail valorisee"},{"value":"Elegance et style","importance":"Medium","expression":"Importance de la presentation ; bien s\'habiller montre le respect de soi et des autres ; pagne, mode, coiffure sont des marqueurs sociaux","marketing_angle":"Attention a l\'esthetique ; qualite perceptible ; marques qui valorisent l\'elegance appreciees ; soin apporte a la presentation"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Didier Drogba","importance":"Low","expression":"Icone nationale, legende du football, ambassadeur de paix ; peut etre reference positivement ; respecte par toutes les generations et communautes ; a joue un role dans la reconciliation","marketing_angle":""},{"value":"Felix Houphouet-Boigny","importance":"Medium","expression":"Pere de l\'independance, premier president ; Basilique de Yamoussoukro ; \"Pere de la Nation\" pour beaucoup ; utiliser avec respect car heritage politique debattu par certains","marketing_angle":""},{"value":"Abidjan \"Perle des Lagunes\"","importance":"Low","expression":"Capitale economique ; modernite ; tours, Plateau, Cocody ; fierte urbaine ; dynamisme","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'fr-CI: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Hospitalite et accueil (Akwaba), Respect des aines et de la hierarchie, Solidarite communautaire.',
    c.taboos_summary = 'CRITICAL TABOOS: Crise post-electorale 2010-2011, Ethnicisme et clivages Nord-Sud, Insultes aux parents ou ancetres. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-CI.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

