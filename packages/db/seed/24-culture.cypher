    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-NG: Communication style is balanced. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Respect for Elders, Faith/Religion, Family/Community.',
    c.taboos_summary = 'CRITICAL TABOOS: Ethnic stereotyping, Religious conflict, Biafra/Civil War. Always avoid these topics.',
