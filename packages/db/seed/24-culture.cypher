    c.values = '[{"value":"Myhmansoyerlik (Hospitality)","importance":"High","expression":"Generous treatment of guests, offering tea and bread, welcoming traditions","marketing_angle":"Position brand as a gracious host; emphasize service excellence, customer care, warmth"},{"value":"Hormat (Respect)","importance":"High","expression":"Deep reverence for elders (yasulylar), parents, teachers, authority figures","marketing_angle":"Use formal register; acknowledge customer value; show deference to age and position"},{"value":"Masgala (Family)","importance":"High","expression":"Extended family bonds, clan (taypa) connections, collective identity","marketing_angle":"Family-oriented messaging; multi-generational imagery; products benefiting whole household"},{"value":"Watancilik (Patriotism)","importance":"High","expression":"Strong national pride, reverence for state symbols, independence celebration","marketing_angle":"Celebrate local achievements; support Turkmen-made products; respect national symbols"},{"value":"Adalat (Fairness/Justice)","importance":"Medium","expression":"Honest dealings, keeping promises, moral uprightness","marketing_angle":"Emphasize trustworthiness, quality guarantees, transparent practices"},{"value":"Agzybirlik (Unity/Solidarity)","importance":"Medium","expression":"National cohesion, collective harmony, social togetherness","marketing_angle":"Emphasize togetherness; avoid divisive content; celebrate national unity themes"},{"value":"Edep (Modesty/Propriety)","importance":"Medium","expression":"Modest behavior, proper conduct, self-restraint, humility","marketing_angle":"Avoid flashy or boastful messaging; emphasize substance over show; understated quality"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Akhal-Teke horses","importance":"Low","expression":"Supreme national symbol; safe for positive imagery; represents beauty, speed, endurance","marketing_angle":""},{"value":"Neutrality status","importance":"Medium","expression":"UN-recognized permanent neutrality since 1995; diplomatic pride point; avoid implying any bias","marketing_angle":""},{"value":"Natural gas reserves","importance":"Low","expression":"Economic pride; development symbol; appropriate for prosperity messaging","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'tk-TM: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Myhmansoyerlik (Hospitality), Hormat (Respect), Masgala (Family).',
