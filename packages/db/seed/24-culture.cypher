    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Ubumwe (Unity)","importance":"High","expression":"National motto emphasizing togetherness; avoiding ethnic divisions; collective identity as Rwandans first","marketing_angle":"Position brand as unifying force; emphasize community benefits; avoid any segmentation that could imply division"},{"value":"Agaciro (Dignity/Self-worth)","importance":"High","expression":"Self-reliance philosophy; Agaciro Development Fund; pride in Rwandan identity; refusing victimhood","marketing_angle":"Empower customers with dignity; avoid patronizing language; position products as tools of self-improvement"},{"value":"Icyubahiro (Respect)","importance":"High","expression":"Deference to elders, titles, hierarchy; polite greetings mandatory; formal address in public","marketing_angle":"Use formal register; always include honorifics when known; show respect for customer\'s time and intelligence"},{"value":"Ubunyangamugayo (Integrity)","importance":"High","expression":"Zero tolerance for corruption; accountability culture; transparency expected; keeping promises","marketing_angle":"Emphasize trustworthiness; deliver on commitments; transparent pricing and policies; no hidden terms"},{"value":"Kwiyubaka (Self-reliance)","importance":"Medium","expression":"Post-genocide rebuilding spirit; Made in Rwanda initiatives; reducing foreign dependency","marketing_angle":"Highlight local partnerships; support Rwandan success stories; position solutions that empower independence"},{"value":"Ubufatanye (Solidarity)","importance":"Medium","expression":"Mutual assistance traditions; Umuganda community service; helping neighbors; collective responsibility","marketing_angle":"Community-focused messaging; CSR resonates strongly; show how brand contributes to collective welfare"},{"value":"Iterambere (Progress/Development)","importance":"Medium","expression":"Vision 2050 aspirations; modernization embrace; technology adoption; continuous improvement mindset","marketing_angle":"Innovation messaging works well; connect to national development; progress-oriented positioning"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Post-genocide Reconciliation","importance":"High","expression":"Pride in rebuilding and unity, but approach with extreme respect; never trivialize the journey; acknowledge without dwelling; focus on resilience and forward movement","marketing_angle":""},{"value":"Gorilla Conservation","importance":"Low","expression":"Successful conservation efforts; ecotourism pride; Virunga mountains; safe positive reference","marketing_angle":""},{"value":"Women in Leadership","importance":"Medium","expression":"Highest percentage of women parliamentarians globally; proud achievement; use respectfully without tokenism","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'rw-RW: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Ubumwe (Unity), Agaciro (Dignity/Self-worth), Icyubahiro (Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: Ethnic references (Hutu/Tutsi/Twa), 1994 Genocide denial/minimization, Divisionism (ubwoko). Always avoid these topics.',
    c.template_version = '3.1',
