    c.values = '[{"value":"Familja (Family)","importance":"High","expression":"Multi-generational households common; family decisions made collectively; Sunday lunch is sacred","marketing_angle":"Frame products/services as benefiting the whole family; respect family authority in decisions"},{"value":"Fidi (Faith/Religion)","importance":"High","expression":"Catholic identity deeply embedded; festa celebrations, religious holidays, church attendance","marketing_angle":"Respect religious calendar; avoid scheduling conflicts with major feasts; Catholic values underpin social norms"},{"value":"Komunita (Community)","importance":"High","expression":"Tight-knit society; everyone knows everyone; reputation matters; word-of-mouth dominant","marketing_angle":"Every customer interaction matters; community trust essential; local endorsement powerful"},{"value":"Ospitalita (Hospitality)","importance":"High","expression":"Genuine warmth to visitors and customers; generosity expected; treating guests well reflects honor","marketing_angle":"Be genuinely welcoming; personal service valued over efficiency; make customers feel like honored guests"},{"value":"Lealta (Loyalty)","importance":"Medium","expression":"Strong loyalty to village, band club, political party, brands once trust established","marketing_angle":"Reward loyalty; long-term relationships valued; switching brands seen as somewhat disloyal"},{"value":"Dinjita (Dignity)","importance":"Medium","expression":"Maintaining face important; public embarrassment deeply offensive; respect essential","marketing_angle":"Never shame customers publicly; handle complaints discreetly; protect dignity in all interactions"},{"value":"Pragmatizmu (Pragmatism)","importance":"Medium","expression":"Mediterranean practicality; focus on what works; flexibility valued over rigid rules","marketing_angle":"Offer practical solutions; flexibility in service; understand local ways of getting things done"},{"value":"Genijalita (Ingenuity)","importance":"Medium","expression":"Making the most with limited resources; creative problem-solving on small island","marketing_angle":"Appreciate resourcefulness; local solutions valued; \"Maltese way\" of solving problems"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Maltese language survival","importance":"Low","expression":"Unique Semitic language written in Latin script - genuine source of pride; safe to celebrate","marketing_angle":""},{"value":"Knights of Malta history","importance":"Low","expression":"Hospitaller heritage (1530-1798) widely celebrated; Valletta as legacy; safe territory","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"MEDIUM_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'mt-MT: Communication style is direct. Hierarchy importance: medium. Orientation: Mixed individual/collective. Core values: Familja (Family), Fidi (Faith/Religion), Komunita (Community).',
    c.taboos_summary = 'CRITICAL TABOOS: Political party affiliation, Abortion, PN vs PL politics. Always avoid these topics.',
