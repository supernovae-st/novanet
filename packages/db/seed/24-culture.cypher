    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Teranga (Hospitality)","importance":"High","expression":"Legendary Senegalese hospitality; welcoming strangers into home; sharing meals; generosity to guests and neighbors; hosts give their best","marketing_angle":"Core brand positioning; \"Welcome\" messaging; generosity offers; \"Dalal ak jaamm\" themes; customer treated as honored guest"},{"value":"Kersa (Discretion/Dignity)","importance":"High","expression":"Maintaining dignity and discretion; not boasting; handling matters privately; modesty in success; quiet excellence","marketing_angle":"Understated quality; dignified communication; never shame customers; privacy respect; subtle prestige"},{"value":"Jom (Honor/Courage)","importance":"High","expression":"Personal honor and courage; keeping one\'s word; moral courage; standing up for principles; integrity in adversity","marketing_angle":"Trust-based messaging; \"Word is bond\" positioning; integrity claims; reliable promises"},{"value":"Ngor (Dignity/Self-Respect)","importance":"High","expression":"Self-respect and dignity; not accepting humiliation; maintaining composure; pride without arrogance","marketing_angle":"Respect-based communication; never condescend; honor customer\'s status; dignified positioning"},{"value":"Yiw (Faith/Islam)","importance":"High","expression":"Islam permeates daily life; prayers, greetings, ethics shaped by Islamic principles; Sufi brotherhoods (Mourides, Tijanes) central","marketing_angle":"Islamic values alignment; respect for religious calendar; brotherhood connections; trustworthiness through faith"},{"value":"Mbokk (Family/Kinship)","importance":"High","expression":"Extended family networks; collective responsibility; elders honored; children as blessing; clan solidarity","marketing_angle":"Family-centered messaging; multi-generational appeal; collective benefits; \"Kër gi\" (the household) themes"},{"value":"Liggéey (Work/Effort)","importance":"Medium","expression":"Hard work valued; especially Mouride work ethic; \"work is prayer\" mentality; entrepreneurship admired","marketing_angle":"Work ethic appreciation; effort-reward messaging; entrepreneurial spirit; Mouride work culture"},{"value":"Xam-xam (Knowledge/Wisdom)","importance":"Medium","expression":"Islamic scholarship valued; Quranic education traditional; wisdom of elders respected; learning encouraged","marketing_angle":"Educational content valued; wisdom-sharing; expert positioning; scholarly respect"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Democracy and stability","importance":"Low","expression":"Senegal\'s peaceful transitions; no coups since independence; safe patriotic messaging","marketing_angle":""},{"value":"Mouride brotherhood/Touba","importance":"Medium","expression":"Major religious pride; reference with utmost respect; avoid commercial exploitation","marketing_angle":""},{"value":"Léopold Sédar Senghor","importance":"Low","expression":"Founding father; poet-president; Negritude movement; cultural and literary pride","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
