n\" identity markers; local expressions; national pride"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Maya civilization heritage","importance":"Low","expression":"Source of great pride; Tikal, Quiriguá UNESCO sites; living Maya culture; celebrate respectfully","marketing_angle":""},{"value":"Textiles and trajes típicos","importance":"Low","expression":"Beautiful Maya weaving traditions; UNESCO consideration; cultural identifier","marketing_angle":""},{"value":"Rigoberta Menchú","importance":"Low","expression":"Nobel Peace Prize winner; internationally known; symbol of indigenous rights","marketing_angle":""},{"value":"Semana Santa (Holy Week)","importance":"Medium","expression":"UNESCO heritage; Antigua processions famous; deeply religious; commercialize carefully","marketing_angle":""}]',
