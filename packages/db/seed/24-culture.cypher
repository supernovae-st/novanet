MERGE (c:Culture {key: 'ko-KR'})
SET c.display_name = 'ko-KR Culture Norms',
    c.description = 'Cultural context and norms for ko-KR',
    c.llm_context = 'USE: ko-KR culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"18:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"Jeong (정 / 情)","importance":"High","expression":"Deep emotional bond; loyalty beyond transactions; long-term relationships; attachment that builds over time; going extra mile for connected people","marketing_angle":"Emphasize relationship-building; loyalty rewards; express genuine care; acknowledge long-term customers; show 마음 (heart/sincerity)"},{"value":"Nunchi (눈치)","importance":"High","expression":"Social awareness; reading the room; intuiting others\' moods and needs; unspoken communication; situational appropriateness","marketing_angle":"Anticipate needs; don\'t over-explain; subtle communication; appropriate messaging per context; respect unspoken cues"},{"value":"Respect/Hierarchy (존경/위계)","importance":"High","expression":"Confucian hierarchy deeply embedded; respect for age, position, expertise; honorific language (존댓말); deference to seniority","marketing_angle":"Use appropriate honorifics always; acknowledge customer status; never presume equality; respect seniority markers"},{"value":"Education/Achievement (교육/성취)","importance":"High","expression":"Education as social mobility; academic credentials valued; continuous improvement; knowledge acquisition","marketing_angle":"Highlight expertise; certifications matter; educational content valued; self-improvement messaging resonates"},{"value":"Diligence (근면)","importance":"High","expression":"Hard work ethic; perseverance (끈기); determination to succeed; overtime culture; sacrifice for goals","marketing_angle":"Acknowledge effort; support customer journey; recognize hard work; persistence-themed messaging"},{"value":"Harmony (화합)","importance":"Medium","expression":"Group cohesion; avoiding conflict; maintaining social harmony; consensus-building","marketing_angle":"Community-oriented messaging; avoid confrontational tone; group benefits over individual gain"},{"value":"Face (체면)","importance":"High","expression":"Social reputation; public image; avoiding embarrassment; maintaining dignity; pride in appearance and status","marketing_angle":"Never embarrass customers; private issue resolution; face-saving options; acknowledge status"},{"value":"Pali-pali Culture (빨리빨리)","importance":"Medium","expression":"Speed and efficiency; urgency; impatience with slow processes; quick results expected","marketing_angle":"Fast service; quick delivery; efficient processes; immediate responses; don\'t waste time"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Korean Wave (한류/Hallyu)","importance":"Low","expression":"BTS, Squid Game, K-beauty; legitimate source of pride; global soft power; safe to reference","marketing_angle":""},{"value":"Traditional Culture","importance":"Low","expression":"Hanbok, hansik, hanji; UNESCO heritage items; Sejong the Great and Hangul invention pride","marketing_angle":""},{"value":"Sports Achievements","importance":"Low","expression":"2002 World Cup; Olympic successes; Kim Yuna; e-sports dominance; unifying pride source","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ko-KR: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Jeong (정 / 情), Nunchi (눈치), Respect/Hierarchy (존경/위계).',
    c.taboos_summary = 'CRITICAL TABOOS: Japanese Colonial Period (1910-1945), North Korea Politics, Territorial Disputes (Dokdo/독도). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ko-KR.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'ln-CD'})
SET c.display_name = 'ln-CD Culture Norms',
    c.description = 'Cultural context and norms for ln-CD',
    c.llm_context = 'USE: ln-CD culture (northern hemisphere, balanced communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
