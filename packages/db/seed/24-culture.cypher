    c.values = '[{"value":"Respect for Elders","importance":"High","expression":"Deep deference to age; titles and honorifics essential; \"Sir/Ma\" ubiquitous; greeting culture paramount; kneeling/prostrating for elders; seeking blessings from seniors","marketing_angle":"Respect-based communication; title usage mandatory; dignified service; never casual with unknown customers"},{"value":"Faith/Religion","importance":"High","expression":"Christianity and Islam deeply embedded; regular worship; religious phrases in daily speech; \"God willing\" universally understood; business success attributed to divine blessing","marketing_angle":"Faith-positive messaging; religious calendar awareness; \"God bless\" expressions appropriate; respect both Christian and Muslim contexts"},{"value":"Family/Community","importance":"High","expression":"Extended family obligations; communal responsibility; \"no man is an island\" mentality; family name protection; supporting relatives expected","marketing_angle":"Family-centered messaging; multi-generational appeal; collective benefits; community belonging themes"},{"value":"Hard Work/Hustle","importance":"High","expression":"\"Hustle\" culture celebrated; entrepreneurship valued; multiple income streams common; resilience admired; \"Naija no dey carry last\" (Nigerians never come last) mentality","marketing_angle":"Achievement messaging; entrepreneurship themes; resilience narratives; self-improvement angles"},{"value":"Hospitality","importance":"High","expression":"Guests treated generously; \"You are welcome\" is literal invitation; food offered to visitors; generosity as virtue; hosting is source of pride","marketing_angle":"Welcoming language; generous offers; abundance themes; hospitable service positioning"},{"value":"Education/Achievement","importance":"Medium","expression":"Degrees celebrated; professional titles (Dr, Engr, Barr) displayed proudly; academic success family pride; \"first to graduate\" narratives powerful","marketin