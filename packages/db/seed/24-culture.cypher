    c.values = '[{"value":"Ubumwe (Unite)","importance":"High","expression":"Devise nationale insistant sur la cohesion ; rejet des divisions ethniques ; identite collective rwandaise avant tout","marketing_angle":"Positionner la marque comme force unificatrice ; mettre en avant les benefices communautaires ; eviter toute segmentation qui pourrait suggerer une division"},{"value":"Agaciro (Dignite/Valeur personnelle)","importance":"High","expression":"Philosophie d\'auto-suffisance ; Fonds de Developpement Agaciro ; fierte de l\'identite rwandaise ; refus du statut de victime","marketing_angle":"Responsabiliser les clients avec dignite ; eviter tout langage condescendant ; positionner les produits comme outils d\'epanouissement personnel"},{"value":"Icyubahiro (Respect)","importance":"High","expression":"Deference envers les aines, les titres, la hierarchie ; salutations polies obligatoires ; adresse formelle en public","marketing_angle":"Utiliser un registre formel ; toujours inclure les titres de civilite connus ; montrer du respect pour le temps et l\'intelligence du client"},{"value":"Ubunyangamugayo (Integrite)","importance":"High","expression":"Tolerance zero pour la corruption ; culture de responsabilite ; transparence attendue ; tenir ses promesses","marketing_angle":"Mettre en avant la fiabilite ; honorer les engagements ; tarification et politiques transparentes ; pas de clauses cachees"},{"value":"Kwiyubaka (Auto-suffisance)","importance":"Medium","expression":"Esprit de reconstruction post-genocide ; initiatives Made in Rwanda ; reduction de la dependance etrangere","marketing_angle":"Souligner les partenariats locaux ; mettre en valeur les reussites rwandaises ; positionner des solutions qui favorisent l\'autonomie"},{"value":"Ubufatanye (Solidarite)","importance":"Medium","expression":"Traditions d\'entraide ; service communautaire Umuganda ; aide aux voisins ; responsabilite collective","marketing_angle":"Messagerie axee sur la communaute ; la RSE resonne fortement ; montrer comment la marque contribue au bien-etre collectif"},{"value":"Iterambere (Progres/Developpement)","importance":"Medium","expression":"Aspirations Vision 2050 ; adoption de la modernisation ; adoption des technologies ; mentalite d\'amelioration continue","marketing_angle":"Le message d\'innovation fonctionne bien ; lier aux objectifs de developpement national ; positionnement oriente vers le progres"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Reconciliation post-genocide","importance":"High","expression":"Fierte dans la reconstruction et l\'unite, mais approcher avec extreme respect ; ne jamais banaliser le parcours ; reconnaitre sans s\'attarder ; se concentrer sur la resilience et l\'avenir","marketing_angle":""},{"value":"Conservation des gorilles","importance":"Low","expression":"Efforts de conservation reussis ; fierte de l\'ecotourisme ; montagnes des Virunga ; reference positive sure","marketing_angle":""},{"value":"Femmes au pouvoir","importance":"Medium","expression":"Plus haut pourcentage de femmes parlementaires au monde ; realisation dont on est fier ; utiliser respectueusement sans tokenisme","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'fr-RW: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Ubumwe (Unite), Agaciro (Dignite/Valeur personnelle), Icyubahiro (Respect).',
    c.taboos_summary = 'CRITICAL TABOOS: References ethniques (Hutu/Tutsi/Twa), Negation/minimisation du genocide de 1994, Divisionnisme (ubwoko). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-RW.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

