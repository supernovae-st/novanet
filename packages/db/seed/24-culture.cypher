    c.business_hours = '{"end":"13:00","lunch_break":false,"start":"08:00"}',
    c.values = '[{"value":"التسامح (Tolerance)","importance":"High","expression":"Omani tradition of religious tolerance (Ibadi Islam); peaceful coexistence; welcoming of diverse communities; Sultan Qaboos\'s legacy of interfaith dialogue","marketing_angle":"Inclusive messaging; multicultural respect; \"التعايش السلمي\" (peaceful coexistence); tolerance themes resonate deeply"},{"value":"الوقار (Dignity/Decorum)","importance":"High","expression":"Measured, restrained behavior valued; avoiding ostentation; quiet confidence; understated elegance over flashy displays","marketing_angle":"Refined, dignified positioning; avoid aggressive or flashy marketing; understated luxury; \"الأناقة الراقية\" (refined elegance)"},{"value":"الكرم العماني (Omani Hospitality)","importance":"High","expression":"Traditional Arabian hospitality with Omani restraint; coffee and dates rituals (قهوة عمانية); gracious hosting without excess","marketing_angle":"Warm but measured hospitality language; \"نتشرف بخدمتكم\" (honored to serve you); genuine warmth without effusiveness"},{"value":"الولاء للوطن (National Loyalty)","importance":"High","expression":"Deep devotion to Oman and Sultan; patriotism expressed through service and respect; celebration of National Day (November 18)","marketing_angle":"National pride themes welcome; Omani heritage celebration; Vision 2040 alignment; \"عُمان أولاً\" themes"},{"value":"احترام التراث (Heritage Respect)","importance":"High","expression":"Preservation of traditional culture; frankincense heritage; maritime history; forts and ancient sites; traditional crafts","marketing_angle":"Heritage-modern balance; authenticity valued; \"التراث العماني الأصيل\" (authentic Omani heritage); craftsmanship themes"},{"value":"الصبر والتأني (Patience/Deliberation)","importance":"Medium","expression":"Thoughtful decision-making; avoiding haste; long-term thinking; measured progress valued over rapid change","marketing_angle":"Don\'t rush customers; patient relationship building; quality over speed messaging; thoughtful positioning"},{"value":"الأمانة (Trustworthiness)","importance":"High","expression":"Keeping promises; reliability in business; maintaining reputation; honoring commitments","marketing_angle":"Trust-building essential; reliability messaging; \"الشريك الموثوق\" (trusted partner); commitment themes"},{"value":"التواضع (Modesty/Humility)","importance":"Medium","expression":"Avoiding boastfulness; quiet achievement; modesty in dress and behavior; success celebrated without arrogance","marketing_angle":"Understated excellence; avoid superlatives excess; quality speaks for itself; humble confidence positioning"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sultan Qaboos bin Said","importance":"Medium","expression":"Deeply beloved; \"Father of Modern Oman\"; can reference legacy and values respectfully; never commercial use of image; mourning period was significant (2020)","marketing_angle":""},{"value":"Omani National Day (November 18)","importance":"Low","expression":"Major celebration; patriotic themes welcome; excellent campaign timing; \"يوم النهضة المباركة\" (Blessed Renaissance Day)","marketing_angle":""},{"value":"Omani Renaissance achievements","importance":"Low","expression":"Modern infrastructure, education, healthcare transformation; can reference freely and positively","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ar-OM: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: التسامح (Tolerance), الوقار (Dignity/Decorum), الكرم العماني (Omani Hospitality).',
    c.taboos_summary = 'CRITICAL TABOOS: Criticism of Sultan or Royal Family, Insulting Islam or Ibadi practices, Criticism of government policies. Always avoid these topics.',
