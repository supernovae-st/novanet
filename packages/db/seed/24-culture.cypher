MERGE (c:Culture {key: 'es-CR'})
SET c.display_name = 'es-CR Culture Norms',
    c.description = 'Cultural context and norms for es-CR',
    c.llm_context = 'USE: es-CR culture (northern hemisphere, indirect communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Pura Vida (Pure Life)","importance":"High","expression":"Philosophy of well-being, gratitude, optimism, and enjoying life\'s simple pleasures; used as greeting, farewell, expression of agreement","marketing_angle":"Embrace authentic positivity; avoid high-pressure tactics; emphasize life quality over acquisition; \"living well\" themes resonate deeply"},{"value":"Paz (Peace)","importance":"High","expression":"No military since 1948; conflict avoidance; diplomatic solutions; national identity built on peace","marketing_angle":"Never aggressive or confrontational messaging; emphasize harmony; peaceful imagery; avoid militaristic metaphors"},{"value":"Familia (Family)","importance":"High","expression":"Extended family central; Sunday family gatherings sacred; intergenerational support; decisions often collective","marketing_angle":"Family-centered campaigns; multi-generational appeal; products that bring family together; \"para toda la familia\""},{"value":"Naturaleza (Nature/Environment)","importance":"High","expression":"25% national parks; biodiversity pride; environmental awareness; eco-consciousness mainstream","marketing_angle":"Sustainability expected, not optional; green messaging resonates; nature imagery powerful; eco-credentials valued"},{"value":"Educacion (Education)","importance":"High","expression":"Free public education since 1869; high literacy rate; teachers respected; \"la educacion es la mejor herencia\"","marketing_angle":"Knowledge-based messaging; educational value emphasized; never condescending; intellectual appeals work"},{"value":"Humildad (Humility)","importance":"Medium","expression":"Avoid ostentation; quiet success preferred; don\'t flaunt wealth; \"no sea creido/a\" (don\'t be arrogant)","marketing_angle":"Subtle luxury; avoid flashiness; understated quality; never boastful; authentic success stories"},{"value":"Solidaridad (Solidarity)","importance":"Medium","expression":"Mutual help expected; community support; helping neighbors; \"echarse una mano\"","marketing_angle":"Cooperative messaging; community benefits; helping others; social responsibility resonates"},{"value":"Democracia (Democracy)","importance":"Medium","expression":"Oldest continuous democracy in Latin America; proud civic tradition; high voter participation","marketing_angle":"Transparency valued; fair practices; participatory messaging; inclusive approaches"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Abolition of military (1948)","importance":"Low","expression":"Major source of pride; redirected funds to education and health; use freely and positively","marketing_angle":""},{"value":"Coffee quality","importance":"Low","expression":"Grano de Oro (golden grain); Tarrazu world-renowned; strong heritage associations","marketing_angle":""},{"value":"Abolition of death penalty (1877)","importance":"Low","expression":"Early progressive stance; human rights pride; can reference in values-aligned contexts","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'es-CR: Communication style is indirect. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Pura Vida (Pure Life), Paz (Peace), Familia (Family).',
    c.taboos_summary = 'CRITICAL TABOOS: Nicaragua tensions, Calling Costa Ricans "Nicaraguans" or implying Central American sameness. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'es-CR.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

