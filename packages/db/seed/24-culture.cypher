MERGE (c:Culture {key: 'ceb-PH'})
SET c.display_name = 'ceb-PH Culture Norms',
    c.description = 'Cultural context and norms for ceb-PH',
    c.llm_context = 'USE: ceb-PH culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Pamilya (Family)","importance":"High","expression":"Multi-generational households; family decisions; sacrificing for children\'s future; OFW remittances","marketing_angle":"Frame products as family investments; \"Para sa pamilya\" messaging; multi-generational benefits"},{"value":"Pagtuo (Faith/Religion)","importance":"High","expression":"Santo Nino devotion; regular mass attendance; religious festivals; prayers before meals","marketing_angle":"Respect Catholic imagery; reference blessings; avoid irreverent religious content"},{"value":"Pagtahod (Respect for Elders)","importance":"High","expression":"Using respect terms (Manong/Manang, Tay/Nay); seeking blessing (mano); deferring to elders","marketing_angle":"Show respect in imagery; elder approval validates choices; intergenerational messaging"},{"value":"Pakikisama (Smooth Relations)","importance":"High","expression":"Avoiding conflict; maintaining harmony; going along with group; not causing ulaw (shame)","marketing_angle":"Community-focused messaging; testimonials; group validation; avoid confrontational CTAs"},{"value":"Pagkamaabiabihon (Hospitality)","importance":"High","expression":"Welcoming guests; offering food/drinks; making visitors feel at home; generosity","marketing_angle":"Warm service tone; generous offers; \"guest treatment\" positioning"},{"value":"Bayanihan (Community Spirit)","importance":"Medium","expression":"Helping neighbors; community mutual aid; local cooperation; shared burdens","marketing_angle":"Community initiatives; local pride; collective action messaging"},{"value":"Kasadya (Joy/Celebration)","importance":"Medium","expression":"Fiestas; family gatherings; finding joy despite hardship; resilience through humor","marketing_angle":"Celebratory messaging; positive energy; humor welcome"},{"value":"Kauswagan (Progress/Advancement)","importance":"Medium","expression":"Education as priority; career advancement; improving family status; entrepreneurship","marketing_angle":"Aspiration messaging; investment in future; education/career tie-ins"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Sinulog Festival / Santo Nino","importance":"High","expression":"Deep religious significance; never use commercially or irreverently; Pit Senyor is sacred expression","marketing_angle":""},{"value":"Visayan identity and language","importance":"Medium","expression":"Celebrate Bisaya identity; avoid implying inferiority to Tagalog; language pride is strong","marketing_angle":""},{"value":"Philippine independence history","importance":"Medium","expression":"Lapu-Lapu as first resistance hero is Cebuano pride; handle colonial history respectfully","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ceb-PH: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Pamilya (Family), Pagtuo (Faith/Religion), Pagtahod (Respect for Elders).',
    c.taboos_summary = 'CRITICAL TABOOS: Disrespecting religious symbols (Santo Nino, cross, saints), Mocking or disrespecting elders, Causing public hiya (shame/embarrassment). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ceb-PH.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'mn-MN'})
