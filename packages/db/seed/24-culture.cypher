    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"కుటుంబం (Family)","importance":"High","expression":"Joint family traditions strong; multi-generational living common; collective decision-making; family honor (కుటుంబ గౌరవం) paramount","marketing_angle":"Family-centric messaging; multi-generational benefits; \"కుటుంబంతో కలిసి\" themes; products serving entire household"},{"value":"గౌరవం (Respect)","importance":"High","expression":"Deep respect for elders (పెద్దల పట్ల గౌరవం); teacher reverence (గురువుల గౌరవం); hierarchical deference; hospitality as duty","marketing_angle":"Respectful communication always; elder-inclusive imagery; honor relationships; humble service attitude"},{"value":"తెలుగు అభిమానం (Telugu Pride)","importance":"High","expression":"Strong Telugu language identity; \"తెలుగు తల్లి\" devotion; Telugu literary heritage pride; regional identity (Andhra/Telangana)","marketing_angle":"Telugu-first communication; respect regional identity; celebrate Telugu achievements"},{"value":"సంస్కృతి (Culture/Heritage)","importance":"High","expression":"Rich literary tradition; classical music (Carnatic) and dance (Kuchipudi); temple traditions; Kakatiya, Satavahana heritage pride","marketing_angle":"Cultural authenticity; heritage preservation themes; tradition-respecting messaging"},{"value":"అతిథి మర్యాద (Hospitality)","importance":"Medium","expression":"\"అతిథి దేవో భవ\" (Guest is God) principle; generous hosting; offering tea/coffee/water mandatory; customer as honored guest","marketing_angle":"Warm welcome experiences; generous offerings; hospitality in service; \"మీ సేవలో\" attitude"},{"value":"చదువు (Education)","importance":"Medium","expression":"Education highly valued; engineering, medicine aspirations strong; Hyderabad as educational hub; \"చదువే నిధి\" belief","marketing_angle":"Education benefits; career advancement; knowledge positioning; family pride through achievement"},{"value":"ధర్మం (Religion/Duty)","importance":"Medium","expression":"Hindu traditions important; temple culture strong; Tirupati significance; festival observances deeply rooted","marketing_angle":"Festival-aligned campaigns; spiritual well-being themes; dharmic responsibility messaging"},{"value":"ఇజ్జత్ (Honor/Reputation)","importance":"Medium","expression":"Family reputation crucial; social standing matters; avoiding shame important; maintaining dignity in all interactions","marketing_angle":"Prestige positioning; status-conscious messaging; dignified communications"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Tirupati Balaji temple","importance":"Low","expression":"Most visited pilgrimage site; TTD administration; safe for spiritual themes","marketing_angle":""},{"value":"Telugu literary tradition","importance":"Medium","expression":"Second-largest spoken Indian language; classical literature; Nannaya, Tikkana; use respectfully","marketing_angle":""},{"value":"Satavahana dynasty","importance":"Low","expression":"Amaravati heritage; ancient glory; safe for historical references","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'te-IN: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: కుటుంబం (Family), గౌరవం (Respect), తెలుగు అభిమానం (Telugu Pride).',
