MERGE (c:Culture {key: 'yo-NG'})
SET c.display_name = 'yo-NG Culture Norms',
    c.description = 'Cultural context and norms for yo-NG',
    c.llm_context = 'USE: yo-NG culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Owo (Respect)","importance":"High","expression":"Deep respect for elders, traditional rulers (Oba, Ooni, Alaafin), and titled persons; prostration (dobale) and kneeling (kunle) for elders; honorifics mandatory; greeting culture elaborate","marketing_angle":"Respect-based communication always; honorifics essential; dignified positioning; never assume casualness; \"E\" pronoun mandatory"},{"value":"Ebi (Family/Lineage)","importance":"High","expression":"Extended family bonds paramount; lineage (idile) identity strong; family name (oruko idile) protected; supporting relatives expected; family elders consulted for major decisions","marketing_angle":"Family-centered messaging; multi-generational appeal; legacy themes; collective family benefits; \"ebi wa\" (our family) resonance"},{"value":"Esin (Faith/Religion)","importance":"High","expression":"Religious pluralism - Christianity, Islam, and traditional Orisa worship all significant; Sunday church and Friday mosque; religious expressions ubiquitous in speech; festivals sacred","marketing_angle":"Multi-faith sensitivity essential; religious calendar awareness (Christmas, Easter, Eid, Osun Festival); spiritual expressions welcomed; no religious favoritism"},{"value":"Omoluabi (Character/Integrity)","importance":"High","expression":"Ideal Yoruba person: honest, humble, respectful, patient, hardworking, generous; character over wealth; \"Iwa l\'ewa\" (character is beauty); reputation carefully guarded","marketing_angle":"Character-positive messaging; integrity-based positioning; trustworthiness claims; \"eniyan rere\" (good person) alignment"},{"value":"Ise (Hard Work)","importance":"Medium","expression":"Work ethic valued; \"Ise l\'ogun ise\" (work is the antidote to poverty); entrepreneurship respected; artisan traditions (adire, aso-oke, woodcarving) celebrated","marketing_angle":"Achievement messaging; entrepreneurship themes; skill recognition; self-improvement positioning"},{"value":"Ola (Honor/Dignity)","importance":"Medium","expression":"Personal and family honor paramount; chieftaincy titles (Chief, Otun, Osi) respected; academic titles valued (Dr, Prof, Engr); success brings honor to family","marketing_angle":"Prestige positioning; achievement recognition; dignified brand associations; premium appeal"},{"value":"Aajo (Community/Togetherness)","importance":"Medium","expression":"Community solidarity strong; town unions (Egbe Omo Ilu); age-grade associations (Egbe); mutual aid societies (Esusu); collective celebration","marketing_angle":"Community themes; \"ara ilu\" (townspeople) connection; collective success messaging; solidarity positioning"},{"value":"Oro (Wisdom/Tradition)","importance":"Medium","expression":"Proverbs (owe) carry authority; oral tradition rich; Ifa divination respected; elders as wisdom keepers; traditional knowledge valued","marketing_angle":"Wisdom-based messaging; proverb integration (carefully); traditional values respect; elder consultation themes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Ile-Ife as Yoruba cradle","importance":"Low","expression":"Origin of Yoruba civilization; safe cultural reference; heritage pride","marketing_angle":""},{"value":"Wole Soyinka","importance":"Low","expression":"Nobel laureate; literary giant; global Yoruba ambassador; safe intellectual reference","marketing_angle":""},{"value":"Yoruba diaspora (Cuba, Brazil, USA)","importance":"Low","expression":"Pride in global cultural influence; Santeria, Candomble connections; safe cultural reference","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'yo-NG: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Owo (Respect), Ebi (Family/Lineage), Esin (Faith/Religion).',
    c.taboos_summary = 'CRITICAL TABOOS: Religious mockery, Ethnic conflicts, Traditional rulers disrespect. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'yo-NG.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

