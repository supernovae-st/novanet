    c.culture_summary = 'qu-PE: Communication style is indirect. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Ayni (Reciprocity), Ayllu (Community), Pachamama (Earth Mother).',
