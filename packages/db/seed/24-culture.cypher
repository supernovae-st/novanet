    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"09:00"}',
    c.values = '[{"value":"ဗုဒ္ဓဘာသာ (Bu-da-ba-tha - Buddhism)","importance":"High","expression":"Theravada Buddhism central to identity; merit-making (ကုသိုလ်); monastic respect (သံဃာတော်); pagoda devotion","marketing_angle":"Align with Buddhist values of compassion, generosity; acknowledge religious calendar; never trivialize Buddhist elements"},{"value":"ရိုသေလေးစားမှု (Yo-thay-lay-sa-hmou - Respect)","importance":"High","expression":"Deep respect for elders, teachers, monks; elaborate pronoun system; physical deference (bowing, lowering oneself)","marketing_angle":"Always use respectful forms; acknowledge seniority; honorific titles essential; protect customer dignity"},{"value":"မျက်နှာသိမ်း (Myet-hna-thein - Face Saving)","importance":"High","expression":"Preserving dignity; avoiding public embarrassment; protecting social reputation; hka-na (shame) avoidance","marketing_angle":"Never embarrass publicly; discrete corrections; protect customer face in all interactions"},{"value":"မိသားစု (Mi-tha-zu - Family)","importance":"High","expression":"Extended family central; multi-generational living; collective decision-making; filial piety","marketing_angle":"Family-centered messaging; products benefiting whole family; respect for elders themes"},{"value":"မေတ္တာ (Metta - Loving-kindness)","importance":"High","expression":"Buddhist loving-kindness; genuine care for all beings; generosity of spirit; compassionate action","marketing_angle":"Warm, caring tone; genuine helpfulness; generous themes resonate; blessing language"},{"value":"ကရုဏာ (Karuna - Compassion)","importance":"Medium","expression":"Active compassion; helping those in suffering; Buddhist virtue in practice","marketing_angle":"Support and help messaging; understanding of difficulties; empathetic service"},{"value":"ဒါန (Dana - Generosity)","importance":"Medium","expression":"Meritorious giving; supporting monasteries; helping community; generosity as spiritual practice","marketing_angle":"Giving campaigns; community benefit themes; merit-making associations"},{"value":"အခမ်းအနား (A-kham-a-na - Harmony)","importance":"Medium","expression":"Social harmony valued; conflict avoidance; smooth relationships; consensus preference","marketing_angle":"Non-confrontational messaging; peaceful resolution; avoid aggressive tactics"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Shwedagon Pagoda","importance":"Low","expression":"Supreme religious symbol; source of deep pride; use respectfully; never commercialize inappropriately","marketing_angle":""},{"value":"Thanaka tradition","importance":"Low","expression":"Traditional cosmetic; identity marker; positive cultural association","marketing_angle":""},{"value":"Jade and gems","importance":"Low","expression":"\"Jade Land\" reputation; precious resources; quality associations","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'my-MM: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: ဗုဒ္ဓဘာသာ (Bu-da-ba-tha - Buddhism), ရိုသေလေးစားမှု (Yo-thay-lay-sa-hmou - Respect), မျက်နှာသိမ်း (Myet-hna-thein - Face Saving).',
