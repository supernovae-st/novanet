    c.values = '[{"value":"Коомчулук (Community/Collectivism)","importance":"High","expression":"Extended family networks, аил (village) ties, mutual support systems, collective decision-making","marketing_angle":"Frame products as benefiting family/community; emphasize shared experiences"},{"value":"Урмат (Respect)","importance":"High","expression":"Deference to elders (аксакалдар), formal address with strangers, hierarchical social interactions","marketing_angle":"Show respect in tone; acknowledge customer status; never appear condescending"},{"value":"Конокчулук (Hospitality)","importance":"High","expression":"Elaborate guest traditions, dastorkon (spread), offering food/tea as sacred duty, treating strangers as honored guests","marketing_angle":"Customer-as-honored-guest framing; warmth in service; generosity themes"},{"value":"Ар-намыс (Honor)","importance":"High","expression":"Family reputation, personal dignity, fulfilling commitments, word as bond","marketing_angle":"Emphasize trustworthiness; reliability; keeping promises; quality assurance"},{"value":"Салт-санаа (Tradition)","importance":"Medium","expression":"Nomadic heritage, Epic of Manas, traditional crafts (felt, textiles), seasonal celebrations","marketing_angle":"Connect modern products to traditional values; respect heritage"},{"value":"Көз карандысыздык (Independence)","importance":"Medium","expression":"National sovereignty pride, self-reliance, overcoming challenges","marketing_angle":"Frame products as empowering; independence through quality/choice"},{"value":"Ынтымак (Harmony)","importance":"Medium","expression":"Social cohesion, conflict avoidance, maintaining relationships","marketing_angle":"Emphasize peaceful solutions; collaboration; win-win outcomes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Epic of Manas","importance":"Low","expression":"World\'s longest epic poem; safe to reference; symbol of Kyrgyz identity and wisdom","marketing_angle":""},{"value":"Nomadic Heritage","importance":"Low","expression":"Yurts (боз үй), horses, mountain culture; authentic cultural identity marker","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ky-KG: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Коомчулук (Community/Collectivism), Урмат (Respect), Конокчулук (Hospitality).',
