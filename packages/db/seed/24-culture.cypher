    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Familia (Family)","importance":"High","expression":"Extended family networks central to daily life; multi-generational households common; collective decision-making; strong bonds despite geographic separation (diaspora); family gatherings on weekends and holidays","marketing_angle":"Family-centered messaging; \"para toda la familia\"; acknowledge diaspora connections; multigenerational harmony; family testimonials resonate"},{"value":"Fe (Faith)","importance":"High","expression":"Strong Catholic tradition with growing evangelical presence; religious holidays deeply observed; churches central to community; religious phrases embedded in daily speech; Semana Santa significant","marketing_angle":"Respect religious sensibilities; \"Si Dios quiere\" natural; align with family values; avoid irreverence; El Salvador del Mundo patronage"},{"value":"Identidad Guanaca (Salvadoran Identity)","importance":"High","expression":"Strong national pride; \"guanaco/a\" term of pride; distinct from other Central Americans; resilience narrative; \"El Pulgarcito de America\" (smallest Central American country); pupusa as national symbol","marketing_angle":"Embrace local identity; \"orgullosamente salvadoreno\" resonates; guanaco references appreciated; local authenticity valued"},{"value":"Trabajo Duro (Hard Work)","importance":"High","expression":"Work ethic highly valued; resilience amid challenges; \"hecharle ganas\" (giving your all); entrepreneurial spirit; self-improvement through effort; remittances represent sacrifice","marketing_angle":"Acknowledge effort and resilience; opportunity messaging; practical value propositions; aspirational but achievable"},{"value":"Respeto (Respect)","importance":"High","expression":"Respect for elders, authority, and hierarchy; proper treatment expected; \"usted\" conveys respect; titles matter; humility valued alongside achievement","marketing_angle":"Formal register with elders; acknowledge expertise; respectful tone mandatory; never condescending"},{"value":"Hospitalidad (Hospitality)","importance":"Medium","expression":"Warm welcome to guests; generosity despite limitations; food sharing as welcome; \"mi casa es su casa\" mentality; warmth in relationships","marketing_angle":"Warmth expected in service; welcoming language; helpful attitude; never cold or dismissive"},{"value":"Solidaridad (Solidarity)","importance":"Medium","expression":"Community support networks; neighbor helping neighbor; collective response to challenges; earthquake/disaster response traditions; \"juntos salimos adelante\"","marketing_angle":"Community-minded messaging; social responsibility; collective progress themes; mutual support"},{"value":"Conexion con Diaspora","importance":"Medium","expression":"Strong ties to Salvadorans abroad (especially US); remittances crucial to economy; transnational families; dual cultural identity","marketing_angle":"Acknowledge diaspora connections; remittance services important; family unity despite distance; nostalgia themes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Pupusas (national dish)","importance":"Low","expression":"Ultimate cultural symbol; unifying food; National Pupusa Day celebrations; safe to reference positively always","marketing_angle":""},{"value":"Coffee quality","importance":"Low","expression":"Internationally recognized; artisan production; export pride; quality associations positive","marketing_angle":""},{"value":"Joya de Ceren (UNESCO)","importance":"Low","expression":"Archaeological site; \"Pompeii of the Americas\"; cultural heritage pride; educational value","marketing_angle":""},{"value":"El Salvador del Mundo (patron)","importance":"Low","expression":"National patron; August 1-6 festival; cathedral icon; religious-cultural pride","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'es-SV: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Familia (Family), Fe (Faith), Identidad Guanaca (Salvadoran Identity).',
    c.taboos_summary = 'CRITICAL TABOOS: Civil War (1979-1992), El Mozote massacre, Gang violence (maras). Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'es-SV.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

