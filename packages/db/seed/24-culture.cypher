    c.values = '[{"value":"Rezistans (Resilience)","importance":"High","expression":"Overcoming adversity; strength through struggle; \"n ap kenbe\" (we are holding on); surviving against odds","marketing_angle":"Emphasize durability, reliability, strength; acknowledge challenges while projecting hope and confidence"},{"value":"Fanmi (Family/Community)","importance":"High","expression":"Extended family networks; collective support; \"lakou\" compound living tradition; shared responsibility","marketing_angle":"Family-centered messaging; multi-generational imagery; \"pou fanmi nou\" (for our families) appeals"},{"value":"Fye (Pride/Dignity)","importance":"High","expression":"National pride in revolution; personal dignity; self-respect; refusing victimhood","marketing_angle":"Respect-based messaging; never condescend; celebrate achievements and potential"},{"value":"Solidarite (Solidarity)","importance":"High","expression":"\"Konbit\" mutual aid; collective work; neighbors helping neighbors; community over individualism","marketing_angle":"Community connection; shared benefit messaging; \"nou ansanm\" (we are together) language"},{"value":"Endepadans (Independence)","importance":"High","expression":"First free Black republic; self-determination; rejecting external control; sovereignty","marketing_angle":"Appeals to self-reliance; empowerment messaging; \"pa gen moun ki pou di nou\" (no one can tell us)"},{"value":"Lafwa (Faith)","importance":"Medium","expression":"Deep religious practice; Christianity and Vodou; spiritual grounding; trust in higher power","marketing_angle":"Respectful acknowledgment of faith; hope and blessing language acceptable"},{"value":"Travay (Hard Work)","importance":"Medium","expression":"Earning through honest labor; enterprise; \"degaje\" resourcefulness; making a way","marketing_angle":"Acknowledge effort; hard-won success; practical solutions; respect for hustle"},{"value":"Respè (Respect)","importance":"Medium","expression":"Deference to elders; proper greetings; acknowledgment of status and age; courtesy","marketing_angle":"Respectful address; proper titles (Mesye, Madam); never dismissive or rude"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"1804 Revolution","importance":"Low","expression":"First successful slave revolution; first Black republic; immense pride; safe to celebrate; founding story","marketing_angle":""},{"value":"Creole Language","importance":"Low","expression":"Linguistic pride; \"lang manman\" (mother tongue); official language; celebrate Kreyol content","marketing_angle":""},{"value":"Carnival (Kanaval)","importance":"Low","expression":"Annual celebration; music, costumes, community; joyful cultural reference","marketing_angle":""},{"value":"Citadelle Laferriere","importance":"Low","expression":"UNESCO World Heritage; post-revolution fortress; symbol of independence and strength","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'ht-HT: Communication style is balanced. Hierarchy importance: medium. Orientation: Collectivist (focus on \'we/together\'). Core values: Rezistans (Resilience), Fanmi (Family/Community), Fye (Pride/Dignity).',
