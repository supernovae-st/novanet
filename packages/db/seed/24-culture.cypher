    c.llm_context = 'USE: ar-TN culture (northern hemisphere, direct communication, low hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'direct',
    c.hierarchy_importance = 'low',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"الحرية والكرامة (Freedom & Dignity)","importance":"High","expression":"Post-2011 Revolution consciousness; citizens value voice and rights; protest culture normalized","marketing_angle":"Frame brand as empowering; respect customer autonomy; never condescending; \"اختيارك\" (your choice) messaging"},{"value":"العائلة (Family)","importance":"High","expression":"Extended family bonds; multi-generational households; collective decision-making; filial piety","marketing_angle":"Family-centered content; show grandparents, parents, children together; products for shared moments; \"للعائلة الكل\""},{"value":"الانفتاح (Openness)","importance":"High","expression":"Mediterranean cosmopolitan identity; French-educated elite; tourism-welcoming culture; bilingualism","marketing_angle":"Modern, connected messaging; international quality claims resonate; \"عالمي\" (international) as quality marker"},{"value":"التعليم والثقافة (Education & Culture)","importance":"High","expression":"High literacy rate (79%); education seen as social mobility; intellectual heritage pride (Ibn Khaldun)","marketing_angle":"Position products as smart choices; knowledge-based marketing; educational content valued"},{"value":"المساواة (Equality)","importance":"Medium","expression":"Progressive personal status code since 1956; women\'s rights leadership in Arab world; secular constitution","marketing_angle":"Gender-balanced imagery; professional women normalized; avoid Gulf-style gender segregation assumptions"},{"value":"الضيافة التونسية (Tunisian Hospitality)","importance":"Medium","expression":"Welcoming tourists and guests; sharing food; mint tea rituals; beach and medina tourism culture","marketing_angle":"Generous service tone; hospitality imagery; \"مرحبا بيك/بيكم\" warmth"},{"value":"الصبر والتفاؤل (Patience & Optimism)","importance":"Medium","expression":"Post-Revolution resilience; economic challenges navigated with hope; \"غدوة خير\" (tomorrow better)","marketing_angle":"Acknowledge challenges realistically; frame solutions; avoid toxic positivity; credibility over hype"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"2011 Revolution (Jasmine Revolution)","importance":"High","expression":"Origin of Arab Spring; pride mixed with ongoing economic struggles; handle with nuance; avoid political positioning","marketing_angle":""},{"value":"Historic sites (Carthage, El Djem, Kairouan)","importance":"Low","expression":"UNESCO heritage; tourism pride; safe for all content; universally positive","marketing_angle":""},{"value":"Bourguiba legacy","importance":"Medium","expression":"Founding president; modernization architect; some political controversy; use carefully","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'ar-TN: Communication style is direct. Hierarchy importance: low. Orientation: Collectivist (focus on \'we/together\'). Core values: الحرية والكرامة (Freedom & Dignity), العائلة (Family), الانفتاح (Openness).',
    c.taboos_summary = 'CRITICAL TABOOS: Insulting Islam or Prophet, Criticizing the military, Taking sides on 2011 Revolution politics. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'ar-TN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

MERGE (c:Culture {key: 'en-VN'})
SET c.display_name = 'en-VN Culture Norms',
    c.description = 'Cultural context and norms for en-VN',
    c.llm_context = 'USE: en-VN culture (northern hemisphere, indirect communication, high hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'northern',
    c.work_week_start = 'monday',
    c.communication_directness = 'indirect',
    c.hierarchy_importance = 'high',
    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":true,"start":"08:00"}',
    c.values = '[{"value":"Gia dinh (Family)","importance":"High","expression":"Extended family bonds; multi-generational living; family honor and reputation; collective welfare","marketing_angle":"Family-centered messaging; products benefiting multiple generations; \"for the whole family\" narratives; show family gatherings"},{"value":"Hieu thao (Filial Piety)","importance":"High","expression":"Deep respect for parents and ancestors; caring for elders; maintaining family honor","marketing_angle":"Acknowledge elder authority; show intergenerational respect; inheritance and legacy themes; honor parents in imagery"},{"value":"The dien (Face/Dignity)","importance":"High","expression":"Preserving social reputation; avoiding public embarrassment; maintaining honor","marketing_angle":"Never embarrass customers; discrete problem resolution; protect dignity; praise publicly, correct privately"},{"value":"Tinh than tap the (Collectivism)","importance":"High","expression":"Group harmony over individual; community solidarity; shared success","marketing_angle":"Position products as community benefits; team success stories; \"we\" over \"I\" framing"},{"value":"Can cu (Diligence/Hard Work)","importance":"High","expression":"Work ethic central to identity; perseverance through adversity; continuous improvement","marketing_angle":"Emphasize quality through effort; reward hard work; \"nothing worthwhile comes easily\" themes"},{"value":"Hoc tap (Education/Learning)","importance":"High","expression":"Education as path to success; respect for teachers and knowledge; continuous self-improvement","marketing_angle":"Position products as educational investments; expertise and credentials valued; lifelong learning themes"},{"value":"Khiem ton (Modesty/Humility)","importance":"Medium","expression":"Self-deprecation; deflecting praise; avoiding boastfulness","marketing_angle":"Subtle success stories; humble brand voice; never arrogant; let quality speak for itself"},{"value":"Nhan nai (Patience/Perseverance)","importance":"Medium","expression":"Long-term thinking; endurance through hardship; gradual progress accepted","marketing_angle":"Long-term value messaging; patience with customers; journey over instant gratification"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Independence and unification (1945, 1975)","importance":"Medium","expression":"Positive but handle carefully; avoid war imagery; focus on peace and development","marketing_angle":""},{"value":"Ha Long Bay and UNESCO sites","importance":"Low","expression":"Major source of pride; natural beauty; excellent for positive brand associations","marketing_angle":""},{"value":"Vietnamese cuisine (pho, banh mi)","importance":"Low","expression":"Strong international recognition; safe and positive; food content resonates well","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'en-VN: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Gia dinh (Family), Hieu thao (Filial Piety), The dien (Face/Dignity).',
    c.taboos_summary = 'CRITICAL TABOOS: Criticism of Communist Party or government, Territorial disputes (South China Sea), Historical war commentary. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'en-VN.md',
    c.created_by = 'seed:locale',
    c.created_at = datetime(),
    c.updated_at = datetime();

