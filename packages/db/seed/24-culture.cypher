    c.individualism_level = 'collectivist',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"ایمان (Iman/Faith)","importance":"High","expression":"Islam permeates daily life, decisions, and social interactions; religious observance central to identity","marketing_angle":"Connect products/services to blessed living, halal choices, faith-aligned values"},{"value":"عزت (Izzat/Honor)","importance":"High","expression":"Family reputation paramount; personal actions reflect on entire family/clan; avoid shame at all costs","marketing_angle":"Emphasize dignity, respect, premium quality that reflects well on buyer"},{"value":"بیرادری (Biradari/Clan loyalty)","importance":"High","expression":"Extended family and clan networks fundamental; collective decision-making; mutual support obligations","marketing_angle":"Family-centric messaging, multi-generational appeal, group benefits"},{"value":"مہمان نوازی (Mehmaan Nawazi/Hospitality)","importance":"High","expression":"Guests treated with utmost generosity; hospitality is sacred duty; refusing hospitality is offensive","marketing_angle":"Generous offers, VIP treatment language, welcoming tone, abundance"},{"value":"وڈیریاں دا احترام (Elder respect)","importance":"Medium","expression":"Elders consulted on major decisions; age commands automatic respect; deference to seniority","marketing_angle":"Acknowledge wisdom, tradition, family approval, elder-endorsed messaging"},{"value":"صبر (Sabr/Patience)","importance":"Medium","expression":"Endurance in hardship valued; acceptance of divine will; long-term thinking","marketing_angle":"Reliability messaging, standing by customers, partnership language"},{"value":"حیا (Haya/Modesty)","importance":"Medium","expression":"Reserved behavior expected, especially for women; modesty in dress, speech, and conduct","marketing_angle":"Tasteful, dignified imagery; avoid flashy or immodest content"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"پاکستانی فوج (Pakistan Armed Forces)","importance":"Medium","expression":"Highly respected; use positively only; never criticize or satirize","marketing_angle":""},{"value":"ایٹمی طاقت (Nuclear capability)","importance":"High","expression":"Source of pride but sensitive topic; avoid casual references","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'pa-PK: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: ایمان (Iman/Faith), عزت (Izzat/Honor), بیرادری (Biradari/Clan loyalty).',
    c.taboos_summary = 'CRITICAL TABOOS: اسلام دی توہین (Blasphemy), بھارت نال ہمدردی (Pro-India sentiment), فرقہ واریت (Sectarian content). Always avoid these topics.',
    c.template_version = '3.1',
