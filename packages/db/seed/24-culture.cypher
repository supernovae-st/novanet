    c.values = '[{"value":"Humildad (Humility)","importance":"High","expression":"Understated self-presentation; \"no te la creas\"; discomfort with boasting; success downplayed; preference for modest achievers over flashy ones","marketing_angle":"Avoid exaggerated claims; authenticity over hype; humble confidence resonates; understated quality messaging"},{"value":"Tranquilidad (Calmness)","importance":"High","expression":"Relaxed pace of life; \"tranqui\" as lifestyle; stress avoidance valued; patience in interactions; quality of life prioritized over hustle","marketing_angle":"Calm, non-aggressive messaging; no high-pressure sales; wellbeing themes; \"despacio se llega lejos\" mentality"},{"value":"Solidaridad (Solidarity)","importance":"High","expression":"Strong community bonds; collective welfare valued; neighbor helping neighbor; cooperative traditions; social safety net pride","marketing_angle":"Community-oriented messaging; collective benefit themes; social responsibility resonates; \"todos juntos\""},{"value":"Igualdad (Equality)","importance":"High","expression":"Egalitarian ethos; class distinctions downplayed; \"somos todos iguales\"; aversion to hierarchy; accessible public services pride","marketing_angle":"Avoid elitist positioning; inclusive messaging; accessible for all themes; democratic values"},{"value":"Mate (Mate Culture)","importance":"High","expression":"National identity symbol; sharing ritual; carried everywhere; social bonding; hospitality indicator; individual thermos omnipresent","marketing_angle":"Mate references highly positive; sharing and community themes; warmth and hospitality; national pride"},{"value":"Familia (Family)","importance":"High","expression":"Central social unit; extended family bonds; Sunday gatherings; multi-generational connections; family advice valued","marketing_angle":"Family-centered messaging works; multi-generational themes; warmth and connection; shared moments"},{"value":"Educacion/Cultura (Education)","importance":"Medium","expression":"Literacy pride; public education tradition; secular education values; cultural participation; intellectual respect","marketing_angle":"Education and culture themes positive; quality and knowledge valued; public good messaging"},{"value":"Libertad (Freedom)","importance":"Medium","expression":"Personal freedom valued; progressive social stance; live-and-let-live; tolerance for difference; individual choice respected","marketing_angle":"Personal choice themes; freedom without judgment; tolerance messaging; progressive values"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"1930 and 1950 World Cup victories","importance":"Low","expression":"Safe and powerful; \"Maracanazo\" 1950 against Brazil especially resonant; founding champions of World Cup","marketing_angle":""},{"value":"José Artigas (national hero)","importance":"Low","expression":"Father of the nation; respected across political spectrum; orientalidad pride; safe historical reference","marketing_angle":""},{"value":"Renewable energy success","importance":"Low","expression":"95%+ renewable electricity; environmental leadership; safe positive reference; Uruguay Natural brand","marketing_angle":""}]',
