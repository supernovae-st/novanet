    c.culture_summary = 'en-SA: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: Hospitality (Diyafa), Family Honour and Unity, National Pride (Vision 2030).',
    c.taboos_summary = 'CRITICAL TABOOS: Criticism of Islam, Criticism of Royal Family or Leadership, Atheism or anti-religious content. Always avoid these topics.',
    c.template_version = '3.1',
