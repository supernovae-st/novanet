    c.business_hours = '{"end":"17:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Liberte et dignite","importance":"High","expression":"Conscience post-Revolution de 2011 ; les citoyens valorisent leur voix et leurs droits ; la culture de protestation est normalisee","marketing_angle":"Positionner la marque comme source d\'autonomisation ; respecter l\'autonomie du client ; jamais condescendant ; messages « votre choix »"},{"value":"Famille","importance":"High","expression":"Liens familiaux elargis ; menages multigenerationnels ; prise de decision collective ; piete filiale","marketing_angle":"Contenu centre sur la famille ; montrer grands-parents, parents, enfants ensemble ; produits pour moments partages ; « pour toute la famille »"},{"value":"Ouverture","importance":"High","expression":"Identite mediterraneenne cosmopolite ; elite francophone ; culture accueillante pour le tourisme ; bilinguisme naturel","marketing_angle":"Messages modernes et connectes ; arguments de qualite internationale resonnent ; « qualite internationale » comme marqueur de valeur"},{"value":"Education et culture","importance":"High","expression":"Taux d\'alphabetisation eleve (79%) ; l\'education vue comme ascenseur social ; fierte du patrimoine intellectuel (Ibn Khaldoun)","marketing_angle":"Positionner les produits comme choix intelligents ; marketing base sur les connaissances ; contenu educatif valorise"},{"value":"Egalite","importance":"Medium","expression":"Code du statut personnel progressiste depuis 1956 ; leadership en matiere de droits des femmes dans le monde arabe ; constitution laique","marketing_angle":"Imagerie equilibree entre les genres ; femmes professionnelles normalisees ; eviter les suppositions de segregation des genres a la mode du Golfe"},{"value":"Hospitalite tunisienne","importance":"Medium","expression":"Accueil des touristes et des invites ; partage de nourriture ; rituels du the a la menthe ; culture touristique de la plage et de la medina","marketing_angle":"Ton de service genereux ; imagerie d\'hospitalite ; chaleur du « bienvenue chez nous »"},{"value":"Patience et optimisme","importance":"Medium","expression":"Resilience post-Revolution ; defis economiques navigues avec espoir ; « demain sera meilleur »","marketing_angle":"Reconnaitre les defis de maniere realiste ; proposer des solutions ; eviter la positivite toxique ; credibilite plutot que battage"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Revolution de 2011 (Revolution du Jasmin)","importance":"High","expression":"Origine du Printemps arabe ; fierte melee aux difficultes economiques persistantes ; traiter avec nuance ; eviter tout positionnement politique","marketing_angle":""},{"value":"Sites historiques (Carthage, El Djem, Kairouan)","importance":"Low","expression":"Patrimoine UNESCO ; fierte touristique ; sur pour tout contenu ; universellement positif","marketing_angle":""},{"value":"Heritage de Bourguiba","importance":"Medium","expression":"President fondateur ; architecte de la modernisation ; certaines controverses politiques ; utiliser avec prudence","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"DIRECT","hierarchy_sensitivity":"LOW"}',
    c.culture_summary = 'fr-TN: Communication style is direct. Hierarchy importance: low. Orientation: Collectivist (focus on \'we/together\'). Core values: Liberte et dignite, Famille, Ouverture.',
