    c.values = '[{"value":"Multilinguisme (Multilingualism)","importance":"High","expression":"Trois langues officielles; alternance des codes au quotidien; flexibilite linguistique comme marqueur identitaire; francais souvent langue administrative et professionnelle","marketing_angle":"Reconnaitre la diversite linguistique; ne pas presumer un public uniquement francophone; demontrer une conscience culturelle"},{"value":"Identite europeenne (European Identity)","importance":"High","expression":"Membre fondateur de l\'UE; siege d\'institutions europeennes; fierte profonde d\'integration europeenne","marketing_angle":"Les valeurs europeennes resonnent; cooperation transfrontaliere; perspective internationale bienvenue"},{"value":"Discretion","importance":"High","expression":"Culture de confidentialite du centre financier; affaires personnelles restent privees; reussite affichee avec retenue","marketing_angle":"Respecter la vie privee; pas de questions intrusives; messages subtils; confiance par la confidentialite"},{"value":"Qualite de vie (Quality of Life)","importance":"High","expression":"Equilibre vie professionnelle-vie personnelle valorise; niveau de vie eleve; qualite plutot que quantite","marketing_angle":"Mettre l\'accent sur qualite, durabilite, amelioration du quotidien; positionnement premium resonne"},{"value":"Stabilite et securite (Stability and Security)","importance":"High","expression":"Stabilite politique; economie notee AAA; mentalite de valeur refuge","marketing_angle":"Messages de fiabilite; partenariats long terme; caracteristiques de securite; bilan eprouve"},{"value":"Cosmopolitisme (Cosmopolitanism)","importance":"High","expression":"Pres de 50% de residents etrangers; main-d\'oeuvre internationale; diversite culturelle comme norme","marketing_angle":"Messages inclusifs; perspectives mondiales; diversite comme atout; eviter le nationalisme"},{"value":"Pragmatisme","importance":"Medium","expression":"Solutions pratiques preferees; efficacite valorisee; resultats plutot qu\'ideologie","marketing_angle":"Se concentrer sur les avantages concrets; propositions de valeur pratiques; pas de promesses creuses"},{"value":"Precision","importance":"Medium","expression":"Rigueur dans les contextes financiers et juridiques; attention aux details; exactitude appreciee","marketing_angle":"Communication precise et complete; eviter les approximations; information verifiable"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Devise nationale \"Mir welle bleiwe wat mir sinn\"","importance":"Low","expression":"\"Nous voulons rester ce que nous sommes\" - identite luxembourgeoise; peut etre reference avec respect; demontre connaissance culturelle","marketing_angle":""},{"value":"Membre fondateur de l\'UE","importance":"Low","expression":"Source de fierte profonde; Luxembourg parmi les six originaux; identite europeenne fondamentale","marketing_angle":""},{"value":"Societe multilingue","importance":"Low","expression":"Reussite linguistique unique; trois langues officielles plus anglais largement utilise; securitaire a celebrer","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"LOW_CONTEXT","directness":"BALANCED","hierarchy_sensitivity":"MEDIUM"}',
    c.culture_summary = 'fr-LU: Communication style is balanced. Hierarchy importance: medium. Orientation: Individualist (focus on \'you\'). Core values: Multilinguisme (Multilingualism), Identite europeenne (European Identity), Discretion.',
    c.taboos_summary = 'CRITICAL TABOOS: Cadrage "paradis fiscal", Confondre Luxembourg avec Belgique ou Allemagne, Discuter de richesse personnelle ou de revenus. Always avoid these topics.',
    c.template_version = '3.1',
    c.source_file = 'fr-LU.md',
    c.created_by = 'seed:locale',
