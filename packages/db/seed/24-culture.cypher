    c.business_hours = '{"end":"12:30","lunch_break":false,"start":"08:00"}',
    c.values = '[{"value":"الكرم والضيافة (Generosity/Hospitality)","importance":"High","expression":"World-renowned hosting (World Cup 2022); treating guests as honored family; majlis culture; \"أهلاً وسهلاً\" as national identity","marketing_angle":"Position products as generous offerings; VIP treatment language; welcoming warmth; \"ضيوفنا الكرام\" (our honored guests)"},{"value":"الإيمان (Faith)","importance":"High","expression":"Islamic values integrated into daily life; prayer times sacred; Ramadan central; Islamic ethics in business","marketing_angle":"Respect religious timing; halal default; appropriate Islamic phrases; Friday as holy day; Ramadan-sensitive scheduling"},{"value":"العائلة (Family)","importance":"High","expression":"Extended family central; family honor collective; intergenerational living; family consultation on decisions","marketing_angle":"Family-centered messaging; multi-generational appeal; \"لعائلتك\" positioning; collective benefit themes"},{"value":"الطموح (Ambition)","importance":"High","expression":"Qatar National Vision 2030; rapid development; knowledge economy building; global ambitions","marketing_angle":"Innovation themes; future-forward messaging; \"نحو المستقبل\" (toward the future); excellence pursuit"},{"value":"الكرامة والشرف (Dignity/Honor)","importance":"High","expression":"Personal and family honor paramount; face-saving in all interactions; reputation protection","marketing_angle":"Never embarrass customers; discrete service; premium positioning respects customer status; dignified communications"},{"value":"الاستدامة (Sustainability)","importance":"Medium","expression":"Environmental awareness; FIFA World Cup legacy sustainability; Qatar National Environment and Climate Change Strategy","marketing_angle":"Green messaging resonates; sustainable products valued; \"الاستدامة لمستقبلنا\" (sustainability for our future)"},{"value":"التميز (Excellence)","importance":"Medium","expression":"World-class standards pursuit; global hub ambitions; infrastructure excellence; being \"first\" and \"best\"","marketing_angle":"Premium quality emphasis; world-class positioning; \"الأفضل في فئته\" (best in class); excellence themes"},{"value":"المعرفة (Knowledge)","importance":"Medium","expression":"Education City investment; Qatar Foundation emphasis; research and development; knowledge economy","marketing_angle":"Education themes; innovation messaging; \"اقتصاد المعرفة\" (knowledge economy); learning-focused content"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"FIFA World Cup 2022","importance":"Low","expression":"Historic achievement; first Arab/Middle East host; freely reference; stadium imagery positive; infrastructure pride","marketing_angle":""},{"value":"Education City and Qatar Foundation","importance":"Low","expression":"Source of pride; world-class universities; can reference freely; innovation and knowledge economy symbols","marketing_angle":""},{"value":"Amiri leadership","importance":"Medium","expression":"Respect required; positive references acceptable; never use for commercial purposes; formal context only","marketing_angle":""}]',
    c.communication_norms = '{"context_type":"HIGH_CONTEXT","directness":"INDIRECT","hierarchy_sensitivity":"HIGH"}',
    c.culture_summary = 'ar-QA: Communication style is indirect. Hierarchy importance: high. Orientation: Collectivist (focus on \'we/together\'). Core values: الكرم والضيافة (Generosity/Hospitality), الإيمان (Faith), العائلة (Family).',
    c.taboos_summary = 'CRITICAL TABOOS: Criticism of Amir or ruling family, Insulting Islam or Prophet, LGBTQ+ content. Always avoid these topics.',
    c.template_version = '3.1',
