    c.values = '[{"value":"Melmastia (Hospitality)","importance":"High","expression":"Generous hosting of guests regardless of cost; offering food, shelter, protection to visitors","marketing_angle":"Position brand as generous host; emphasize service excellence; warm reception messaging"},{"value":"Nang (Honor)","importance":"High","expression":"Personal and family reputation paramount; public perception carefully guarded","marketing_angle":"Emphasize quality, reliability, discretion; never risk customer\'s standing"},{"value":"Namus (Protection of Family Honor)","importance":"High","expression":"Protecting family members, especially women; defending family name","marketing_angle":"Family-oriented messaging; products that support and protect the household"},{"value":"Ghairat (Courage/Dignity)","importance":"High","expression":"Standing firm on principles; bravery in defending one\'s values","marketing_angle":"Bold, dignified brand positioning; emphasize strength and reliability"},{"value":"Badal (Reciprocity/Balance)","importance":"Medium","expression":"Repaying both kindness and wrongs; maintaining social equilibrium","marketing_angle":"Loyalty programs; reciprocal customer relationships; fair dealing emphasis"},{"value":"Sabat (Steadfastness)","importance":"Medium","expression":"Loyalty to one\'s word; keeping promises; consistency","marketing_angle":"Emphasize reliability, promise-keeping; long-term value propositions"},{"value":"Nanawatai (Sanctuary/Forgiveness)","importance":"Medium","expression":"Offering protection to those who ask; mercy and reconciliation","marketing_angle":"Customer recovery; second chances; forgiving return policies"},{"value":"Jirga (Collective Decision)","importance":"Medium","expression":"Consensus-building through elder councils; community agreement","marketing_angle":"Multi-stakeholder approval messaging; community benefit themes"},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Afghan hospitality reputation","importance":"Low","expression":"Known globally for generous hosting; safe for positive reference","marketing_angle":""},{"value":"Ahmad Shah Massoud (in some regions)","importance":"High","expression":"Politically divisive; avoid in commercial contexts","marketing_angle":""},{"value":"Islamic Emirate achievements","importance":"High","expression":"Politically charged; avoid commercial commentary","marketing_angle":""}]',
