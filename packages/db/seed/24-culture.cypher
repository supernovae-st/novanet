MERGE (c:Culture {key: 'es-CL'})
SET c.display_name = 'es-CL Culture Norms',
    c.description = 'Cultural context and norms for es-CL',
    c.llm_context = 'USE: es-CL culture (southern hemisphere, balanced communication, medium hierarchy). TRIGGERS: regional holidays, seasonal references, formality levels. NOT: generic greetings, universal values.',
    c.hemisphere = 'southern',
    c.work_week_start = 'monday',
    c.communication_directness = 'balanced',
    c.hierarchy_importance = 'medium',
    c.individualism_level = 'mixed',
    c.seasons = '{}',
    c.holidays = '[]',
    c.business_hours = '{"end":"18:00","lunch_break":false,"start":"09:00"}',
    c.values = '[{"value":"Familia (Family)","importance":"High","expression":"Extended family bonds; Sunday family gatherings (asado); multi-generational support; children highly valued","marketing_angle":"Family-centered messaging; \"para tu familia\"; imagery of gatherings; protect loved ones"},{"value":"Solidaridad (Solidarity)","importance":"High","expression":"Helping neighbors; community response to crises (earthquakes, fires); \"Teletón\" culture; collective action","marketing_angle":"Community connection; mutual support; \"juntos salimos adelante\"; collaborative messaging"},{"value":"Esfuerzo (Hard Work/Effort)","importance":"High","expression":"Self-made success valued; \"cultura del trabajo\"; education as pathway; meritocracy ideal","marketing_angle":"Reward effort; achievement narratives; practical value propositions; \"lo que cuesta, vale\""},{"value":"Humor/Talla","importance":"High","expression":"Self-deprecating humor; irony; not taking oneself too seriously; \"chaqueteo\" (cutting down tall poppies)","marketing_angle":"Light tone welcomed; brands can be playful; authenticity over pomposity"},{"value":"Educación (Education/Manners)","importance":"Medium","expression":"Academic achievement valued; also means good manners; \"ser educado\"; respect in interactions","marketing_angle":"Quality messaging; professional presentation; polite communication; informed choice"},{"value":"Austeridad/Modestia","importance":"Medium","expression":"Distrust of flashy displays; understated success; showing off is \"flaite\" or \"siútico\"","marketing_angle":"Avoid excessive luxury signals; understated elegance; practical value; no bragging"},{"value":"Emprendimiento (Entrepreneurship)","importance":"Medium","expression":"Growing startup culture; \"sacarse la mugre\"; innovation valued in younger generations","marketing_angle":"Innovation messaging; progress; \"Chile can do it\"; forward-thinking"},{"value":"Chilenidad (Chilean Identity)","importance":"Medium","expression":"Pride in unique national character; \"Chile lindo\"; geographic distinctiveness; resilience","marketing_angle":"National references when authentic; local over foreign; \"hecho en Chile\""},{"value":"Pride Point","importance":"Sensitivity","expression":"Usage Notes","marketing_angle":""},{"value":"Natural landscapes (Patagonia, Atacama, Torres del Paine)","importance":"Low","expression":"Immense pride; world-class nature; safe celebratory reference","marketing_angle":""},{"value":"Teletón and solidarity","importance":"Low","expression":"Annual telethon tradition; national unity symbol; positive community reference","marketing_angle":""},{"value":"Chilean poets (Neruda, Mistral)","importance":"Low","expression":"Nobel laureates; cultural pride; literary heritage; safe reference","marketing_angle":""},{"value":"Resilience to earthquakes","importance":"Medium","expression":"Pride in survival and rebuilding; but real trauma involved; acknowledge don\'t trivialize","marketing_angle":""}]',
