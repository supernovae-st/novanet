    c.values = '[{"value":"Familia (Family)","importance":"High","expression":"Extended family central to identity; multi-generational households; family decisions made collectively; compadrazgo (godparent) system expands family bonds","marketing_angle":"Family-oriented messaging; multi-generational appeal; \"para toda la familia\"; home and belonging themes"},{"value":"Orgullo Mexicano (Mexican Pride)","importance":"High","expression":"Strong national identity; pride in cultural heritage, food, music, art; \"Hecho en Mexico\" valued; resilience narrative","marketing_angle":"Celebrate Mexican identity; local pride; avoid condescension; authentic Mexican aesthetics"},{"value":"Calidez (Warmth)","importance":"High","expression":"Personal connections essential; relationship before transaction; hospitality (mi casa es tu casa); physical warmth in greetings","marketing_angle":"Warm, friendly tone; personalization; avoid cold transactional approach; build rapport first"},{"value":"Respeto (Respect)","importance":"High","expression":"Deference to elders and authority; formal address expected initially; dignity preservation; never embarrass publicly","marketing_angle":"Use usted appropriately; acknowledge expertise; respect hierarchy; preserve dignity in all interactions"},{"value":"Trabajo Duro (Hard Work)","importance":"High","expression":"Dedication to providing for family; self-made success respected; entrepreneurial spirit (\"echale ganas\"); resilience admired","marketing_angle":"Honor work ethic; support aspirations; acknowledge effort; success through dedication narratives"},{"value":"Alegria (Joy/Celebration)","importance":"Medium","expression":"Life celebration despite hardship; fiestas central to culture; humor in adversity; enjoying the moment","marketing_angle":"Celebration themes; joy and color acceptable; humor connects; don\'t be overly serious"},{"value":"Fe (Faith)","importance":"Medium","expression":"Catholic tradition deeply embedded; religious holidays 