// SLUGIFIED_BY (ADR-030)
MERGE (ac_SLUGIFIED_BY:Schema:ArcClass {key: 'SLUGIFIED_BY'})
ON CREATE SET
  ac_SLUGIFIED_BY.display_name = 'Slugified By',
  ac_SLUGIFIED_BY.llm_context = 'USE: when validating slug conformity to locale rules. TRIGGERS: "slug validation", "diacritics check", "accent validation", "URL rules". NOT: slug provenance (use DERIVED_SLUG_FROM), page routing (use full_path). RELATES: BlockNative:head-seo-meta (source), Slugification (target rules). VALIDATION RULES by slug_rule: - latin_preserve (preserve_diacritics=true): "código-qr" VALID, "codigo-qr" INVALID - latin_strip (preserve_diacritics=false): "codigo-qr" VALID, "código-qr" INVALID - native_script: "コード" VALID (native characters allowed) - transliterate: ASCII-only after transliteration map applied CRITICAL: If slug fails validation, the arc property validated=false.',
  ac_SLUGIFIED_BY.family = 'semantic',
  ac_SLUGIFIED_BY.scope = 'cross_realm',
  ac_SLUGIFIED_BY.cardinality = 'many_to_one',
  ac_SLUGIFIED_BY.is_self_referential = false,
  ac_SLUGIFIED_BY.inverse_name = 'SLUGIFIES',
  ac_SLUGIFIED_BY.arc_properties = ['validated', 'applied_rule', 'validation_timestamp', 'validation_errors'],
  ac_SLUGIFIED_BY.arc_property_info = '[{name: \'applied_rule\', type: \'string\', required: true, enum: [\'latin_preserve\', \'latin_strip\', \'native_script\', \'transliterate\']}, {name: \'validated\', type: \'boolean\', required: true}, {name: \'validation_errors\', type: \'array\', required: false}, {name: \'validation_timestamp\', type: \'datetime\', required: false}]',
  ac_SLUGIFIED_BY.cypher_pattern = '(BlockNative)-[:SLUGIFIED_BY]->(Slugification)',
  ac_SLUGIFIED_BY.temperature_threshold = null,
  ac_SLUGIFIED_BY.node_class = 'arc_class',
  ac_SLUGIFIED_BY.created_by = 'seed:schema',
  ac_SLUGIFIED_BY.created_at = datetime()
ON MATCH SET
  ac_SLUGIFIED_BY.display_name = 'Slugified By',
  ac_SLUGIFIED_BY.llm_context = 'USE: when validating slug conformity to locale rules. TRIGGERS: "slug validation", "diacritics check", "accent validation", "URL rules". NOT: slug provenance (use DERIVED_SLUG_FROM), page routing (use full_path). RELATES: BlockNative:head-seo-meta (source), Slugification (target rules). VALIDATION RULES by slug_rule: - latin_preserve (preserve_diacritics=true): "código-qr" VALID, "codigo-qr" INVALID - latin_strip (preserve_diacritics=false): "codigo-qr" VALID, "código-qr" INVALID - native_script: "コード" VALID (native characters allowed) - transliterate: ASCII-only after transliteration map applied CRITICAL: If slug fails validation, the arc property validated=false.',
  ac_SLUGIFIED_BY.family = 'semantic',
  ac_SLUGIFIED_BY.scope = 'cross_realm',
  ac_SLUGIFIED_BY.cardinality = 'many_to_one',
  ac_SLUGIFIED_BY.is_self_referential = false,
  ac_SLUGIFIED_BY.inverse_name = 'SLUGIFIES',
  ac_SLUGIFIED_BY.arc_properties = ['validated', 'applied_rule', 'validation_timestamp', 'validation_errors'],
  ac_SLUGIFIED_BY.arc_property_info = '[{name: \'applied_rule\', type: \'string\', required: true, enum: [\'latin_preserve\', \'latin_strip\', \'native_script\', \'transliterate\']}, {name: \'validated\', type: \'boolean\', required: true}, {name: \'validation_errors\', type: \'array\', required: false}, {name: \'validation_timestamp\', type: \'datetime\', required: false}]',
  ac_SLUGIFIED_BY.cypher_pattern = '(BlockNative)-[:SLUGIFIED_BY]->(Slugification)',
  ac_SLUGIFIED_BY.temperature_threshold = null,
  ac_SLUGIFIED_BY.node_class = 'arc_class',
  ac_SLUGIFIED_BY.updated_at = datetime();

