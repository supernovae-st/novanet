// ═══════════════════════════════════════════════════════════════════════════════
// Hierarchy: EdgeFamily -[:HAS_EDGE_KIND]-> EdgeKind (70)
// ═══════════════════════════════════════════════════════════════════════════════

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_CONCEPT'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_PAGE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_BRAND_IDENTITY'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'SUPPORTS_LOCALE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'DEFAULT_LOCALE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_BLOCK'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'OF_TYPE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_PROMPT'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'HAS_RULES'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'ownership'}), (ek:EdgeKind {key: 'BELONGS_TO_PROJECT_L10N'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'FOR_LOCALE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'HAS_L10N'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'HAS_OUTPUT'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'FALLBACK_TO'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'VARIANT_OF'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'HAS_IDENTITY'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

MATCH (ef:EdgeFamily {key: 'localization'}), (ek:EdgeKind {key: 'HAS_VOICE'})
MERGE (ef)-[:HAS_EDGE_KIND]->(ek);

