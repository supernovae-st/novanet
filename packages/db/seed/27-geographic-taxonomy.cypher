// -----------------------------------------------------------------------------
// CREATE HIERARCHY RELATIONSHIPS
// -----------------------------------------------------------------------------

// Continent -> GeoRegion
MATCH (c:Continent {key: 'africa'}), (r:GeoRegion) WHERE r.parent_continent = 'africa' MERGE (r)-[:IN_CONTINENT]->(c);
MATCH (c:Continent {key: 'americas'}), (r:GeoRegion) WHERE r.parent_continent = 'americas' MERGE (r)-[:IN_CONTINENT]->(c);
MATCH (c:Continent {key: 'asia'}), (r:GeoRegion) WHERE r.parent_continent = 'asia' MERGE (r)-[:IN_CONTINENT]->(c);
MATCH (c:Continent {key: 'europe'}), (r:GeoRegion) WHERE r.parent_continent = 'europe' MERGE (r)-[:IN_CONTINENT]->(c);
MATCH (c:Continent {key: 'oceania'}), (r:GeoRegion) WHERE r.parent_continent = 'oceania' MERGE (r)-[:IN_CONTINENT]->(c);

// GeoSubRegion -> GeoRegion
MATCH (sr:GeoSubRegion), (r:GeoRegion) WHERE sr.parent_region = r.key MERGE (sr)-[:IN_REGION]->(r);

// LanguageFamily -> LanguageBranch
MATCH (f:LanguageFamily), (b:LanguageBranch) WHERE b.parent_family = f.key MERGE (b)-[:BRANCH_OF]->(f);

// CulturalRealm -> CulturalSubRealm
MATCH (cr:CulturalRealm), (csr:CulturalSubRealm) WHERE csr.parent_realm = cr.key MERGE (csr)-[:PART_OF_REALM]->(cr);

// PopulationCluster -> PopulationSubCluster
MATCH (pc:PopulationCluster), (psc:PopulationSubCluster) WHERE psc.parent_cluster = pc.key MERGE (psc)-[:CLUSTER_OF]->(pc);

// OF_CLASS arc removed (v0.13.1): arc does not exist in schema
// Instance→Class relationships are auto-wired via seed/99-autowire-classes.cypher
