  ak_VARIANT_OF.llm_context = 'Variant relationship: Entity A is a variant/version of Entity B. The source is a specialized form of the target (more specific). Examples: CustomQRCode VARIANT_OF QRCode, DynamicQR VARIANT_OF QRCode variant_type: version (temporal), flavor (style), edition (release), specialization (domain), customization (user-defined)',
  ak_VARIANT_OF.family = 'semantic',
  ak_VARIANT_OF.scope = 'intra_realm',
  ak_VARIANT_OF.cardinality = 'many_to_one',
  ak_VARIANT_OF.is_self_referential = false,
  ak_VARIANT_OF.inverse_name = 'HAS_VARIANT',
  ak_VARIANT_OF.arc_properties = ['strength', 'temperature', 'variant_type'],
  ak_VARIANT_OF.cypher_pattern = '(Entity)-[:VARIANT_OF]->(Entity)',
  ak_VARIANT_OF.temperature_threshold = 0.2,
  ak_VARIANT_OF.created_at = datetime()
