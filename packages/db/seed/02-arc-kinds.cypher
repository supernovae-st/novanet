MATCH (ak:ArcKind {key: 'USE_CASE_FOR'}), (k:Kind {label: 'Entity'})
MERGE (ak)-[:TO_KIND]->(k);

MATCH (ak:ArcKind {key: 'VARIANT_OF'}), (k:Kind {label: 'Entity'})
MERGE (ak)-[:TO_KIND]->(k);

