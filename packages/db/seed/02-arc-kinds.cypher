  ac_ALTERNATIVE_TO.inverse_name = null,
  ac_ALTERNATIVE_TO.arc_properties = ['strength', 'temperature', 'alternative_type', 'context'],
  ac_ALTERNATIVE_TO.cypher_pattern = '(Entity)-[:ALTERNATIVE_TO]->(Entity)',
