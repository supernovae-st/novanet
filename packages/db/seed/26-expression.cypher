// ============================================================================
// Wire ExpressionSets to Locales
// ============================================================================

MATCH (l:Locale {key: 'ar-SA'}), (es:ExpressionSet {key: 'ar-SA'})
MERGE (l)-[:HAS_EXPRESSIONS]->(es);

MATCH (l:Locale {key: 'de-DE'}), (es:ExpressionSet {key: 'de-DE'})
MERGE (l)-[:HAS_EXPRESSIONS]->(es);

MATCH (l:Locale {key: 'es-ES'}), (es:ExpressionSet {key: 'es-ES'})
MERGE (l)-[:HAS_EXPRESSIONS]->(es);

MATCH (l:Locale {key: 'fr-FR'}), (es:ExpressionSet {key: 'fr-FR'})
MERGE (l)-[:HAS_EXPRESSIONS]->(es);

MATCH (l:Locale {key: 'hi-IN'}), (es:ExpressionSet {key: 'hi-IN'})
