// packages/core/src/graph/layers.ts
// NODE_LAYERS mapping all 8 node types to their layers
// AUTO-GENERATED by novanet v10.4.0 — DO NOT EDIT
// Run: novanet schema generate

import type { NodeType } from '../types/nodes.js';
import type { Layer } from './types.js';

// =============================================================================
// NODE_LAYERS - Maps each NodeType to its layer
// =============================================================================

/**
 * Maps each NodeType to its layer within its realm.
 * AUTO-GENERATED from models/node-kinds/ folder structure.
 *
 * Layers by realm:
 * - Global: config, knowledge, seo
 * - Project: foundation, semantic, structure
 */
export const NODE_LAYERS: Record<NodeType, Layer> = {
  // ═══════════════════════════════════════════════════════════════════════════
  // GLOBAL REALM (4 nodes)
  // ═══════════════════════════════════════════════════════════════════════════

  // config (1 node) - matches models/node-kinds/global/config/
  Locale: 'config',

  // knowledge (1 node) - matches models/node-kinds/global/knowledge/
  LocaleVoice: 'knowledge',

  // seo (2 nodes) - matches models/node-kinds/global/seo/
  SEOKeyword: 'seo',
  SEOTarget: 'seo',

  // ═══════════════════════════════════════════════════════════════════════════
  // PROJECT REALM (4 nodes)
  // ═══════════════════════════════════════════════════════════════════════════

  // foundation (1 node) - matches models/node-kinds/project/foundation/
  Project: 'foundation',

  // semantic (1 node) - matches models/node-kinds/project/semantic/
  Concept: 'semantic',

  // structure (2 nodes) - matches models/node-kinds/project/structure/
  Block: 'structure',
  Page: 'structure',

};

// =============================================================================
// HELPER FUNCTIONS
// =============================================================================

/**
 * Get the layer for a node type
 * @param nodeType - The node type to look up
 * @returns The layer for the node type
 */
export function getLayer(nodeType: NodeType): Layer {
  return NODE_LAYERS[nodeType];
}

/**
 * Get all node types in a layer
 * @param layer - The layer to look up
 * @returns Array of node types belonging to the layer
 */
export function getNodeTypesByLayer(layer: Layer): NodeType[] {
  return (Object.entries(NODE_LAYERS) as [NodeType, Layer][])
    .filter(([, l]) => l === layer)
    .map(([nodeType]) => nodeType);
}
