      "severity": "high"
    },
    {
      "name": "Feet are Impure",
      "description": "Feet are the lowest and most impure body part. Never point feet at people or sacred objects.",
      "severity": "high"
    },
    {
      "name": "Women and Monks",
      "description": "Women must not touch monks or hand items directly to them.",
      "severity": "high"
    },
    {
      "name": "Aggressive Marketing",
      "description": "Lao culture values harmony. Hard-sell tactics and aggressive CTAs feel disrespectful.",
