# =============================================================================
# {{name}}L10n Node Definition (Localized Variant)
# =============================================================================
# Scope: {{scope}}
# Subcategory: {{subcategory}}
# Parent: {{name}}
# Generated by: turbo gen node
# =============================================================================

name: {{name}}L10n
scope: {{scope}}
subcategory: {{subcategory}}
description: "Localized variant of {{name}} for a specific locale"

# L10n nodes inherit standard properties from parent
# Plus locale-specific content

# Custom properties for localized content
properties:
  # Localized display name
  - name: display_name
    type: string
    description: "Localized display name in target locale"
    required: true

  # Localized description/content
  - name: description
    type: string
    description: "Localized description in target locale"
    required: false

  # Add more localized properties as needed
  # Example:
  # - name: tagline
  #   type: string
  #   description: "Localized tagline"

# Relations
outgoing_relations:
  - relation: FOR_LOCALE
    to: Locale
    description: "Target locale for this localization"
    required: true

incoming_relations:
  - relation: HAS_L10N
    from: {{name}}
    description: "Parent invariant node"

# Constraints
constraints:
  - type: unique
    properties: [key, locale_key]
    description: "One L10n per locale per parent"
