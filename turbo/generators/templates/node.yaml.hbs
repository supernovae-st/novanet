# =============================================================================
# {{name}} Node Definition
# =============================================================================
# Realm: {{realm}}
# Layer: {{layer}}
# Generated by: turbo gen node
# =============================================================================

name: {{name}}
realm: {{realm}}
layer: {{layer}}
description: "{{description}}"

# Standard properties (all nodes have these)
standard_properties:
  - key           # Unique identifier with semantic prefix
  - display_name  # Human-readable name
  - llm_context   # AI hints: "USE: [when]. TRIGGERS: [keywords]. NOT: [disambiguation]."
  - priority      # 'critical' | 'high' | 'medium' | 'low'
  - freshness     # 'realtime' | 'hourly' | 'daily' | 'static'
  - created_at    # Creation timestamp
  - updated_at    # Last update timestamp

# Custom properties for this node type
properties:
  # Add your custom properties here
  # Example:
  # - name: segment
  #   type: string
  #   enum: [b2b, b2c, enterprise]
  #   description: "Target market segment"
  #   required: true

# Relations from this node
outgoing_relations: []
  # Example:
  # - relation: HAS_L10N
  #   to: {{name}}L10n
  #   description: "Localized variant"

# Relations to this node
incoming_relations: []
  # Example:
  # - relation: HAS_{{snakeCase name}}
  #   from: Project
  #   description: "Project owns this {{name}}"

# Constraints
constraints:
  - type: unique
    property: key
