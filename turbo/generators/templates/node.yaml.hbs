# =============================================================================
# {{name}} Node Definition
# =============================================================================
# Realm: {{realm}}
# Layer: {{layer}}
# Generated by: turbo gen node
# =============================================================================

name: {{name}}
realm: {{realm}}
layer: {{layer}}

# Standard properties (all nodes have these — v0.20.0)
standard_properties:
  - key           # Unique identifier with semantic prefix
  - display_name  # Human-readable name
  - node_class    # PascalCase class name (e.g., "Entity", "PageNative")
  - content       # Plain language: what this node IS and HOW it works
  - triggers      # English keywords for RAG activation (max 10)
  - provenance    # Data origin: seed | nika | mcp
  - created_at    # Creation timestamp
  - updated_at    # Last update timestamp

# Custom properties for this node type
properties:
  # Add your custom properties here
  # Example:
  # - name: segment
  #   type: string
  #   enum: [b2b, b2c, enterprise]
  #   description: "Target market segment"
  #   required: true

# Relations from this node
outgoing_relations: []
  # Example:
  # - relation: HAS_L10N
  #   to: {{name}}L10n
  #   description: "Localized variant"

# Relations to this node
incoming_relations: []
  # Example:
  # - relation: HAS_{{snakeCase name}}
  #   from: Project
  #   description: "Project owns this {{name}}"

# Constraints
constraints:
  - type: unique
    property: key
