# =============================================================================
# View: {{name}}
# =============================================================================
# Description: {{description}}
# Root: {{rootType}}
# Generated by: turbo gen view
# v11.0: Uses Entity/EntityContent (not Concept/ConceptL10n)
# =============================================================================

name: {{name}}
description: "{{description}}"
version: "11.0.0"

# Parameters accepted by this view
parameters:
  - name: key
    type: string
    required: true
    description: "Key of the root {{rootType}} node"
  - name: locale
    type: string
    required: false
    description: "Locale code (e.g., 'fr-FR')"

# Root node configuration
root:
  type: {{rootType}}
  match_by: key

# What to include in the result
includes:
{{#each includes}}
  {{this}}: true
{{/each}}

# Cypher query template
# Variables: $key, $locale
cypher: |
  MATCH (root:{{rootType}} {key: $key})
{{#if (includes 'blocks')}}
  OPTIONAL MATCH (root)-[:HAS_BLOCK]->(block:Block)
{{/if}}
{{#if (includes 'entities')}}
  OPTIONAL MATCH (root)-[:USES_ENTITY]->(entity:Entity)
  OPTIONAL MATCH (entity)-[:HAS_CONTENT]->(entityContent:EntityContent)-[:FOR_LOCALE]->(locale:Locale {key: $locale})
{{/if}}
{{#if (includes 'knowledge')}}
  OPTIONAL MATCH (locale)-[:HAS_VOICE]->(voice:LocaleVoice)
  OPTIONAL MATCH (locale)-[:HAS_CULTURE]->(culture:LocaleCulture)
  OPTIONAL MATCH (locale)-[:HAS_TERMS]->(terms:TermSet)
{{/if}}
{{#if (includes 'prompts')}}
  OPTIONAL MATCH (root)-[:HAS_PROMPT]->(prompt)
  OPTIONAL MATCH (root)-[:HAS_RULES]->(rules)
{{/if}}
{{#if (includes 'seo')}}
  OPTIONAL MATCH (entity)-[:HAS_SEO_KEYWORDS]->(seoKeyword:SEOKeyword)-[:FOR_LOCALE]->(locale)
{{/if}}
{{#if (includes 'geo')}}
  OPTIONAL MATCH (entity)-[:HAS_GEO_QUERIES]->(geoQuery:GEOQuery)-[:FOR_LOCALE]->(locale)
{{/if}}
  RETURN root,
         collect(DISTINCT block) AS blocks,
         collect(DISTINCT entity) AS entities,
         collect(DISTINCT entityContent) AS entityContents

# Documentation
docs:
  usage: |
    Use this view to fetch {{rootType}} data with related entities.

    Example with NovaNetFilter:
    ```typescript
    const filter = NovaNetFilter.create()
      .from{{rootType}}('your-{{snakeCase rootType}}-key')
      .forLocale('fr-FR');
    ```

  returns: |
    - root: The {{rootType}} node
    - blocks: Related Block nodes (if included)
    - entities: Related Entity nodes (if included)
    - entityContents: Localized entity content (if included)
