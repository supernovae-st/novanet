# =============================================================================
# View: {{name}}
# =============================================================================
# Description: {{description}}
# Root: {{rootType}}
# Generated by: turbo gen view
# =============================================================================

name: {{name}}
description: "{{description}}"
version: "1.0.0"

# Parameters accepted by this view
parameters:
  - name: key
    type: string
    required: true
    description: "Key of the root {{rootType}} node"
  - name: locale
    type: string
    required: false
    description: "Locale code (e.g., 'fr-FR')"

# Root node configuration
root:
  type: {{rootType}}
  match_by: key

# What to include in the result
includes:
{{#each includes}}
  {{this}}: true
{{/each}}

# Cypher query template
# Variables: $key, $locale
cypher: |
  MATCH (root:{{rootType}} {key: $key})
{{#if (includes 'blocks')}}
  OPTIONAL MATCH (root)-[:HAS_BLOCK]->(block:Block)
{{/if}}
{{#if (includes 'concepts')}}
  OPTIONAL MATCH (root)-[:USES_CONCEPT]->(concept:Concept)
  OPTIONAL MATCH (concept)-[:HAS_L10N]->(conceptL10n:ConceptL10n)-[:FOR_LOCALE]->(locale:Locale {key: $locale})
{{/if}}
{{#if (includes 'localeKnowledge')}}
  OPTIONAL MATCH (locale)-[:HAS_VOICE]->(voice:LocaleVoice)
  OPTIONAL MATCH (locale)-[:HAS_CULTURE]->(culture:LocaleCulture)
  OPTIONAL MATCH (locale)-[:HAS_LEXICON]->(lexicon:LocaleLexicon)
{{/if}}
{{#if (includes 'prompts')}}
  OPTIONAL MATCH (root)-[:HAS_PROMPT]->(prompt)
  OPTIONAL MATCH (root)-[:HAS_RULES]->(rules)
{{/if}}
{{#if (includes 'seo')}}
  OPTIONAL MATCH (concept)-[:TARGETS_SEO]->(seoKeyword:SEOKeywordL10n)-[:FOR_LOCALE]->(locale)
{{/if}}
{{#if (includes 'geo')}}
  OPTIONAL MATCH (concept)-[:TARGETS_GEO]->(geoSeed:GEOSeedL10n)-[:FOR_LOCALE]->(locale)
{{/if}}
  RETURN root,
         collect(DISTINCT block) AS blocks,
         collect(DISTINCT concept) AS concepts,
         collect(DISTINCT conceptL10n) AS conceptL10ns

# Documentation
docs:
  usage: |
    Use this view to fetch {{rootType}} data with related entities.

    Example with NovaNetFilter:
    ```typescript
    const filter = NovaNetFilter.create()
      .from{{rootType}}('your-{{snakeCase rootType}}-key')
      .forLocale('fr-FR');
    ```

  returns: |
    - root: The {{rootType}} node
    - blocks: Related Block nodes (if included)
    - concepts: Related Concept nodes (if included)
    - conceptL10ns: Localized concept data (if included)
